# 企业微信 API 爬虫环境变量配置示例
# 复制此文件为 .env 并修改配置

# 爬虫配置
WXWORK_BASE_URL=https://developer.work.weixin.qq.com
WXWORK_START_PATH=/document/path/91201
WXWORK_OUTPUT_DIR=../api_docs

# 爬虫行为配置
CRAWL_DELAY=2  # 请求间隔（秒）
MAX_DEPTH=10   # 最大爬取深度
TIMEOUT=30     # 请求超时时间（秒）

# 输出配置
GENERATE_JSON=true
GENERATE_MARKDOWN=true
GENERATE_INDEX=true
