{
  "page_title": "修改成员假期余额",
  "apis": [
    {
      "group_title": "修改成员假期余额",
      "api_name": "setoneuserquota",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/oa/vacation/setoneuserquota",
      "description": "通过本接口可以修改可见范围内员工的“假期余额”。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "userid",
          "type": "string",
          "required": true,
          "description": "需要修改假期余额的成员的userid"
        },
        {
          "name": "vacation_id",
          "type": "uint32",
          "required": true,
          "description": "假期id"
        },
        {
          "name": "leftduration",
          "type": "uint32",
          "required": true,
          "description": "设置的假期余额,单位为秒 不能大于1000天或24000小时，当假期时间刻度为按小时请假时，必须为360整倍数，即0.1小时整倍数，按天请假时，必须为8640整倍数，即0.1天整倍数"
        },
        {
          "name": "time_attr",
          "type": "uint32",
          "required": true,
          "description": "假期时间刻度：0-按天请假；1-按小时请假  主要用于校验，必须等于企业假期管理配置中设置的假期时间刻度类型"
        },
        {
          "name": "remarks",
          "type": "string",
          "required": false,
          "description": "修改备注，用于显示在假期余额的修改记录当中，可对修改行为作说明，不超过200字符"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码描述"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"userid\": \"ZhangSan\",\n    \"vacation_id\": 1,\n    \"leftduration\": 604800,\n    \"time_attr\": 1,\n    \"remarks\": \"PLACE_HOLDER\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "自建应用：配置到「审批 - 可调用接口的应用」中\n代开发应用：具有「审批」权限\n第三方应用：具有「审批」权限\n\n注：从2023年12月1日0点起，不再支持通过系统应用secret调用接口，存量企业暂不受影响 查看详情"
        },
        {
          "title": "错误说明",
          "content": "301062 - 没有假勤权限\n301063 - 参数错误\n301064 - 内部错误\n301098 - 成员不在假期的适用范围内"
        }
      ]
    }
  ]
}