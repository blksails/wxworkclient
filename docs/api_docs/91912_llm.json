{
  "page_title": "获取企业授权信息",
  "apis": [
    {
      "group_title": "获取企业授权信息",
      "api_name": "get_auth_info",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/service/get_auth_info?suite_access_token=SUITE_ACCESS_TOKEN",
      "description": "通过永久授权码换取企业微信的授权信息。",
      "query_params": [
        {
          "name": "suite_access_token",
          "type": "string",
          "required": true,
          "description": "第三方应用凭证"
        }
      ],
      "body_params": [
        {
          "name": "auth_corpid",
          "type": "string",
          "required": true,
          "description": "授权方corpid"
        },
        {
          "name": "permanent_code",
          "type": "string",
          "required": true,
          "description": "永久授权码，通过get_permanent_code获取"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "edition_info",
          "type": "object",
          "required": false,
          "description": "企业当前生效的版本信息"
        },
        {
          "name": "edition_info.agent",
          "type": "object[]",
          "required": false,
          "description": "授权的应用信息"
        },
        {
          "name": "edition_info.agent[].agentid",
          "type": "int32",
          "required": false,
          "description": "应用ID"
        },
        {
          "name": "edition_info.agent[].edition_id",
          "type": "string",
          "required": false,
          "description": "版本ID，可在服务商平台查看已配置的付费版本信息"
        },
        {
          "name": "edition_info.agent[].edition_name",
          "type": "string",
          "required": false,
          "description": "版本名称"
        },
        {
          "name": "edition_info.agent[].app_status",
          "type": "int32",
          "required": false,
          "description": "付费状态"
        },
        {
          "name": "edition_info.agent[].user_limit",
          "type": "int32",
          "required": false,
          "description": "用户上限"
        },
        {
          "name": "edition_info.agent[].expired_time",
          "type": "int32",
          "required": false,
          "description": "版本到期时间"
        },
        {
          "name": "edition_info.agent[].is_virtual_version",
          "type": "bool",
          "required": false,
          "description": "是否虚拟版本"
        },
        {
          "name": "edition_info.agent[].is_shared_from_other_corp",
          "type": "bool",
          "required": false,
          "description": "是否由互联企业分享安装"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"auth_corpid\": \"auth_corpid_value\",\n\t\"permanent_code\": \"code_value\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"edition_info\": {\n\t\t\"agent\": [\n\t\t\t{\n\t\t\t\t\"agentid\": 1,\n\t\t\t\t\"edition_id\": \"RLS65535\",\n\t\t\t\t\"edition_name\": \"协同版\",\n\t\t\t\t\"app_status\": 3,\n\t\t\t\t\"user_limit\": 200,\n\t\t\t\t\"expired_time\": 1541990791,\n\t\t\t\t\"is_virtual_version\": false,\n\t\t\t\t\"is_shared_from_other_corp\": true\n\t\t\t}\n\t\t]\n\t}\n}"
        }
      ],
      "sections": []
    }
  ]
}