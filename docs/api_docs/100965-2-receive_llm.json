{
  "group_title": "变更授权通知",
  "api_name": "receive",
  "method": "POST",
  "api_url": "https://127.0.0.1/suite/receive",
  "description": "当授权方（即授权企业）在企业微信管理端的授权管理中，修改了对应用的授权后，企业微信服务器推送变更授权通知。支持第三方应用以及代开发应用。",
  "query_params": [
    {
      "name": "msg_signature",
      "type": "string",
      "required": true,
      "description": "消息签名"
    },
    {
      "name": "timestamp",
      "type": "string",
      "required": true,
      "description": "时间戳"
    },
    {
      "name": "nonce",
      "type": "string",
      "required": true,
      "description": "随机数"
    }
  ],
  "body_params": [
    {
      "name": "SuiteId",
      "type": "string",
      "required": true,
      "description": "第三方应用的SuiteId或者代开发应用模板id"
    },
    {
      "name": "InfoType",
      "type": "string",
      "required": true,
      "description": "change_auth"
    },
    {
      "name": "TimeStamp",
      "type": "string",
      "required": true,
      "description": "时间戳"
    },
    {
      "name": "AuthCorpId",
      "type": "string",
      "required": true,
      "description": "授权方的corpid"
    },
    {
      "name": "State",
      "type": "string",
      "required": true,
      "description": "构造授权链接指定的state参数"
    },
    {
      "name": "ExtraInfo",
      "type": "string",
      "required": false,
      "description": "额外信息，部分场景会携带，在其他文档中分别描述"
    }
  ],
  "response_params": [],
  "request_examples": [
    {
      "title": "请求包体示例",
      "language": "xml",
      "code": "<xml>\n\t<SuiteId><![CDATA[ww4asffe99exxx0f4c]]></SuiteId>\n\t<InfoType><![CDATA[change_auth]]></InfoType>\n\t<TimeStamp>1403610513</TimeStamp>\n\t<AuthCorpId><![CDATA[wxf8b4f85f3a794e77]]></AuthCorpId>\n\t<State><![CDATA[abc]]></State>\n\t<ExtraInfo></ExtraInfo>\n</xml>"
    }
  ],
  "response_examples": [],
  "sections": [
    {
      "title": "参数说明",
      "content": "| 参数 | 说明 |\n| --- | --- |\n| SuiteId | 第三方应用的SuiteId或者代开发应用模板id |\n| InfoType | change_auth |\n| TimeStamp | 时间戳 |\n| AuthCorpId | 授权方的corpid |\n| State | 构造授权链接指定的state参数 |\n| ExtraInfo | 额外信息，部分场景会携带，在其他文档中分别描述 |"
    }
  ]
}