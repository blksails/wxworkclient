      "body_params": [],
      "response_params": [
        {
          "name": "ServiceCorpId",
          "type": "string",
          "required": false,
          "description": "服务商CorpID"
        },
        {
          "name": "InfoType",
          "type": "string",
          "required": false,
          "description": "事件类型，此时固定为license_pay_success"
        },
        {
          "name": "AuthCorpId",
          "type": "string",
          "required": false,
          "description": "客户企业CorpID"
        },
        {
          "name": "OrderId",
          "type": "string",
          "required": false,
          "description": "订单号。如果为多企业新购订单，该值为子订单号"
        },
        {
          "name": "BuyerUserId",
          "type": "string",
          "required": false,
          "description": "服务商内下单用户UserID"
        },
        {
          "name": "TimeStamp",
          "type": "uint32",
          "required": false,
          "description": "时间戳"
        }
      ],
      "request_examples": [],
      "response_examples": [
        {
