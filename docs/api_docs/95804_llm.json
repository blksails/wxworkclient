          "language": "xml",
          "code": "<xml>\n\t<ServiceCorpId><![CDATA[xxxx]]></ServiceCorpId>\n\t<InfoType><![CDATA[license_pay_success]]></InfoType>\n\t<AuthCorpId><![CDATA[yyyy]]></AuthCorpId>\n\t<OrderId><![CDATA[zzzz]]></OrderId>\n\t<BuyerUserId><![CDATA[USERID]]></BuyerUserId>\n\t<TimeStamp>1403610513</TimeStamp>\n</xml>"
        }
      ],
      "sections": []
    }
  ]
