{
  "page_title": "创建收款订单",
  "apis": [
    {
      "group_title": "创建收款订单",
      "api_name": "open_order",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/paytool/open_order?provider_access_token=PROVIDER_ACCESS_TOKEN",
      "description": "服务商可以使用该接口创建各种业务的收款订单",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "服务商调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "business_type",
          "type": "uint32",
          "required": true,
          "description": "业务类型 取值范围：1 - 普通第三方应用；2 - 代开发应用；3 - 行业解决方案"
        },
        {
          "name": "custom_corpid",
          "type": "string",
          "required": false,
          "description": "客户企业corpid。可以不指定 不多于64字节"
        },
        {
          "name": "pay_type",
          "type": "uint32",
          "required": true,
          "description": "支付方式 取值范围：0-客户支付；1-服务商代支付；2-免支付"
        },
        {
          "name": "bank_receipt_media_id",
          "type": "string",
          "required": false,
          "description": "支付方式选择服务商代支付时，需上传企业已支付服务商订单费用的凭证，凭证需是银行收款回单或发票。"
        },
        {
          "name": "creator",
          "type": "string",
          "required": false,
          "description": "订单创建人的userid，设置的创建人需要有收银台收款的权限"
        },
        {
          "name": "product_list",
          "type": "object",
          "required": true,
          "description": "具体购买商品"
        },
        {
          "name": "nonce_str",
          "type": "string",
          "required": true,
          "description": "随机字符串，长度要求在32字节以内，用于保证签名不可预测及防重放攻击。"
        },
        {
          "name": "ts",
          "type": "uint64",
          "required": true,
          "description": "unix时间戳（中国时区）,精确到秒。"
        },
        {
          "name": "sig",
          "type": "string",
          "required": true,
          "description": "数字签名。签名所需密钥获取路径： 工作台->企业微信服务商助手->工具->收银台->收银台API调用密钥"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码描述"
        },
        {
          "name": "order_id",
          "type": "string",
          "required": false,
          "description": "收款订单号"
        },
        {
          "name": "order_url",
          "type": "string",
          "required": false,
          "description": "收款订单链接 客户支付订单为订单支付链接，服务商代支付和免支付订单为订单确认链接"
        },
        {
          "name": "origin_price",
          "type": "uint32",
          "required": false,
          "description": "原价，单位分, 仅部分可以确定价格的请求下会返回"
        },
        {
          "name": "paid_price",
          "type": "uint32",
          "required": false,
          "description": "折后价，单位分, 仅部分可以确定价格的请求下会返回 代开发应用的原价和折后价一致"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n  \"business_type\": 1,\n  \"custom_corpid\": \"wx979abee1572365f9\",\n  \"pay_type\": 1,\n  \"bank_receipt_media_id\": \"MEDIA_ID_XXX\",\n  \"creator\": \"CREATOR\",\n  \"product_list\": {\n    \"third_app\": {\n      \"order_type\": 0,\n      \"buy_info_list\": [{\n          \"suiteid\": \"wx63bea8582b858ee7\",\n          \"appid\": 1,\n          \"edition_id\": \"sp7fd5170a8e807a44\",\n          \"duration_days\": 1,\n          \"take_effect_date\": \"20221220\",\n          \"user_count\": 10,\n          \"discount_info\": {\n            \"discount_type\": 2,\n            \"discount_amount\": 0,\n            \"discount_ratio\": 75,\n            \"discount_remarks\": \"老客户优惠\"\n          }\n        },\n        {\n          \"suiteid\": \"wx46b0217691d307f7\",\n          \"appid\": 1,\n          \"edition_id\": \"spb5625fc505870d09\",\n          \"duration_days\": 1,\n          \"user_count\": 10\n        }\n      ],\n      \"notify_custom_corp\": 1\n    }\n  },\n  \"nonce_str\": \"129031823\",\n  \"ts\": 1548302135,\n  \"sig\": \"mPOwVW/vQ74xN+b+Yu1KMa9RrmhKJaJjAtXHTof+EpU=\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"order_id\": \"N00000F24364063FC57FACFC5C6A0\",\n    \"order_url\": \"https://open.work.weixin.qq.com/payforapp/PREORDERT0Rkc2g3dWlQNzFLNTRXMDJBV25BNi95OVZZbjBPOE11N2FCWkc0STJRdz0=\",\n    \"origin_price\": 1000,\n    \"paid_price\": 900\n}"
        }
      ],
      "sections": []
    }
  ]
}