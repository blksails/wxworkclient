{
  "page_title": "获取观看直播统计",
  "apis": [
    {
      "group_title": "获取观看直播统计",
      "api_name": "get_watch_stat",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/school/living/get_watch_stat",
      "description": "通过该接口可以获取所有观看直播的人员统计",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "livingid",
          "type": "string",
          "required": true,
          "description": "直播的id"
        },
        {
          "name": "next_key",
          "type": "string",
          "required": false,
          "description": "上一次调用时返回的next_key，初次调用可以填\"0\""
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "ending",
          "type": "int32",
          "required": false,
          "description": "是否结束。0：表示还有更多数据，需要继续拉取，1：表示已经拉取完所有数据。注意只能根据该字段判断是否已经拉完数据"
        },
        {
          "name": "next_key",
          "type": "string",
          "required": false,
          "description": "当前数据最后一个key值，如果下次调用带上该值则从该key值往后拉，用于实现分页拉取"
        },
        {
          "name": "stat_infoes",
          "type": "object",
          "required": false,
          "description": "统计信息列表"
        },
        {
          "name": "stat_infoes.students",
          "type": "object[]",
          "required": false,
          "description": "观看直播的学生列表"
        },
        {
          "name": "stat_infoes.students.student_userid",
          "type": "string",
          "required": false,
          "description": "学生的userid"
        },
        {
          "name": "stat_infoes.students.parent_userid",
          "type": "string",
          "required": false,
          "description": "家长的userid，直播参与者是家长身份才展示，学生身份加入直播不展示"
        },
        {
          "name": "stat_infoes.students.partyids",
          "type": "int32[]",
          "required": false,
          "description": "学生所在的班级id列表"
        },
        {
          "name": "stat_infoes.students.watch_time",
          "type": "int32",
          "required": false,
          "description": "观看时长，单位为秒"
        },
        {
          "name": "stat_infoes.students.enter_time",
          "type": "int32",
          "required": false,
          "description": "首次进入直播时间"
        },
        {
          "name": "stat_infoes.students.leave_time",
          "type": "int32",
          "required": false,
          "description": "最后离开直播时间"
        },
        {
          "name": "stat_infoes.students.is_comment",
          "type": "int32",
          "required": false,
          "description": "是否评论，1表示评论，0表示没有评论"
        },
        {
          "name": "stat_infoes.visitors",
          "type": "object[]",
          "required": false,
          "description": "观看直播的游客列表"
        },
        {
          "name": "stat_infoes.visitors.nickname",
          "type": "string",
          "required": false,
          "description": "微信昵称"
        },
        {
          "name": "stat_infoes.visitors.watch_time",
          "type": "int32",
          "required": false,
          "description": "观看时长，单位为秒"
        },
        {
          "name": "stat_infoes.visitors.enter_time",
          "type": "int32",
          "required": false,
          "description": "首次进入直播时间"
        },
        {
          "name": "stat_infoes.visitors.leave_time",
          "type": "int32",
          "required": false,
          "description": "最后离开直播时间"
        },
        {
          "name": "stat_infoes.visitors.is_comment",
          "type": "int32",
          "required": false,
          "description": "是否评论，1表示评论，0表示没有评论"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"livingid\": \"livingid1\",\n\t\"next_key\": \"NEXT_KEY\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\",\n   \"ending\":1,\n   \"next_key\": \"NEXT_KEY\",\n   \"stat_infoes\":{\n\t\t\"students\":[\n\t\t\t{\n\t\t\t\t\"student_userid\": \"zhansan_child\",\n\t\t\t\t\"parent_userid\": \"zhangsan\",\n\t\t\t\t\"partyids\":[\n\t\t\t\t\t10,11\n\t\t\t\t],\n\t\t\t\t\"watch_time\": 30,\n\t\t\t\t\"enter_time\": 1586433904,\n\t\t\t\t\"leave_time\": 1586434000,\n\t\t\t\t\"is_comment\": 1\n\t\t\t},\n\t\t\t{\n\t\t\t\t\"student_userid\": \"lisi_child\",\n\t\t\t\t\"parent_userid\": \"lisi\",\n\t\t\t\t\"partyids\":[\n\t\t\t\t\t10,11\n\t\t\t\t],\n\t\t\t\t\"watch_time\": 30,\n\t\t\t\t\"enter_time\": 1586433904,\n\t\t\t\t\"leave_time\": 1586434000,\n\t\t\t\t\"is_comment\": 0\n\t\t\t}\n\t\t],\n\t\t\"visitors\":[\n\t\t\t{\n\t\t\t\t\"nickname\": \"wx_nickname1\",\n\t\t\t\t\"watch_time\": 30,\n\t\t\t\t\"enter_time\": 1586433904,\n\t\t\t\t\"leave_time\": 1586434000,\n\t\t\t\t\"is_comment\": 1\n\t\t\t},\n\t\t\t{\n\t\t\t\t\"nickname\": \"wx_nickname2\",\n\t\t\t\t\"watch_time\": 30,\n\t\t\t\t\"enter_time\": 1586433904,\n\t\t\t\t\"leave_time\": 1586434000,\n\t\t\t\t\"is_comment\": 0\n\t\t\t}\n\t\t]\n   }\n}"
        }
      ],
      "sections": []
    }
  ]
}