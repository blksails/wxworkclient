          "description": "调用接口凭证"
        }
      ],
      "body_params": [],
      "response_params": [],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n  \"name\": \"Shared Space\",\n  \"members\": [\"user1\", \"user2\"],\n  \"notify_range\": [\"user3\", \"user4\"]\n}"
        }
      ],
      "response_examples": []
    },
