{
  "page_title": "添加子表",
  "apis": [
    {
      "group_title": "添加子表",
      "api_name": "add_sheet",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedoc/smartsheet/add_sheet",
      "description": "本接口用于在表格的某个位置添加一个智能表，该智能表不存在视图、记录和字段，可以使用 API 在该智能表中添加视图、记录和字段。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "docid",
          "type": "string",
          "required": true,
          "description": "文档的docid"
        },
        {
          "name": "properties",
          "type": "object",
          "required": false,
          "description": "智能表属性"
        },
        {
          "name": "properties.title",
          "type": "string",
          "required": false,
          "description": "智能表标题"
        },
        {
          "name": "properties.index",
          "type": "int32",
          "required": false,
          "description": "智能表下标"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "properties",
          "type": "object",
          "required": false,
          "description": "智能表属性"
        },
        {
          "name": "properties.sheet_id",
          "type": "string",
          "required": false,
          "description": "智能表 ID，创建子表时生成的 6 位随机 ID"
        },
        {
          "name": "properties.title",
          "type": "string",
          "required": false,
          "description": "智能表标题"
        },
        {
          "name": "properties.index",
          "type": "int32",
          "required": false,
          "description": "智能表下标"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"docid\": \"DOCID\",\n\t\"properties\": {\n\t\t\"title\": \"智能表\",\n\t\t\"index\": 3\n\t}\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"properties\": {\n\t\t\"title\": \"智能表\",\n\t\t\"index\": 3,\n\t\t\"sheet_id\": \"123abc\"\n\t}\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "* 自建应用需配置到“可调用应用”列表中的应用secret所获取的accesstoken来调用（accesstoken如何获取？）\n* 第三方应用需具有“文档”权限\n* 代开发自建应用需具有“文档”权限"
        },
        {
          "title": "目录",
          "content": "[上一篇](/document/path/98030)获取表格数据\n[下一篇](/document/path/100197)删除子表"
        }
      ]
    }
  ]
}