{
  "page_title": "通过邮箱获取userid",
  "apis": [
    {
      "group_title": "通过邮箱获取userid",
      "api_name": "get_userid_by_email",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/user/get_userid_by_email",
      "description": "通过邮箱获取其所对应的userid。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证，授权企业的token或上游获取的下游企业的token"
        }
      ],
      "body_params": [
        {
          "name": "email",
          "type": "string",
          "required": true,
          "description": "邮箱"
        },
        {
          "name": "email_type",
          "type": "int32",
          "required": false,
          "description": "邮箱类型：1-企业邮箱（默认）；2-个人邮箱"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "userid",
          "type": "string",
          "required": false,
          "description": "成员UserID。注意：已升级openid的代开发或第三方，获取的是密文userid"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n    \"email\":\"12345@qq.com\",\n    \"email_type\":1\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"userid\": \"zhangsan\"\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "应用须拥有指定成员的查看权限。"
        },
        {
          "title": "更多说明",
          "content": "请确保邮箱的正确性，若出错的次数超过企业人数上限的20%，会导致1天不可调用。"
        }
      ]
    }
  ]
}