          "type": "string",
          "required": true,
          "description": "任务id"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": true,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": true,
          "description": "错误码说明"
        },
        {
          "name": "fail_list",
          "type": "object[]",
          "required": false,
          "description": "错误的消息列表，如msgid不存在、非文本等"
        },
        {
          "name": "fail_list[].errcode",
          "type": "int32",
          "required": true,
          "description": "错误码"
        },
        {
          "name": "fail_list[].errmsg",
          "type": "string",
          "required": true,
          "description": "错误码说明"
        },
        {
          "name": "fail_list[].msgid",
          "type": "string",
          "required": true,
          "description": "每条消息对应的msgid，与入参对应"
        },
        {
          "name": "response_errcode",
          "type": "int32",
          "required": true,
          "description": "专区程序返回的错误码"
        },
        {
          "name": "response_data",
          "type": "string",
          "required": true,
          "description": "专区程序的输出结果，为自定义的JSON字符串"
        }
      ],
      "request_examples": [],
      "response_examples": []
    }
  ]
