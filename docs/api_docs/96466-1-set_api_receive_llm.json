{
  "group_title": "开启接收消息",
  "api_name": "set_api_receive",
  "method": "POST",
  "api_url": "https://api.3dept.com/",
  "description": "企业可以在应用的管理后台开启接收消息模式，需要提供可用的接收消息服务器URL。",
  "query_params": [],
  "body_params": [
    {
      "name": "URL",
      "type": "string",
      "required": true,
      "description": "企业后台接收企业微信推送请求的访问协议和地址，支持http或https协议"
    },
    {
      "name": "Token",
      "type": "string",
      "required": true,
      "description": "用于生成签名的参数"
    },
    {
      "name": "EncodingAESKey",
      "type": "string",
      "required": true,
      "description": "消息体的加密参数"
    }
  ],
  "response_params": [],
  "request_examples": [
    {
      "title": "验证URL有效性请求示例",
      "language": "text",
      "code": "GET https://api.3dept.com/?msg_signature=ASDFQWEXZCVAQFASDFASDFSS&timestamp=13500001234&nonce=123412323&echostr=ENCRYPT_STR"
    }
  ],
  "response_examples": [],
  "sections": [
    {
      "title": "验证URL有效性",
      "content": "企业在获取请求时需要做Urldecode处理，否则可能会验证不成功。企业后台接收到验证请求后，需要作出正确的响应才能通过URL验证。"
    }
  ]
}