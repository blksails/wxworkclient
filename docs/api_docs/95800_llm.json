{
  "page_title": "获取未观看直播统计V2",
  "apis": [
    {
      "group_title": "获取未观看直播统计V2",
      "api_name": "get_unwatch_stat_v2",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/school/living/get_unwatch_stat_v2",
      "description": "通过该接口可以获取未观看直播的学生和家长统计，学生和学生的家长必须是已经关注「学校通知」才会纳入统计范围。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "livingid",
          "type": "string",
          "required": true,
          "description": "直播id"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "上一次调用时返回的next_cursor，初次调用可以填\"0\""
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "has_more",
          "type": "int32",
          "required": false,
          "description": "是否结束。1：表示还有更多数据，需要继续拉取，0：表示已经拉取完所有数据。注意只能根据该字段判断是否已经拉完数据"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "当前数据最后一个cursor值，如果下次调用带上该值则从该cursor值往后拉，用于实现分页拉取"
        },
        {
          "name": "stat_info",
          "type": "object",
          "required": false,
          "description": "统计信息列表"
        },
        {
          "name": "stat_info.students",
          "type": "object[]",
          "required": false,
          "description": "未观看直播的学生列表"
        },
        {
          "name": "stat_info.students.student_userid",
          "type": "string",
          "required": false,
          "description": "学生的userid"
        },
        {
          "name": "stat_info.students.partyids",
          "type": "int32[]",
          "required": false,
          "description": "学生所在的班级id列表"
        },
        {
          "name": "stat_info.parents",
          "type": "object[]",
          "required": false,
          "description": "未观看直播的家长列表"
        },
        {
          "name": "stat_info.parents.parent_userid",
          "type": "string",
          "required": false,
          "description": "家长的userid"
        },
        {
          "name": "stat_info.parents.student_userid",
          "type": "string",
          "required": false,
          "description": "家长对应学生的userid"
        },
        {
          "name": "stat_info.parents.partyids",
          "type": "int32[]",
          "required": false,
          "description": "家长对应学生所在的班级id列表"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"livingid\": \"livingid1\",\n\t\"next_cursor\": \"NEXT_CURSOR\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\",\n   \"has_more\":1,\n   \"next_cursor\": \"NEXT_CURSOR\",\n   \"stat_info\":{\n\t\t\"students\":[\n\t\t\t{\n\t\t\t\t\"student_userid\": \"zhansan_child\",\n\t\t\t\t\"partyids\":[\n\t\t\t\t\t10,11\n\t\t\t\t]\n\t\t\t}，\n\t\t\t{\n\t\t\t\t\"student_userid\": \"lisi_child\",\n\t\t\t\t\"partyids\":[\n\t\t\t\t\t5\n\t\t\t\t]\n\t\t\t}\n\t\t],\n\t\t\"parents\":[\n\t\t\t{\n\t\t\t\t\"parent_userid\": \"zhangsan\",\n\t\t\t\t\"student_userid\": \"zhansan_child\",\n\t\t\t\t\"partyids\":[\n\t\t\t\t\t10,11\n\t\t\t\t]\n\t\t\t}，\n\t\t\t{\n\t\t\t\t\"parent_userid\": \"lisi\",\n\t\t\t\t\"student_userid\": \"lisi_child\",\n\t\t\t\t\"partyids\":[\n\t\t\t\t\t5\n\t\t\t\t]\n\t\t\t}\n\t\t]\n   }\n}"
        }
      ],
      "sections": []
    }
  ]
}