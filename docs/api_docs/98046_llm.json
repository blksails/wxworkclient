{
  "page_title": "取消收款订单",
  "apis": [
    {
      "group_title": "取消收款订单",
      "api_name": "close_order",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/paytool/close_order?provider_access_token=PROVIDER_ACCESS_TOKEN",
      "description": "服务商可以使用该接口取消指定的收款订单",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "服务商调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "order_id",
          "type": "string",
          "required": true,
          "description": "收款订单号 不多于64字节"
        },
        {
          "name": "nonce_str",
          "type": "string",
          "required": true,
          "description": "随机字符串，长度要求在32字节以内，用于保证签名不可预测及防重放攻击。 需保证15分钟内不能重复，推荐随机字符串生成算法"
        },
        {
          "name": "ts",
          "type": "uint64",
          "required": true,
          "description": "unix时间戳（中国时区）,精确到秒。 注意业务系统的机器时间与腾讯的时间相差不能超过15分钟"
        },
        {
          "name": "sig",
          "type": "string",
          "required": true,
          "description": "数字签名。见签名算法。签名所需密钥获取路径： 工作台->企业微信服务商助手->工具->收银台->收银台API调用密钥"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码描述"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"order_id\": \"T0Rkc2g3dWlQNzFLNTRXMDJBV25BNi95OVZZbjBPOE11N2FCWkc0STJRdz0=\",\n\t\"nonce_str\": \"129031823\",\n\t\"ts\": 1548302135,\n\t\"sig\": \"mPOwVW/vQ74xN+b+Yu1KMa9RrmhKJaJjAtXHTof+EpU=\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}