{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "获取激活码详情",
      "api_name": "get_active_info_by_code",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/license/get_active_info_by_code?provider_access_token=ACCESS_TOKEN",
      "description": "查询某个账号激活码的状态以及激活绑定情况。",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "应用服务商的接口调用凭证"
        }
      ],
      "body_params": [
        {
          "name": "corpid",
          "type": "string",
          "required": true,
          "description": "要查询的企业的corpid"
        },
        {
          "name": "active_code",
          "type": "string",
          "required": true,
          "description": "激活码"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "active_info",
          "type": "object",
          "required": false,
          "description": "账号码信息"
        },
        {
          "name": "active_info.active_code",
          "type": "string",
          "required": false,
          "description": "账号激活码"
        },
        {
          "name": "active_info.type",
          "type": "int32",
          "required": false,
          "description": "账号类型：1:基础账号，2:互通账号"
        },
        {
          "name": "active_info.status",
          "type": "int32",
          "required": false,
          "description": "账号状态"
        },
        {
          "name": "active_info.userid",
          "type": "string",
          "required": false,
          "description": "账号绑定激活的企业成员userid，未激活则不返回该字段。返回加密的userid"
        },
        {
          "name": "active_info.create_time",
          "type": "int32",
          "required": false,
          "description": "创建时间"
        },
        {
          "name": "active_info.active_time",
          "type": "int32",
          "required": false,
          "description": "首次激活绑定用户的时间"
        },
        {
          "name": "active_info.expire_time",
          "type": "int32",
          "required": false,
          "description": "过期时间"
        },
        {
          "name": "active_info.merge_info",
          "type": "object",
          "required": false,
          "description": "合并信息"
        },
        {
          "name": "active_info.merge_info.to_active_code",
          "type": "string",
          "required": false,
          "description": "该激活码合并到的新激活码信息"
        },
        {
          "name": "active_info.merge_info.from_active_code",
          "type": "string",
          "required": false,
          "description": "激活码激活userid时，若userid原来已经绑定了一个激活码，则会返回该字段"
        },
        {
          "name": "active_info.share_info",
          "type": "object",
          "required": false,
          "description": "分配信息"
        },
        {
          "name": "active_info.share_info.to_corpid",
          "type": "string",
          "required": false,
          "description": "下游企业corpid"
        },
        {
          "name": "active_info.share_info.from_corpid",
          "type": "string",
          "required": false,
          "description": "上游企业corpid"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"corpid\":\"xxx\",\n\t\"active_code\" : \"XXXXXXXX\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"active_info\": {\n\t\t\"active_code\": \"code1\",\n\t\t\"type\": 1,\n\t\t\"status\": 1,\n\t\t\"userid\": \"USERID\",\n\t\t\"create_time\":1640966400,\n\t\t\"active_time\": 1640966400,\n\t\t\"expire_time\":1640966400,\n\t\t\"merge_info\":\n\t\t{\n\t\t\t  \"to_active_code\":\"code_new\",\n\t\t\t  \"from_active_code\":\"code_old\"\n\t\t},\n\t\t\"share_info\":\n\t\t{\n\t\t\t\"to_corpid\":\"CORPID\",\n\t\t\t\"from_corpid\":\"CORPID\"\n\t\t}\n\t}\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "批量获取激活码详情",
      "api_name": "batch_get_active_info_by_code",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/license/batch_get_active_info_by_code?provider_access_token=ACCESS_TOKEN",
      "description": "批量查询账号激活码的状态以及激活绑定情况。",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "应用服务商的接口调用凭证"
        }
      ],
      "body_params": [
        {
          "name": "corpid",
          "type": "string",
          "required": true,
          "description": "要查询的企业的corpid"
        },
        {
          "name": "active_code_list",
          "type": "array",
          "required": true,
          "description": "激活码列表，最多不超过1000个"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "active_info_list",
          "type": "object[]",
          "required": false,
          "description": "账号码信息列表"
        },
        {
          "name": "active_info_list.active_code",
          "type": "string",
          "required": false,
          "description": "账号激活码"
        },
        {
          "name": "active_info_list.type",
          "type": "int32",
          "required": false,
          "description": "账号类型"
        },
        {
          "name": "active_info_list.status",
          "type": "int32",
          "required": false,
          "description": "账号状态"
        },
        {
          "name": "active_info_list.userid",
          "type": "string",
          "required": false,
          "description": "账号绑定激活的企业成员userid"
        },
        {
          "name": "active_info_list.create_time",
          "type": "int32",
          "required": false,
          "description": "创建时间"
        },
        {
          "name": "active_info_list.active_time",
          "type": "int32",
          "required": false,
          "description": "首次激活绑定用户的时间"
        },
        {
          "name": "active_info_list.expire_time",
          "type": "int32",
          "required": false,
          "description": "过期时间"
        },
        {
          "name": "active_info_list.merge_info",
          "type": "object",
          "required": false,
          "description": "合并信息"
        },
        {
          "name": "active_info_list.share_info",
          "type": "object",
          "required": false,
          "description": "分配信息"
        },
        {
          "name": "invalid_active_code_list",
          "type": "array",
          "required": false,
          "description": "无效的激活码列表"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"corpid\":\"xxx\",\n\t\"active_code_list\" : [\"XXXXXXXX\",\"YYYYYYYY\",\"ZZZZZZZZ\"]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"active_info_list\": [\n\t\t{\n\t\t\t\"active_code\": \"XXXXXXXX\",\n\t\t\t\"type\": 1,\n\t\t\t\"status\": 1,\n\t\t\t\"userid\": \"USERID1\",\n\t\t\t\"create_time\":1640966400,\n\t\t\t\"active_time\": 1640966400,\n\t\t\t\"expire_time\":1640966400,\n\t\t\t\"merge_info\":\n\t\t\t{\n\t\t\t\t\"to_active_code\":\"code_new\",\n\t\t\t\t\"from_active_code\":\"code_old\"\n\t\t\t},\n\t\t\t\"share_info\":\n\t\t\t{\n\t\t\t\t\"to_corpid\":\"CORPID\",\n\t\t\t\t\"from_corpid\":\"CORPID\"\n\t\t\t}\n\t\t},\n\t\t{\n\t\t\t\"active_code\": \"YYYYYYYY\",\n\t\t\t\"type\": 2,\n\t\t\t\"status\": 1,\n\t\t\t\"userid\": \"USERID2\",\n\t\t\t\"create_time\":1640966400,\n\t\t\t\"active_time\": 1640966400,\n\t\t\t\"expire_time\":1640966400,\n\t\t\t\"merge_info\":\n\t\t\t{\n\t\t\t\t\"to_active_code\":\"code_new\",\n\t\t\t\t\"from_active_code\":\"code_old\"\n\t\t\t},\n\t\t\t\"share_info\":\n\t\t\t{\n\t\t\t\t\"to_corpid\":\"CORPID\",\n\t\t\t\t\"from_corpid\":\"CORPID\"\n\t\t\t}\n\t\t}\n\t],\n\t\"invalid_active_code_list\":[\"ZZZZZZZZ\"]\n}"
        }
      ],
      "sections": []
    }
  ]
}