{
  "page_title": "服务商代开发",
  "apis": [
    {
      "group_title": "下单购买账号",
      "api_name": "create_new_order",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/license/create_new_order?provider_access_token=ACCESS_TOKEN",
      "description": "服务商下单为企业购买新的账号，可以同时购买基础账号与互通账号。下单之后，需要到服务商管理端发起支付，支付完成之后，订单才能生效。也可以通过接口使用余额支付订单。",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "应用服务商的接口调用凭证，获取方法参见服务商的凭证"
        }
      ],
      "body_params": [
        {
          "name": "corpid",
          "type": "string",
          "required": true,
          "description": "企业id"
        },
        {
          "name": "buyer_userid",
          "type": "string",
          "required": true,
          "description": "下单人。服务商企业内成员的明文userid。该userid必须登录过企业微信，并且企业微信已绑定微信，且必须为服务商企业内具有“购买接口许可”权限的管理员。最终也支持由其他人支付"
        },
        {
          "name": "account_count.base_count",
          "type": "uint32",
          "required": true,
          "description": "基础账号个数，最多1000000个。(若企业为服务商测试企业，最多购买1000个)"
        },
        {
          "name": "account_count.external_contact_count",
          "type": "uint32",
          "required": true,
          "description": "互通账号个数，最多1000000个。(若企业为服务商测试企业，最多购买1000个)"
        },
        {
          "name": "account_duration.months",
          "type": "uint32",
          "required": true,
          "description": "购买的月数，每个月按照31天计算"
        },
        {
          "name": "account_duration.days",
          "type": "uint32",
          "required": true,
          "description": "购买的天数"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "order_id",
          "type": "string",
          "required": false,
          "description": "订单号"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"corpid\" : \"wwxxx\",\n\t\"buyer_userid\":\"xxxx\",\n\t\"account_count\":{\n\t  \"base_count\":100,\n \t  \"external_contact_count\":100\n\t},\n\t\"account_duration\": {\n\t\t\"months\":2,\n\t\t\"days\":20\n\t}\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"order_id\": \"xxxx\"\n}"
        }
      ],
      "sections": []
    }
  ]
}