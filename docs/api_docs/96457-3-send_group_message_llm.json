{
  "group_title": "发送消息到群聊会话",
  "api_name": "send_group_message",
  "method": "POST",
  "api_url": "https://qyapi.weixin.qq.com/cgi-bin/appchat/send?access_token=ACCESS_TOKEN",
  "description": "企业后台调用接口创建群聊后，可通过应用推送消息到群内",
  "query_params": [],
  "body_params": [
    {
      "name": "chatid",
      "type": "string",
      "required": true,
      "description": "群聊id"
    },
    {
      "name": "msgtype",
      "type": "string",
      "required": true,
      "description": "消息类型，text/image/voice/video/file/textcard/news"
    },
    {
      "name": "text",
      "type": "object",
      "required": false,
      "description": "文本消息内容"
    },
    {
      "name": "image",
      "type": "object",
      "required": false,
      "description": "图片消息内容"
    },
    {
      "name": "news",
      "type": "object",
      "required": false,
      "description": "图文消息内容"
    }
  ],
  "response_params": [
    {
      "name": "errcode",
      "type": "int32",
      "required": true,
      "description": "错误码"
    },
    {
      "name": "errmsg",
      "type": "string",
      "required": true,
      "description": "错误信息"
    }
  ],
  "request_examples": [
    {
      "title": "示例",
      "language": "json",
      "code": "{\n  \"chatid\": \"ChatID\",\n  \"msgtype\": \"text\",\n  \"text\": {\n    \"content\": \"Hello Group\"\n  }\n}"
    }
  ],
  "response_examples": [
    {
      "title": "示例",
      "language": "json",
      "code": "{\n  \"errcode\": 0,\n  \"errmsg\": \"ok\"\n}"
    }
  ],
  "sections": []
}