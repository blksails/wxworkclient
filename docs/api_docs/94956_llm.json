{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "导出任务完成通知",
      "api_name": "batch_job_result",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/webhook/batch_job_result",
      "description": "用于接收任务执行完毕的结果通知，事件回调到提交任务的第三方套件配置的回调地址。",
      "query_params": [],
      "body_params": [
        {
          "name": "SuiteId",
          "type": "string",
          "required": true,
          "description": "套件ID"
        },
        {
          "name": "CreateTime",
          "type": "int32",
          "required": true,
          "description": "消息创建时间（整型）"
        },
        {
          "name": "InfoType",
          "type": "string",
          "required": true,
          "description": "事件类型：batch_job_result"
        },
        {
          "name": "JobId",
          "type": "string",
          "required": true,
          "description": "异步任务id，最大长度为64字符"
        },
        {
          "name": "JobType",
          "type": "string",
          "required": true,
          "description": "操作类型，字符串，在异步导出的场景下分别有：export_user(导出成员详情)、 export_simple_user(导出成员）、export_department(导出部门）、export_taguser(导出标签成员)"
        },
        {
          "name": "ErrCode",
          "type": "int32",
          "required": true,
          "description": "返回码"
        },
        {
          "name": "ErrMsg",
          "type": "string",
          "required": true,
          "description": "对返回码的文本描述内容"
        }
      ],
      "response_params": [],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "xml",
          "code": "<xml>\n\t<SuiteId><![CDATA[ww543f52cb62809e5a]]></SuiteId>\n\t<InfoType><![CDATA[batch_job_result]]></InfoType>\n\t<TimeStamp>1628653600</TimeStamp>\n\t<BatchJob>\n\t\t<JobId><![CDATA[jobid_FTR983N1FNGMsoZKXogNzmLwS8cwu150GTufJB]]></JobId>\n\t\t<JobType><![CDATA[export_user]]></JobType>\n\t\t<ErrCode>0</ErrCode>\n\t\t<ErrMsg><![CDATA[ok]]></ErrMsg>\n\t</BatchJob>\n</xml>"
        }
      ],
