{
  "page_title": "下单成功通知",
  "apis": [
    {
      "group_title": "下单成功通知",
      "api_name": "receive",
      "method": "POST",
      "api_url": "https://127.0.0.1/suite/receive",
      "description": "当企业在应用市场购买付费应用完成下单后，或者服务商在管理端为企业代下单后，企业微信后台会推送下单成功通知到服务商的指令回调URL。",
      "query_params": [
        {
          "name": "msg_signature",
          "type": "string",
          "required": true,
          "description": "消息体签名"
        },
        {
          "name": "timestamp",
          "type": "string",
          "required": true,
          "description": "时间戳"
        },
        {
          "name": "nonce",
          "type": "string",
          "required": true,
          "description": "随机数"
        }
      ],
      "body_params": [
        {
          "name": "SuiteId",
          "type": "string",
          "required": true,
          "description": "第三方应用的SuiteId"
        },
        {
          "name": "PaidCorpId",
          "type": "string",
          "required": true,
          "description": "购买方corpid"
        },
        {
          "name": "InfoType",
          "type": "string",
          "required": true,
          "description": "固定为 open_order"
        },
        {
          "name": "TimeStamp",
          "type": "string",
          "required": true,
          "description": "时间戳"
        },
        {
          "name": "OrderId",
          "type": "string",
          "required": true,
          "description": "订单号，付费订单的唯一标志。服务商可据此拉取购买信息。该OrderId由企业微信生成，不超过32个字符"
        },
        {
          "name": "OperatorId",
          "type": "string",
          "required": true,
          "description": "下单操作者userid，当服务商或代理商代下单时，该字段为空"
        }
      ],
      "response_params": [],
      "request_examples": [
