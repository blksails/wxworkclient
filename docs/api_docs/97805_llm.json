{
  "page_title": "第三方应用开发 - 服务端API",
  "apis": [
    {
      "group_title": "修改文档通知范围及权限",
      "api_name": "mod_doc_member",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedoc/mod_doc_member",
      "description": "该接口用于修改文档、表格、智能表格通知范围列表，可以新增文档、表格、智能表格通知范围并设置权限、修改已有范围的权限以及删除文档、表格、智能表格通知范围内的人员",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "docid",
          "type": "string",
          "required": true,
          "description": "操作的文档id"
        },
        {
          "name": "update_file_member_list",
          "type": "object[]",
          "required": false,
          "description": "更新文档通知范围的列表, 批次大小最大100"
        },
        {
          "name": "update_file_member_list[].type",
          "type": "uint32",
          "required": true,
          "description": "文档通知范围的类型 1:用户。文档通知范围仅支持按人配置"
        },
        {
          "name": "update_file_member_list[].auth",
          "type": "uint32",
          "required": true,
          "description": "文档通知范围内人员获得的权限 1:只读权限 2:读写权限（目前仅智能表可设置为读写权限） 7:管理员权限"
        },
        {
          "name": "update_file_member_list[].userid",
          "type": "string",
          "required": false,
          "description": "企业内成员的ID"
        },
        {
          "name": "update_file_member_list[].tmp_external_userid",
          "type": "string",
          "required": false,
          "description": "外部用户临时id。同一个用户在不同的文档中返回的该id不一致。"
        },
        {
          "name": "del_file_member_list",
          "type": "object[]",
          "required": false,
          "description": "删除的文档通知范围列表，批次大小最大一百"
        },
        {
          "name": "del_file_member_list[].type",
          "type": "uint32",
          "required": true,
          "description": "文档通知范围的类型 1:用户。文档通知范围仅支持按人配置"
        },
        {
          "name": "del_file_member_list[].userid",
          "type": "string",
          "required": false,
          "description": "企业内成员的ID"
        },
        {
          "name": "del_file_member_list[].tmp_external_userid",
          "type": "string",
          "required": false,
          "description": "外部用户临时id。同一个用户在不同的文档中返回的该id不一致。"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"docid\":\"DOCID\",\n    \"update_file_member_list\":[\n        {\n            \"type\":1,\n            \"auth\":7,\n            \"userid\":\"USERID1\"\n        }\n     ],\n    \"del_file_member_list\":[\n        {\n            \"type\":1,\n            \"userid\":\"USERID2\"\n        },\n        {\n            \"type\":1,\n            \"tmp_external_userid\":\"TMP_EXTERNAL_USERID2\"\n        }\n   ]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}