{
  "page_title": "会话消息搜索",
  "apis": [
    {
      "group_title": "会话消息搜索",
      "api_name": "search_msg",
      "method": "SDK调用",
      "api_url": "",
      "description": "可调用该接口对企业会话的内容进行搜索",
      "query_params": [
        {
          "name": "query_word",
          "type": "string",
          "required": true,
          "description": "搜索的关键词，要求大于等于2个UTF8字符"
        },
        {
          "name": "chat_info.chat_type",
          "type": "uint32",
          "required": false,
          "description": "指定会话类型，1：单聊；2：群聊"
        },
        {
          "name": "chat_info.id_list",
          "type": "object[]",
          "required": false,
          "description": "会话双方的id列表，长度必须为2"
        },
        {
          "name": "chat_info.chat_id",
          "type": "string",
          "required": false,
          "description": "指定的群聊会话id"
        },
        {
          "name": "chat_info.msg_type_list",
          "type": "uint32[]",
          "required": false,
          "description": "指定搜索的消息类型"
        },
        {
          "name": "chat_info.sender",
          "type": "object",
          "required": false,
          "description": "指定消息的发送者"
        },
        {
          "name": "chat_info.sender_list",
          "type": "object[]",
          "required": false,
          "description": "指定消息的发送者列表，最多100个"
        },
        {
          "name": "start_time",
          "type": "uint32",
          "required": false,
          "description": "搜索会话范围的起始时间，Unix时间戳"
        },
        {
          "name": "end_time",
          "type": "uint32",
          "required": false,
          "description": "搜索会话范围的结束时间，Unix时间戳"
        },
        {
          "name": "skip_stop_words",
          "type": "bool",
          "required": false,
          "description": "是否去掉部分常见停用词"
        },
        {
          "name": "limit",
          "type": "uint32",
          "required": false,
          "description": "每次请求返回的数据上限，最大为100"
        },
        {
          "name": "cursor",
          "type": "string",
          "required": false,
          "description": "用于分页查询的游标"
        }
      ],
      "body_params": [
        {
          "name": "query_word",
          "type": "string",
          "required": true,
          "description": "搜索的关键词，要求大于等于2个UTF8字符"
        },
        {
          "name": "chat_info",
          "type": "object",
          "required": false,
          "description": "指定要搜索的客户会话范围"
        },
        {
          "name": "start_time",
          "type": "uint32",
          "required": false,
          "description": "指定搜索会话范围的起始时间，Unix时间戳"
        },
        {
          "name": "end_time",
          "type": "uint32",
          "required": false,
          "description": "指定搜索会话范围的结束时间，Unix时间戳"
        },
        {
          "name": "skip_stop_words",
          "type": "bool",
          "required": false,
          "description": "是否在搜索时去掉部分常见停用词"
        },
        {
          "name": "limit",
          "type": "uint32",
          "required": false,
          "description": "每次请求返回的数据上限"
        },
        {
          "name": "cursor",
          "type": "string",
          "required": false,
          "description": "用于分页查询的游标"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "has_more",
          "type": "int32",
          "required": false,
          "description": "是否还有更多数据未获取，0: 否, 1: 是"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "下一次请求的cursor值"
        },
        {
          "name": "msg_list",
          "type": "object[]",
          "required": false,
          "description": "搜索结果的消息列表，按消息发送时间降序排序"
        },
        {
          "name": "msg_list[].msgid",
          "type": "string",
          "required": false,
          "description": "每条消息对应的msgid"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"query_word\": \"欢迎\",\n\t\"chat_info\": {\n\t\t\"chat_type\": 1,\n\t\t\"id_list\": [ {\n\t\t\t\t\"open_userid\": \"OPEN_USERID\"\n\t\t\t\t}, {\n\t\t\t\t\"external_userid\": \"EXTERNALID1\"\n\t\t\t}\n\t\t],\n\t\t\"chat_id\": \"CHAT_ID\",\n\t\t\"msg_type_list\":[1],\n\t\t\"sender\": {\n\t\t\t\"open_userid\": \"OPEN_USERID\"\n\t\t},\n\t\t\"sender_list\": [\n\t\t\t{\n\t\t\t\t\"open_userid\":\"OPEN_USERID\"\n\t\t\t}\n\t\t]\n\t},\n\t\"start_time\": 1668355200,\n\t\"end_time\": 1668528000,\n\t\"skip_stop_words\": true,\n\t\"limit\": 50,\n\t\"cursor\": \"CURSOR\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"has_more\": 1,\n\t\"next_cursor\": \"CURSOR\",\n\t\"msg_list\":[\n\t\t{\n\t\t\t\"msgid\": \"xxxmsgid\"\n\t\t},\n\t\t{\n\t\t\t\"msgid\": \"yyymsgid\"\n\t\t}\n\t]\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "自建应用、代开发应用、第三方应用需具备「数据与智能专区权限」"
        },
        {
          "title": "支持搜索的消息",
          "content": "仅支持对部分消息内容进行搜索，包括：\n- 文本消息：消息内容\n- 链接消息：消息标题\n- 小程序消息：消息标题\n- 文件消息：文件名称\n- 在线文档消息：文档名称\n- 图文混合消息：文本内容\n- 微盘文件消息：文件名称"
        },
        {
          "title": "请求方法",
          "content": "通过SDK调用，具体方式参考[专区程序使用指引](#54006)"
        },
        {
          "title": "IdInfo说明",
          "content": "成员ID：会话者的身份类型为企业成员时填\n客户ID：会话者的身份类型为客户时填"
        }
      ]
    }
  ]
}