{
  "page_title": "ww.sendChatMessage(params)",
  "apis": [
    {
      "group_title": "ww.sendChatMessage",
      "api_name": "sendChatMessage",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/chatdata/sendChatMessage",
      "description": "从聊天工具栏或附件栏打开的页面中向当前会话发送消息",
      "query_params": [],
      "body_params": [
        {
