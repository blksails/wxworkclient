          "required": false,
          "description": "发送完成后进入会话"
        },
        {
          "name": "params.msgtype",
          "type": "string",
          "required": true,
          "description": "消息类型"
        },
        {
          "name": "params.text.content",
          "type": "string",
          "required": true,
          "description": "文本内容"
        },
        {
          "name": "params.success",
          "type": "Function",
          "required": false,
          "description": "成功回调"
        },
        {
          "name": "params.fail",
          "type": "Function",
          "required": false,
          "description": "失败回调"
        },
        {
          "name": "params.cancel",
          "type": "Function",
          "required": false,
          "description": "取消回调"
        },
        {
          "name": "params.complete",
          "type": "Function",
          "required": false,
          "description": "完成回调"
        }
      ],
      "response_params": [
        {
          "name": "Promise<Object>.errMsg",
