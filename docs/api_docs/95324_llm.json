{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "获取应用共享信息",
      "api_name": "list_app_share_info",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/corpgroup/corp/list_app_share_info",
      "description": "局校互联中的局端或者上下游中的上游企业通过该接口可以获取某个应用分享给的所有企业列表。特别注意，对于有敏感权限的应用，需要下级/下游企业确认后才能共享成功，若下级/下游企业未确认，则不会存在于该接口的返回列表",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证，上级/上游企业应用access_token"
        }
      ],
      "body_params": [
        {
          "name": "agentid",
          "type": "int32",
          "required": true,
          "description": "上级/上游企业应用agentid"
        },
        {
          "name": "business_type",
          "type": "int32",
          "required": false,
          "description": "填0则为企业互联/局校互联，填1则表示上下游企业"
        },
        {
          "name": "corpid",
          "type": "string",
          "required": false,
          "description": "下级/下游企业corpid，若指定该参数则表示拉取该下级/下游企业的应用共享信息"
        },
        {
          "name": "limit",
          "type": "int32",
          "required": false,
          "description": "返回的最大记录数，整型，最大值100，默认情况或者值为0表示下拉取全量数据，建议分页拉取或者通过指定corpid参数拉取。"
        },
        {
          "name": "cursor",
          "type": "string",
          "required": false,
          "description": "用于分页查询的游标，字符串类型，由上一次调用返回，首次调用可不填"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "ending",
          "type": "int32",
          "required": false,
          "description": "1表示拉取完毕，0表示数据没有拉取完"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "分页游标，再下次请求时填写以获取之后分页的记录，如果已经没有更多的数据则返回空"
        },
        {
          "name": "corp_list",
          "type": "object[]",
          "required": false,
          "description": "应用共享信息"
        },
        {
          "name": "corp_list.corpid",
          "type": "string",
          "required": false,
          "description": "下级/下游企业corpid"
        },
        {
          "name": "corp_list.corp_name",
          "type": "string",
          "required": false,
          "description": "下级/下游企业名称"
        },
        {
          "name": "corp_list.agentid",
          "type": "int32",
          "required": false,
          "description": "下级/下游企业应用id"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n        \"agentid\":1111,\n\t\t\"business_type\":1,\n\t\t\"corpid\":\"wwcorp\",\n\t\t\"limit\":100,\n\t\t\"cursor\":\"xxxxxx\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\",\n   \"ending\":0\n   \"corp_list\":[\n                {\n                        \"corpid\": \"wwcorpid1\",\n                        \"corp_name\": \"测试企业1\",\n                        \"agentid\": 1111\n                },\n                {\n                        \"corpid\": \"wwcorpid2\",\n                        \"corp_name\": \"测试企业2\",\n                        \"agentid\": 1112\n                }\n   ],\n   \"next_cursor\": \"next_cursor1111\"\n}"
        }
      ],
      "sections": []
    }
  ]
}