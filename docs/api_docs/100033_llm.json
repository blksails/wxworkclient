{
  "page_title": "服务商代开发 - 服务端API - 数据与智能专区 - 专区程序调用sdk - 会话摘要模型",
  "apis": [
    {
      "group_title": "创建摘要提取任务",
      "api_name": "create_summary_task",
      "method": "POST",
      "api_url": "create_summary_task",
      "description": "应用在专区的程序可调用本组接口进行一批会话的摘要提取。",
      "query_params": [],
      "body_params": [
        {
          "name": "msg_list",
          "type": "object[]",
          "required": true,
          "description": "消息列表，每次最多1000个。总和不超过1000个。"
        },
        {
          "name": "msg_list[].msgid",
          "type": "string",
          "required": true,
          "description": "每条消息对应的msgid。多次出现同一个msgid，以首次出现的为准。目前支持文本、语音、音频存档消息"
        },
        {
          "name": "msg_list[].encrypt_info.secret_key",
          "type": "string",
          "required": true,
          "description": "该消息的密钥，将encrypted_secret_key用RSA私钥解密后得到"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "jobid",
          "type": "string",
          "required": false,
          "description": "任务id。首次提交时返回"
        },
        {
          "name": "fail_list",
          "type": "object[]",
          "required": false,
          "description": "提交出错的消息列表，只有msgid重复项返回至该列表"
        },
        {
          "name": "fail_list[].errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "fail_list[].errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "fail_list[].msgid",
          "type": "string",
          "required": false,
          "description": "每条消息对应的msgid，与入参对应"
        },
        {
          "name": "fail_list[].encrypt_info",
          "type": "object",
          "required": false,
          "description": "每条消息对应的加密信息，与入参对应"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"msg_list\":[\n        {\n            \"msgid\": \"MSGID1\",\n            \"encrypt_info\":{\n                \"secret_key\": \"SECRETKEY1\"\n            }\n        },\n        {\n            \"msgid\": \"MSGID2\",\n            \"encrypt_info\":{\n                \"secret_key\": \"SECRETKEY2\"\n            }\n        }\n    ]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "成功响应示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"jobid\": \"JOBID\",\n    \"fail_list\":[\n        {\n            \"errcode\": 710601,\n            \"errmsg\": \"xxx\",\n            \"msgid\": \"MSGID2\",\n            \"encrypt_info\":{\n                \"secret_key\": \"SECRETKEY2\"\n            }\n        }\n    ]\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "获取摘要提取结果",
      "api_name": "get_summary_result",
      "method": "POST",
      "api_url": "get_summary_result",
      "description": "应用在专区的程序可调用本组接口获取摘要提取的结果。",
      "query_params": [],
      "body_params": [
        {
          "name": "jobid",
          "type": "string",
          "required": true,
          "description": "任务id"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "status",
          "type": "int32",
          "required": false,
          "description": "任务执行状态 0: 执行未完成 1: 执行完成 2: 执行失败"
        },
        {
          "name": "fail_list",
          "type": "object[]",
          "required": false,
          "description": "错误的消息列表，如msgid不存在、非文本等"
        },
        {
          "name": "response_data",
          "type": "string",
          "required": false,
          "description": "摘要提取的结果"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"jobid\": \"JOBID\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "成功响应示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"status\": 1,\n    \"fail_list\":[{\n        \"errcode\": 710601,\n        \"errmsg\": \"xxx\",\n        \"msgid\": \"MSGID2\"\n    }],\n    \"response_data\": \"xxx\"\n}"
        }
      ],
      "sections": []
    }
  ]
}