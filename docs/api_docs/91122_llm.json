{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "获取访问用户敏感信息",
      "api_name": "getuserdetail3rd",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/service/auth/getuserdetail3rd?suite_access_token=SUITE_ACCESS_TOKEN",
      "description": "获取访问用户敏感信息",
      "query_params": [
        {
          "name": "suite_access_token",
          "type": "string",
          "required": true,
          "description": "第三方应用的suite_access_token"
        }
      ],
      "body_params": [
        {
          "name": "user_ticket",
          "type": "string",
          "required": true,
          "description": "成员票据"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "corpid",
          "type": "string",
          "required": false,
          "description": "用户所属企业的corpid"
        },
        {
          "name": "userid",
          "type": "string",
          "required": false,
          "description": "成员UserID"
        },
        {
          "name": "name",
          "type": "string",
          "required": false,
          "description": "成员姓名，此字段从2019年12月30日起，对新创建第三方应用不再返回真实name，使用userid代替name返回，2020年6月30日起，对所有历史第三方应用不再返回，第三方页面需要通过通讯录展示组件来展示名字"
        },
        {
          "name": "gender",
          "type": "string",
          "required": false,
          "description": "性别。0表示未定义，1表示男性，2表示女性。仅在用户同意snsapi_privateinfo授权时返回真实值，否则返回0."
        },
        {
          "name": "avatar",
          "type": "string",
          "required": false,
          "description": "头像url。仅在用户同意snsapi_privateinfo授权时返回真实头像，否则返回默认头像"
        },
        {
          "name": "qr_code",
          "type": "string",
          "required": false,
          "description": "员工个人二维码（扫描可添加为外部联系人），仅在用户同意snsapi_privateinfo授权时返回"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n   \"user_ticket\": \"USER_TICKET\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\",\n   \"corpid\":\"wwxxxxxxyyyyy\",\n   \"userid\":\"lisi\",\n   \"name\":\"李四\",\n   \"gender\":\"1\",\n   \"avatar\":\"http://shp.qpic.cn/bizmp/xxxxxxxxxxx/0\",\n   \"qr_code\":\"https://open.work.weixin.qq.com/wwopen/userQRCode?vcode=vcfc13b01dfs78e981c\"\n}"
        }
      ],
      "sections": []
    }
  ]
}