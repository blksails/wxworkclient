{
  "page_title": "删除记录",
  "apis": [
    {
      "group_title": "删除记录",
      "api_name": "delete_records",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedoc/smartsheet/delete_records",
      "description": "本接口用于删除 Smartsheet 的某个子表中的一行或多行记录。单次删除建议在500行内",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "docid",
          "type": "string",
          "required": true,
          "description": "文档的docid"
        },
        {
          "name": "sheet_id",
          "type": "string",
          "required": true,
          "description": "Smartsheet 子表ID"
        },
        {
          "name": "record_ids",
          "type": "string[]",
          "required": true,
          "description": "要删除的记录 ID"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"docid\": \"DOCID\",\n\t\"sheet_id\": \"123Abc\",\n\t\"record_ids\": [\n\t\t\"re9IqD\",\n\t\t\"rpS0P9\"\n\t]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "* 自建应用需配置到“可调用应用”列表中的应用secret所获取的accesstoken来调用（accesstoken如何获取？）\n* 第三方应用需具有“文档”权限\n* 代开发自建应用需具有“文档”权限"
        }
      ]
    }
  ]
}