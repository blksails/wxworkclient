{
  "group_title": "获取企业上下游通讯录分组下的企业详情列表",
  "api_name": "get_chain_corpinfo_list",
  "method": "POST",
  "api_url": "https://qyapi.weixin.qq.com/cgi-bin/corpgroup/corp/get_chain_corpinfo_list",
  "description": "自建应用/代开发应用可通过该接口获取企业上下游通讯录的某个分组下的企业列表",
  "query_params": [
    {
      "name": "access_token",
      "type": "string",
      "required": true,
      "description": "调用接口凭证。上游企业应用access_token"
    }
  ],
  "body_params": [
    {
      "name": "chain_id",
      "type": "string",
      "required": true,
      "description": "上下游id"
    },
    {
      "name": "groupid",
      "type": "int32",
      "required": false,
      "description": "分组id。如果不填，表示根目录"
    },
    {
      "name": "need_pending",
      "type": "bool",
      "required": false,
      "description": "是否需要返回未加入的企业。默认不返回"
    },
    {
      "name": "cursor",
      "type": "string",
      "required": false,
      "description": "开启分页使用，传入返回值next_cursor"
    },
    {
      "name": "limit",
      "type": "int32",
      "required": false,
      "description": ">0开启分页功能"
    }
  ],
  "response_params": [
    {
      "name": "errcode",
      "type": "int32",
      "required": false,
      "description": "返回码"
    },
    {
      "name": "errmsg",
      "type": "string",
      "required": false,
      "description": "对返回码的文本描述内容"
    },
    {
      "name": "has_more",
      "type": "bool",
      "required": false,
      "description": "开启分页时告知是否还有更多记录"
    },
    {
      "name": "next_cursor",
      "type": "string",
      "required": false,
      "description": "下次请求时应传入的cursor"
    },
    {
      "name": "group_corps",
      "type": "object[]",
      "required": false,
      "description": "分组列表数据"
    },
    {
      "name": "group_corps[].groupid",
      "type": "int32",
      "required": false,
      "description": "企业所属上下游的分组id"
    },
    {
      "name": "group_corps[].corpid",
      "type": "string",
      "required": false,
      "description": "企业id，最多64个字节，已加入的企业返回"
    },
    {
      "name": "group_corps[].corp_name",
      "type": "string",
      "required": false,
      "description": "企业名称"
    },
    {
      "name": "group_corps[].custom_id",
      "type": "string",
      "required": false,
      "description": "上下游企业自定义id"
    },
    {
      "name": "group_corps[].invite_userid",
      "type": "string",
      "required": false,
      "description": "该上下游的邀请人的userid"
    },
    {
      "name": "group_corps[].pending_corpid",
      "type": "string",
      "required": false,
      "description": "未加入企业id"
    },
    {
      "name": "group_corps[].is_joined",
      "type": "int32",
      "required": false,
      "description": "企业是否已加入"
    }
  ],
  "request_examples": [],
  "response_examples": []
}