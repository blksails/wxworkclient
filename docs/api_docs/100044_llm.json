{
  "page_title": "产生会话回调通知",
  "apis": [
    {
      "group_title": "产生会话回调通知",
      "api_name": "conversation_new_message",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/webhook/callback?access_token=ACCESS_TOKEN",
      "description": "当企业下新产生消息时，企业微信专区后台会向具有企业会话内容权限的应用关联的程序推送相应的事件消息。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "event_type",
          "type": "string",
          "required": true,
          "description": "事件类型，此时固定为conversation_new_message"
        },
        {
          "name": "timestamp",
          "type": "uint32",
          "required": true,
          "description": "时间戳"
        },
        {
          "name": "conversation_new_message.token",
          "type": "string",
          "required": true,
          "description": "10分钟内有效，用于调用获取会话记录，不超过128字节"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        }
      ],
      "request_examples": [
        {
          "title": "事件示例",
          "language": "json",
          "code": "{\n    \"event_type\": \"conversation_new_message\",\n    \"timestamp\": 1408091189,\n    \"conversation_new_message\": {\n        \"token\": \"zzzzzzzzzzz\"\n    }\n}"
        }
      ],
      "response_examples": [],
      "sections": []
    }
  ]
}