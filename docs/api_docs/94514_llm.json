{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "查询成员用户是否已授权",
      "api_name": "check_member_auth",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/user/check_member_auth",
      "description": "当企业当前授权模式为成员授权时，可调用该接口查询成员用户是否已授权",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "企业调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "open_userid",
          "type": "string",
          "required": true,
          "description": "企业成员的 open_userid。全局唯一，对于同一个服务商不同的应用 open_userid 是相同的；同一用户，对于不同服务商 open_userid 是不同的"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "is_member_auth",
          "type": "bool",
          "required": false,
          "description": "成员授权模式下，该成员已授权"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"open_userid\": \"xxx\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"is_member_auth\": true\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "仅企业为成员授权模式下可调用"
        }
      ]
    }
  ]
}