{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "修改文件安全设置",
      "api_name": "file_secure_setting",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedrive/file_secure_setting",
      "description": "该接口用于修改文件安全设置，水印相关设置。仅支持在线文档类型。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "fileid",
          "type": "string",
          "required": true,
          "description": "文件fileid"
        },
        {
          "name": "watermark.text",
          "type": "string",
          "required": false,
          "description": "水印文字，此字段不填则保持原样"
        },
        {
          "name": "watermark.margin_type",
          "type": "uint32",
          "required": false,
          "description": "水印类型。1：低密度水印， 2： 高密度水印，此字段不填则保持原样"
        },
        {
          "name": "watermark.show_visitor_name",
          "type": "bool",
          "required": false,
          "description": "是否显示访问人名称，此字段不填则保持原样"
        },
        {
          "name": "watermark.show_text",
          "type": "bool",
          "required": false,
          "description": "是否展示水印文本，此字段不填则保持原样"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n    \"fileid\": \"FILEID\",\n    \"watermark\": {\n        \"text\": \"WATERMARK_TEXT\",\n        \"margin_type\": 0,\n        \"show_visitor_name\": false,\n        \"show_text\": false\n    }\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}