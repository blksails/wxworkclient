{
  "page_title": "服务商代开发",
  "apis": [
    {
      "group_title": "退款通知",
      "api_name": "receive",
      "method": "POST",
      "api_url": "https://127.0.0.1/suite/receive",
      "description": "当某个客户发起有效的退款，经服务商在管理端同意后（或过期自动完成退款），会触发回调事件给服务商，服务商收到退款事件后，需自行通过相关接口重新获取这个客户最新的购买状态",
      "query_params": [
        {
          "name": "msg_signature",
          "type": "string",
          "required": true,
          "description": "消息签名"
        },
        {
          "name": "timestamp",
          "type": "uint32",
          "required": true,
          "description": "时间戳"
        },
        {
          "name": "nonce",
          "type": "uint32",
          "required": true,
          "description": "随机数"
        }
      ],
      "body_params": [
        {
          "name": "SuiteId",
          "type": "string",
          "required": true,
          "description": "第三方应用的SuiteId"
        },
        {
          "name": "PaidCorpId",
          "type": "string",
          "required": true,
          "description": "购买方corpid"
        },
        {
          "name": "InfoType",
          "type": "string",
          "required": true,
          "description": "固定为refund"
        },
        {
          "name": "TimeStamp",
          "type": "uint32",
          "required": true,
          "description": "时间戳"
        },
        {
          "name": "OrderId",
          "type": "string",
          "required": true,
          "description": "订单号，付费订单的唯一标志。服务商可据此拉取购买信息。该OrderId由企业微信生成，不超过32个字符"
        }
      ],
      "response_params": [],
      "request_examples": [
        {
          "title": "xml请求示例",
          "language": "xml",
          "code": "<xml>\n    <SuiteId><![CDATA[ww4asffe99e54c0aaa]]></SuiteId>\n    <PaidCorpId><![CDATA[wxf8b4f85f3a794aaa]]></PaidCorpId>\n    <InfoType><![CDATA[refund]]></InfoType>\n    <TimeStamp>1403610513</TimeStamp>\n    <OrderId><![CDATA[ORDERID]]></OrderId>\n</xml>"
        }
      ],
