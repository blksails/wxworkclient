{
  "page_title": "服务商代开发",
  "apis": [
    {
      "group_title": "导出标签成员",
      "api_name": "taguser",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/export/taguser",
      "description": "异步导出接口，用于导出指定标签的成员信息。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "tagid",
          "type": "uint32",
          "required": true,
          "description": "需要导出的标签"
        },
        {
          "name": "encoding_aeskey",
          "type": "string",
          "required": true,
          "description": "Base64编码后的加密密钥。长度固定为43，从a-z, A-Z, 0-9共62个字符中选取，是AESKey的Base64编码。解码后即为32字节长的AESKey。加密方式采用AES-256-CBC方式，数据采用PKCS#7填充至32字节的倍数；IV初始向量大小为16字节，取AESKey前16字节。"
        },
        {
          "name": "block_size",
          "type": "uint32",
          "required": false,
          "description": "每块数据的人员数和部门数之和，支持范围[104,106]，默认值为106"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "jobid",
          "type": "string",
          "required": false,
          "description": "任务ID，可通过获取导出结果接口查询任务结果"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"tagid\": 1,\n\t\"encoding_aeskey\": \"IJUiXNpvGbODwKEBSEsAeOAPAhkqHqNCF6g19t9wfg2\",\n\t\"block_size\": 1000000\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\",\n   \"jobid\": \"jobid_xxxxxxxxx\"\n}"
        }
      ],
      "sections": []
    }
  ]
}