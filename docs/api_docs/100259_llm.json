{
  "page_title": "提交余额支付订单任务",
  "apis": [
    {
      "group_title": "提交余额支付订单任务",
      "api_name": "submit_pay",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/advanced_api/submit_pay",
      "description": "使用该接口创建支付任务，该接口默认使用充值账户余额进行支付。提交成功后，该订单无法再变更支付方式。",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "应用服务商的接口调用凭证，获取方法参见服务商的凭证"
        }
      ],
      "body_params": [
        {
          "name": "payer_userid",
          "type": "string",
          "required": true,
          "description": "支付人，服务商企业内成员的明文userid，用于充值账户的流水记录。必须为服务商企业内具有“购买高级接口”或者“高级接口管理”权限的成员"
        },
        {
          "name": "order_id",
          "type": "string",
          "required": true,
          "description": "要使用充值账户余额支付的订单id"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"payer_userid\": \"USERID\",\n\t\"order_id\": \"ORDERID\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}