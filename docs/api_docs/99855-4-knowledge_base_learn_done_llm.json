{
  "group_title": "內容学习完成(每个內容学习完成都会回调一次)",
  "api_name": "knowledge_base_learn_done",
  "method": "POST",
  "api_url": "https://qyapi.weixin.qq.com/cgi-bin/chatdata/knowledge_base_learn_done",
  "description": "当每个內容学习完成时，企业微信服务器会向该知识集授权应用关联的程序推送消息。",
  "query_params": [],
  "body_params": [
    {
      "name": "event_type",
      "type": "string",
      "required": true,
      "description": "事件类型，固定为：`knowledge_base_learn_done`"
    },
    {
      "name": "timestamp",
      "type": "uint32",
      "required": true,
      "description": "删除知识集时间戳"
    },
    {
      "name": "knowledge_base_id",
      "type": "string",
      "required": true,
      "description": "知识集ID"
    },
    {
      "name": "knowledge_base_name",
      "type": "string",
      "required": true,
      "description": "知识集名称"
    },
    {
      "name": "doc_id",
      "type": "int32",
      "required": true,
      "description": "內容ID"
    },
    {
      "name": "learn_status",
      "type": "int32",
      "required": true,
      "description": "学习状态。0-学习成功；1-学习失败"
    }
  ],
  "response_params": [],
  "request_examples": [
    {
      "title": "事件示例",
      "language": "json",
      "code": "{\n\t\"event_type\": \"knowledge_base_learn_done\",\n\t\"timestamp\": 1408091189,\n\t\"knowledge_base_learn_done\": {\n\t\t\"knowledge_base_id\": \"xxxxxxx\",\n\t\t\"knowledge_base_name\": \"zzzzz\",\n\t\t\"doc_id\" : 1,\n\t\t\"learn_status\" : 0\n\t}\n}"
    }
  ],
  "response_examples": [],
  "sections": []
}