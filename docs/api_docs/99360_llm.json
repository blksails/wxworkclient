{
  "page_title": "获取收款订单列表",
  "apis": [
    {
      "group_title": "获取收款订单列表",
      "api_name": "get_order_list",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/paytool/get_order_list",
      "description": "服务商可以使用该接口查询指定时间段内创建的各种业务的收款订单列表",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "服务商调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "business_type",
          "type": "uint32",
          "required": false,
          "description": "业务类型 取值范围：1 - 普通第三方应用 2 - 代开发应用 3 - 行业解决方案"
        },
        {
          "name": "start_time",
          "type": "uint32",
          "required": false,
          "description": "起始时间"
        },
        {
          "name": "end_time",
          "type": "uint32",
          "required": false,
          "description": "结束时间"
        },
        {
          "name": "cursor",
          "type": "string",
          "required": false,
          "description": "用于分页查询的游标，字符串类型，由上一次调用返回，首次调用不填"
        },
        {
          "name": "limit",
          "type": "uint32",
          "required": true,
          "description": "分页，预期请求的数据量，取值范围 1 ~ 2000"
        },
        {
          "name": "nonce_str",
          "type": "string",
          "required": true,
          "description": "随机字符串，长度要求在32字节以内，用于保证签名不可预测及防重放攻击。 需保证15分钟内不能重复，推荐随机字符串生成算法"
        },
        {
          "name": "ts",
          "type": "uint64",
          "required": true,
          "description": "unix时间戳（中国时区）,精确到秒。 注意业务系统的机器时间与腾讯的时间相差不能超过15分钟"
        },
        {
          "name": "sig",
          "type": "string",
          "required": true,
          "description": "数字签名。见签名算法。签名所需密钥获取路径： 工作台->企业微信服务商助手->工具->收银台->收银台API调用密钥"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码描述"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "分页游标，下次请求时填写以获取之后分页的记录"
        },
        {
          "name": "has_more",
          "type": "uint32",
          "required": false,
          "description": "是否还有更多数据"
        },
        {
          "name": "pay_order_list",
          "type": "obj[]",
          "required": false,
          "description": "订单列表"
        },
        {
          "name": "pay_order_list[].order_id",
          "type": "string",
          "required": false,
          "description": "订单号"
        },
        {
          "name": "pay_order_list[].create_time",
          "type": "uint64",
          "required": false,
          "description": "订单创建时间"
        },
        {
          "name": "pay_order_list[].custom_corpid",
          "type": "string",
          "required": false,
          "description": "客户企业的corpid"
        },
        {
          "name": "pay_order_list[].buy_content",
          "type": "string",
          "required": false,
          "description": "购买内容"
        },
        {
          "name": "pay_order_list[].origin_price",
          "type": "uint64",
          "required": false,
          "description": "原价金额"
        },
        {
          "name": "pay_order_list[].paid_price",
          "type": "uint64",
          "required": false,
          "description": "实付金额。免支付订单实付金额返回0"
        },
        {
          "name": "pay_order_list[].order_status",
          "type": "uint32",
          "required": false,
          "description": "订单状态。取值范围为： 1 - 待支付 2 - 已支付 3 - 订单取消 4 - 支付过期 5 - 退款申请中 6 - 已退款 7 - 交易完成 8 - 待企业确认 9 - 已部分退款"
        },
        {
          "name": "pay_order_list[].order_from",
          "type": "uint32",
          "required": false,
          "description": "订单来源。取值范围为： 1 - 客户下单 2 - 服务商创建"
        },
        {
          "name": "pay_order_list[].creator",
          "type": "string",
          "required": false,
          "description": "订单创建人"
        },
        {
          "name": "pay_order_list[].pay_type",
          "type": "uint32",
          "required": false,
          "description": "支付方式 0-客户支付；1-服务商代支付；2-免支付"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"business_type\":1,\n    \"start_time\":1670643437,\n    \"end_time\":1671507437,\n    \"cursor\":\"tJzlB9tdqfh-g7i_J-ehOz_TWcd7dSKa39_AqCIeMFw\",\n    \"limit\":0,\n    \"nonce_str\":\"129031823\",\n    \"ts\":1548302135,\n    \"sig\":\"mPOwVW/vQ74xN+b+Yu1KMa9RrmhKJaJjAtXHTof+EpU=\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"next_cursor\": \"5f0uN2RNNsR8Dj0G08XUSg==\",\n    \"has_more\": 1,\n    \"pay_order_list\": [\n        {\n            \"order_id\": \"ORDERID\",\n            \"create_time\": 1672220217,\n            \"custom_corpid\": \"wx9***********65f9\",\n            \"buy_content\": \"BUYCONTENT\",\n            \"origin_price\": 1000,\n            \"paid_price\": 9000,\n            \"order_status\": 1,\n            \"order_from\": 1,\n            \"creator\": \"CREATOR\",\n            \"pay_type\" : 2\n        }\n    ]\n}"
        }
      ],
      "sections": []
    }
  ]
}