      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "config_id",
          "type": "string",
          "required": true,
          "description": "企业联系方式的配置id"
        },
        {
          "name": "scene",
          "type": "int32",
          "required": true,
          "description": "场景。 1 - 群的小程序插件 2 - 群的二维码插件"
        },
        {
          "name": "remark",
          "type": "string",
          "required": false,
          "description": "联系方式的备注信息，用于助记，超过30个字符将被截断"
        },
        {
          "name": "auto_create_room",
          "type": "int32",
          "required": false,
          "description": "当群满了后，是否自动新建群。0-否；1-是。 默认为1"
        },
        {
          "name": "room_base_name",
          "type": "string",
          "required": false,
          "description": "自动建群的群名前缀，当auto_create_room为1时有效。最长40个utf8字符"
        },
        {
          "name": "room_base_id",
          "type": "int32",
          "required": false,
          "description": "自动建群的群起始序号，当auto_create_room为1时有效"
        },
        {
          "name": "chat_id_list",
          "type": "array",
          "required": true,
          "description": "使用该配置的客户群ID列表，最多支持5个。见客户群ID获取方法"
        },
        {
          "name": "state",
