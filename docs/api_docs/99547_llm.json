        },
        {
          "name": "mark_source",
          "type": "bool",
          "required": false,
          "description": "是否标记客户添加来源为该应用创建的「加入群聊」, 默认值为true; 仅对「营销获客」应用生效, 且只能由创建此二维码的应用更新"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"config_id\": \"9ad7fa5cdaa6511298498f979c4722de\",\n\t\"scene\": 2,\n\t\"remark\": \"bb_remark\",\n\t\"auto_create_room\": 1,\n\t\"room_base_name\" : \"销售客服群\",\n\t\"room_base_id\" : 10,\n\t\"chat_id_list\": [\"wrOgQhDgAAH2Yy-CTZ6POca8mlBEdaaa\", \"wrOgQhDgAALPUthpRAKvl7mgiQRw_aaa\"],\n\t\"state\" : \"klsdup3kj3s1\",\n\t\"mark_source\":true\n}"
        }
      ]
    },
