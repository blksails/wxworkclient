          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"config_id\":\"9ad7fa5cdaa6511298498f979c472aaa\"\n}"
        }
      ]
    },
    {
      "group_title": "更新客户群进群方式配置",
      "api_name": "update_join_way",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/groupchat/update_join_way",
