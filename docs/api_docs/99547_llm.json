          "required": true,
          "description": "联系方式的配置id"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "join_way",
          "type": "object",
          "required": false,
          "description": "配置详情"
        }
      ],
      "request_examples": [
