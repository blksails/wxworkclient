{
  "page_title": "获取表格行列信息",
  "apis": [
    {
      "group_title": "获取表格行列信息",
      "api_name": "get_sheet_properties",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedoc/spreadsheet/get_sheet_properties",
      "description": "该接口用于获取在线表格的工作表、行数、列数等。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "docid",
          "type": "string",
          "required": true,
          "description": "在线表格的docid"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "properties",
          "type": "object[]",
          "required": false,
          "description": "工作表属性"
        },
        {
          "name": "properties[].sheet_id",
          "type": "string",
          "required": false,
          "description": "工作表ID，工作表的唯一标识"
        },
        {
          "name": "properties[].title",
          "type": "string",
          "required": false,
          "description": "工作表名称"
        },
        {
          "name": "properties[].row_count",
          "type": "uint32",
          "required": false,
          "description": "表格的总行数"
        },
        {
          "name": "properties[].column_count",
          "type": "uint32",
          "required": false,
          "description": "表格的总列数"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"docid\": \"DOCID\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"properties\": [\n\t\t{\n\t\t\t\"sheet_id\": \"ABCDE\",\n\t\t\t\"title\": \"XXXXXX\",\n\t\t\t\"row_count\": 100,\n\t\t\t\"column_count\": 100\n\t\t}\n\t]\n}"
        }
      ],
      "sections": []
    }
  ]
}