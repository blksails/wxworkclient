{
  "page_title": "全量覆盖成员",
  "apis": [
    {
      "group_title": "全量覆盖成员",
      "api_name": "replaceuser",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/batch/replaceuser",
      "description": "本接口以userid为主键，全量覆盖企业的通讯录成员，任务完成后企业的通讯录成员与提交的文件完全保持一致。请先下载CSV文件，根据需求填写文件内容。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "media_id",
          "type": "string",
          "required": true,
          "description": "上传的csv文件的media_id"
        },
        {
          "name": "to_invite",
          "type": "bool",
          "required": false,
          "description": "是否邀请新建的成员使用企业微信，默认值为true"
        },
        {
          "name": "callback.url",
          "type": "string",
          "required": false,
          "description": "企业应用接收企业微信推送请求的访问协议和地址，支持http或https协议"
        },
        {
          "name": "callback.token",
          "type": "string",
          "required": false,
          "description": "用于生成签名"
        },
        {
          "name": "callback.encodingaeskey",
          "type": "string",
          "required": false,
          "description": "用于消息体的加密，是AES密钥的Base64编码"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "jobid",
          "type": "string",
          "required": false,
          "description": "异步任务id，最大长度为64字节"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n\t\"media_id\":\"xxxxxx\",\n\t\"to_invite\": true,\n\t\"callback\":\n\t{\n\t \t\"url\": \"xxx\",\n\t \t\"token\": \"xxx\",\n\t \t\"encodingaeskey\": \"xxx\"\n\t}\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"jobid\": \"xxxxx\"\n}"
        }
      ],
      "sections": []
    }
  ]
}