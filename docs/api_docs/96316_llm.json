{
  "page_title": "批量获取客户详情",
  "apis": [
    {
      "group_title": "批量获取客户详情",
      "api_name": "get_by_user",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/batch/get_by_user",
      "description": "企业/第三方可通过此接口获取指定成员添加的客户信息列表。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "userid_list",
          "type": "array",
          "required": true,
          "description": "企业成员的userid列表，字符串类型，最多支持100个"
        },
        {
          "name": "cursor",
          "type": "string",
          "required": false,
          "description": "用于分页查询的游标，字符串类型，由上一次调用返回，首次调用可不填"
        },
        {
          "name": "limit",
          "type": "uint32",
          "required": false,
          "description": "返回的最大记录数，整型，最大值100，默认值50，超过最大值时取最大值"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "external_contact_list",
          "type": "object[]",
          "required": false,
          "description": "客户信息列表"
        },
        {
          "name": "external_contact_list[].external_contact",
          "type": "object",
          "required": false,
          "description": "客户基本信息"
        },
        {
          "name": "external_contact_list[].external_contact.external_userid",
          "type": "string",
          "required": false,
          "description": "外部联系人的userid"
        },
        {
          "name": "external_contact_list[].external_contact.name",
          "type": "string",
          "required": false,
          "description": "姓名"
        },
        {
          "name": "external_contact_list[].external_contact.position",
          "type": "string",
          "required": false,
          "description": "职位"
        },
        {
          "name": "external_contact_list[].external_contact.avatar",
          "type": "string",
          "required": false,
          "description": "头像链接"
        },
        {
          "name": "external_contact_list[].external_contact.corp_name",
          "type": "string",
          "required": false,
          "description": "公司名称"
        },
        {
          "name": "external_contact_list[].external_contact.corp_full_name",
          "type": "string",
          "required": false,
          "description": "公司全称"
        },
        {
          "name": "external_contact_list[].external_contact.type",
          "type": "uint32",
          "required": false,
          "description": "类型"
        },
        {
          "name": "external_contact_list[].external_contact.gender",
          "type": "uint32",
          "required": false,
          "description": "性别"
        },
        {
          "name": "external_contact_list[].external_contact.unionid",
          "type": "string",
          "required": false,
          "description": "unionid"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile",
          "type": "object",
          "required": false,
          "description": "外部属性"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr",
          "type": "object[]",
          "required": false,
          "description": "外部属性列表"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].type",
          "type": "uint32",
          "required": false,
          "description": "属性类型"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].name",
          "type": "string",
          "required": false,
          "description": "属性名称"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].text",
          "type": "object",
          "required": false,
          "description": "文本属性"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].text.value",
          "type": "string",
          "required": false,
          "description": "文本值"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].web",
          "type": "object",
          "required": false,
          "description": "网页属性"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].web.url",
          "type": "string",
          "required": false,
          "description": "网页链接"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].web.title",
          "type": "string",
          "required": false,
          "description": "网页标题"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].miniprogram",
          "type": "object",
          "required": false,
          "description": "小程序属性"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].miniprogram.appid",
          "type": "string",
          "required": false,
          "description": "小程序appid"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].miniprogram.pagepath",
          "type": "string",
          "required": false,
          "description": "小程序页面路径"
        },
        {
          "name": "external_contact_list[].external_contact.external_profile.external_attr[].miniprogram.title",
          "type": "string",
          "required": false,
          "description": "小程序标题"
        },
        {
          "name": "external_contact_list[].follow_info",
          "type": "object",
          "required": false,
          "description": "企业成员客户跟进信息"
        },
        {
          "name": "external_contact_list[].follow_info.userid",
          "type": "string",
          "required": false,
          "description": "成员userid"
        },
        {
          "name": "external_contact_list[].follow_info.remark",
          "type": "string",
          "required": false,
          "description": "备注"
        },
        {
          "name": "external_contact_list[].follow_info.description",
          "type": "string",
          "required": false,
          "description": "描述"
        },
        {
          "name": "external_contact_list[].follow_info.createtime",
          "type": "uint32",
          "required": false,
          "description": "创建时间"
        },
        {
          "name": "external_contact_list[].follow_info.tag_id",
          "type": "string[]",
          "required": false,
          "description": "标签ID列表"
        },
        {
          "name": "external_contact_list[].follow_info.remark_corp_name",
          "type": "string",
          "required": false,
          "description": "备注企业名称"
        },
        {
          "name": "external_contact_list[].follow_info.remark_mobiles",
          "type": "string[]",
          "required": false,
          "description": "备注手机号列表"
        },
        {
          "name": "external_contact_list[].follow_info.oper_userid",
          "type": "string",
          "required": false,
          "description": "操作成员userid"
        },
        {
          "name": "external_contact_list[].follow_info.add_way",
          "type": "uint32",
          "required": false,
          "description": "添加方式"
        },
        {
          "name": "external_contact_list[].follow_info.wechat_channels",
          "type": "object",
          "required": false,
          "description": "微信渠道信息"
        },
        {
          "name": "external_contact_list[].follow_info.wechat_channels.nickname",
          "type": "string",
          "required": false,
          "description": "微信昵称"
        },
        {
          "name": "external_contact_list[].follow_info.wechat_channels.source",
          "type": "uint32",
          "required": false,
          "description": "来源"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "分页游标，再下次请求时填写以获取之后分页的记录，如果已经没有更多的数据则返回空"
        },
        {
          "name": "fail_info.unlicensed_userid_list",
          "type": "string[]",
          "required": false,
          "description": "无许可的userid列表"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n   \"userid_list\":\n   [\n\t\t\"zhangsan\",\n\t\t\"lisi\"\n\t],\n   \"cursor\":\"\",\n   \"limit\":100\n}"
        }
      ],
