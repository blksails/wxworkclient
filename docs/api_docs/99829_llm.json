{
  "page_title": "第三方应用开发 - 服务端API - 数据与智能专区 - 专区程序调用sdk - 关键词规则管理",
  "apis": [
    {
      "group_title": "新增关键词规则",
      "api_name": "create_rule",
      "method": "POST",
      "api_url": "create_rule",
      "description": "通过此接口新建关键词规则，最多可创建500条规则。",
      "query_params": [],
      "body_params": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "关键词规则名称，长度限制1~20个字符"
        },
        {
          "name": "keyword.word_list",
          "type": "string[]",
          "required": false,
          "description": "关键词列表，长度1~32个字符，列表大小不超过20个。关键词列表与关键行为列表必须选填一项"
        },
        {
          "name": "keyword.is_case_sensitive",
          "type": "bool",
          "required": false,
          "description": "匹配关键词时是否区分大小写，0-不区分；1-区分，默认为区分。如果传了该字段，word_list不能为空"
        },
        {
          "name": "keyword.match_rule",
          "type": "int32",
          "required": false,
          "description": "关键词匹配方式，0-包含；1-完全匹配，默认为包含。如果传了该字段，word_list不能为空"
        },
        {
          "name": "keyword.is_trim_msg",
          "type": "bool",
          "required": false,
          "description": "是否将消息前后的空格、制表符和换行符去掉后进行匹配，0-否；1-是，默认为否。仅match_rule=1时生效"
        },
        {
          "name": "semantics.semantics_list",
          "type": "int32[]",
          "required": false,
          "description": "关键行为列表 1-红包 2-手机号码 3-邮箱地址 ...（详细列表见文档）"
        },
        {
          "name": "applicable_range",
          "type": "object",
          "required": false,
          "description": "规则适用说明，详细说明参考规则适用范围结构体说明"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "rule_id",
          "type": "string",
          "required": false,
          "description": "关键词规则id"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"name\": \"已回复\",\n\t\"keyword\": {\n\t\t\"word_list\": [\"收到\", \"好的\"],\n\t\t\"is_case_sensitive\":1,\n\t\t\"match_rule\":1,\n\t\t\"is_trim_msg\":1\n\t},\n\t\"semantics\": {\n\t\t\"semantics_list\": [1, 2]\n\t},\n\t\"applicable_range\": {...}\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"rule_id\":\"vvvvvvvvvvvvvvvvvxxxx\"\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "获取关键词列表",
      "api_name": "get_rule_list",
      "method": "POST",
      "api_url": "get_rule_list",
      "description": "通过此接口获取客户企业下的关键词规则列表",
      "query_params": [],
      "body_params": [
        {
          "name": "cursor",
          "type": "string",
          "required": false,
          "description": "由企业微信后台返回，第一次调用可不填"
        },
        {
          "name": "limit",
          "type": "int32",
          "required": false,
          "description": "指定获取的数量上限，不填默认100"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "rule_list",
          "type": "object[]",
          "required": false,
          "description": "规则列表"
        },
        {
          "name": "has_more",
          "type": "bool",
          "required": false,
          "description": "是否还有更多数据"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "下次调用时将该字段填入cursor中"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"cursor\":\"XMGIENJGJ\",\n\t\"limit\":100\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"rule_list\": [{\n\t\t\"rule_id\": \"xxxxxxxxx\",\n\t\t\"name\": \"已回复\",\n\t\t\"create_time\": 16666666666\n\t}],\n\t\"has_more\":false,\n\t\"next_cursor\":\"JIUENGMG\"\n}"
        }
      ],
      "sections": []
    },
