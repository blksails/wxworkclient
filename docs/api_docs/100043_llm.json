      "group_title": "客户同意进行聊天内容存档事件回调",
      "api_name": "chat_archive_audit_approved_single",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/webhook/receive",
      "description": "回调的json包序列化为字符串传给注册的回调函数data字段",
      "query_params": [],
      "body_params": [
        {
          "name": "event_type",
          "type": "string",
          "required": true,
          "description": "事件类型 当客户在单聊中同意存档时，该字段值为chat_archive_audit_approved_single 当客户在群聊中同意存档时，该字段值为chat_archive_audit_approved_room"
        },
        {
          "name": "timestamp",
          "type": "int32",
          "required": true,
          "description": "时间戳"
        },
        {
          "name": "chat_archive_audit_approved.userid",
          "type": "string",
          "required": true,
          "description": "单聊时返回，企业服务人员的UserID"
        },
        {
          "name": "chat_archive_audit_approved.external_userid",
          "type": "string",
          "required": true,
          "description": "外部联系人的userid，注意不是企业成员的账号"
        },
        {
          "name": "chat_archive_audit_approved.chatid",
          "type": "string",
          "required": true,
          "description": "群聊时返回，所在群聊的ChatId"
        }
      ],
      "response_params": [],
      "request_examples": [
