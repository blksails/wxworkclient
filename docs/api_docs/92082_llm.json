{
  "page_title": "批量更新家长",
  "apis": [
    {
      "group_title": "批量更新家长",
      "api_name": "batch_update_parent",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/school/user/batch_update_parent",
      "description": "用于批量更新家长信息，包括家长UserID、手机号、孩子信息等。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证。获取方法查看“获取access_token”"
        }
      ],
      "body_params": [
        {
          "name": "parents",
          "type": "object[]",
          "required": false,
          "description": "家长列表，每次最多100个"
        },
        {
          "name": "parents[].parent_userid",
          "type": "string",
          "required": true,
          "description": "家长UserID。学校内必须唯一。不区分大小写，长度为1~64个字节。只能由数字、字母和“_-@.”四种字符组成，且第一个字符必须是数字或字母。"
        },
        {
          "name": "parents[].new_parent_userid",
          "type": "string",
          "required": false,
          "description": "更新的家长UserID。不能与已经存在的家长userid相同。每个家长仅能更新一次。"
        },
        {
          "name": "parents[].mobile",
          "type": "string",
          "required": false,
          "description": "家长手机号"
        },
        {
          "name": "parents[].children",
          "type": "object[]",
          "required": false,
          "description": "家长的孩子列表，最多10个"
        },
        {
          "name": "parents[].children[].student_userid",
          "type": "string",
          "required": true,
          "description": "学生的UserID"
        },
        {
          "name": "parents[].children[].relation",
          "type": "string",
          "required": true,
          "description": "家长与学生的关系，最长32字节"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "result_list",
          "type": "object[]",
          "required": false,
          "description": "失败的学生列表"
        },
        {
          "name": "result_list[].parent_userid",
          "type": "string",
          "required": false,
          "description": "失败的家长userid"
        },
        {
          "name": "result_list[].errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "result_list[].errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"parents\":[\n        {\n            \"parent_userid\": \"zhangsan_baba\",\n            \"new_parent_userid\":\"zhangsan_baba_new\",\n            \"mobile\": \"10000000000\",\n            \"children\":[\n                {\n                    \"student_userid\": \"zhangsan\",\n                    \"relation\": \"爸爸\"\n                }\n            ]\n        },\n        {\n            \"parent_userid\": \"lisi_mama\",\n            \"mobile\": \"10000000001\",\n            \"children\":[\n                {\n                    \"student_userid\": \"lisi\",\n                    \"relation\": \"妈妈\"\n                }\n            ]\n        }\n    ]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 1,\n\t\"errmsg\": \"invalid parent_userid: lisi_parent_userid\",\n\t\"result_list\": [\n\t\t{\n\t\t\t\"parent_userid\": \"lisi_parent_userid\",\n\t\t\t\"errcode\": 1,\n\t\t\t\"errmsg\": \"invalid parent_userid: lisi_parent_userid\"\n\t\t}\n\t]\n}"
        }
      ],
      "sections": []
    }
  ]
}