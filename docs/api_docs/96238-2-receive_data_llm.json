    },
    {
      "name": "timestamp",
      "type": "int",
      "required": true,
      "description": "时间戳"
    },
    {
      "name": "nonce",
      "type": "string",
      "required": true,
      "description": "随机数"
    }
  ],
  "body_params": [
    {
      "name": "XML Data",
      "type": "object",
      "required": true,
      "description": "加密的消息结构体"
    }
  ],
  "request_examples": [
    {
      "title": "示例",
      "language": "text",
      "code": "<xml>\n   <ToUserName><![CDATA[toUser]]></ToUserName>\n   <AgentID><![CDATA[toAgentID]]></AgentID>\n   <Encrypt><![CDATA[msg_encrypt]]></Encrypt>\n</xml>"
