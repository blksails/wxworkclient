      "group_title": "关于客户朋友圈",
      "api_name": "获取企业全部的发表列表",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/chatdata/get_publish_list",
      "description": "成员可发表内容到微信客户的朋友圈，还可与客户评论互动。企业也可统一创建内容，由成员确认后发表。客户朋友圈可分为企业发表和个人发表两类。",
      "query_params": [],
      "body_params": [],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "publish_list",
          "type": "object[]",
          "required": false,
          "description": "发表列表"
        },
        {
          "name": "publish_list[].type",
          "type": "string",
          "required": false,
          "description": "发表类型"
        },
        {
          "name": "publish_list[].content",
          "type": "string",
          "required": false,
          "description": "发表内容"
        }
      ],
      "request_examples": [],
      "response_examples": [],
      "sections": [
        {
          "title": "关于客户朋友圈",
          "content": "成员可发表内容到微信客户的朋友圈，还可与客户评论互动。企业也可统一创建内容，由成员确认后发表。客户朋友圈可分为以下两类：企业发表和个人发表。"
        }
      ]
