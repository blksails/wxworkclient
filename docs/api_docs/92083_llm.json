{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "设置家校通讯录自动同步模式",
      "api_name": "set_arch_sync_mode",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/school/set_arch_sync_mode",
      "description": "企业和第三方可通过此接口修改家校通讯录与班级标签之间的自动同步模式，注意，一旦设置禁止自动同步，将无法再次开启。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "arch_sync_mode",
          "type": "int32",
          "required": true,
          "description": "家校通讯录同步模式：1-禁止将标签同步至家校通讯录，2-禁止将家校通讯录同步至标签，3-禁止家校通讯录和标签相互同步"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n   \"arch_sync_mode\": 1\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}