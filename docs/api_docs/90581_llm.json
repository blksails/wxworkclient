{
  "page_title": "第三方应用开发 - 服务端API - 推广二维码 - 获取注册码",
  "apis": [
    {
      "group_title": "获取注册码",
      "api_name": "get_register_code",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/service/get_register_code?provider_access_token=PROVIDER_ACCESS_TOKEN",
      "description": "根据注册推广包生成注册码（register_code）",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "服务商provider_access_token，获取方法参见服务商的凭证"
        }
      ],
      "body_params": [
        {
          "name": "template_id",
          "type": "string",
          "required": true,
          "description": "推广包ID，最长为128个字节。在服务商管理端-应用管理-推广二维码，创建的推广码详情可查看。"
        },
        {
          "name": "corp_name",
          "type": "string",
          "required": false,
          "description": "企业名称"
        },
        {
          "name": "admin_name",
          "type": "string",
          "required": false,
          "description": "管理员姓名"
        },
        {
          "name": "admin_mobile",
          "type": "string",
          "required": false,
          "description": "管理员手机号"
        },
        {
          "name": "state",
          "type": "string",
          "required": false,
          "description": "用户自定义的状态值。只支持英文字母和数字，最长为128字节。若指定该参数，接口查询注册状态及注册完成回调事件会相应返回该字段值"
        },
        {
          "name": "follow_user",
          "type": "string",
          "required": false,
          "description": "跟进人的userid，必须是服务商所在企业的成员。若配置该值，则由该注册码创建的企业，在服务商管理后台，该企业的报备记录会自动标注跟进人员为指定成员"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码对应的描述"
        },
        {
          "name": "register_code",
          "type": "string",
          "required": false,
          "description": "注册码，只能消费一次。在访问注册链接时消费。最长为512个字节"
        },
        {
          "name": "expires_in",
          "type": "uint32",
          "required": false,
          "description": "register_code有效期，生成链接需要在有效期内点击跳转"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n    \"template_id\":\"TEMPLATEID\" ,\n    \"corp_name\":\"腾讯科技\",\n    \"admin_name\":\"张三\",\n    \"admin_mobile\":\"12345678901\",\n    \"state\":\"TestState123\",\n    \"follow_user\": \"lisi\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\":0,\n    \"errmsg\":\"ok\",\n    \"register_code\":\"pIKi3wRPNWCGF-pyP-YU5KWjDDD\",\n    \"expires_in\": 600\n}"
        }
      ],
      "sections": []
    }
  ]
}