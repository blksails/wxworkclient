{
  "group_title": "删除部门事件",
  "api_name": "delete_party",
  "method": "POST",
  "api_url": "https://qyapi.weixin.qq.com/cgi-bin/webhook/change_contact",
  "description": "该事件会回调给通讯录同步助手，代开发自建应用以及上游企业共享的应用。",
  "query_params": [],
  "body_params": [
    {
      "name": "ToUserName",
      "type": "string",
      "required": true,
      "description": "企业微信CorpID"
    },
    {
      "name": "FromUserName",
      "type": "string",
      "required": true,
      "description": "此事件该值固定为sys，表示该消息由系统生成"
    },
    {
      "name": "CreateTime",
      "type": "int32",
      "required": true,
      "description": "消息创建时间 （整型）"
    },
    {
      "name": "MsgType",
      "type": "string",
      "required": true,
      "description": "消息的类型，此时固定为event"
    },
    {
      "name": "Event",
      "type": "string",
      "required": true,
      "description": "事件的类型，此时固定为change_contact"
    },
    {
      "name": "ChangeType",
      "type": "string",
      "required": true,
      "description": "此时固定为delete_party"
    },
    {
      "name": "Id",
      "type": "string",
      "required": true,
      "description": "部门Id"
    }
  ],
  "response_params": [],
  "request_examples": [
