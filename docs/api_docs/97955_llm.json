{
  "page_title": "重命名文件",
  "apis": [
    {
      "group_title": "重命名文件",
      "api_name": "file_rename",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedrive/file_rename",
      "description": "该接口用于对指定文件进行重命名。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "fileid",
          "type": "string",
          "required": true,
          "description": "文件fileid"
        },
        {
          "name": "new_name",
          "type": "string",
          "required": true,
          "description": "重命名后的文件名 （注意：文件名最多填255个字符, 英文算1个, 汉字算2个）"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "fileid",
          "type": "string",
          "required": false,
          "description": "文件fileid"
        },
        {
          "name": "file_name",
          "type": "string",
          "required": false,
          "description": "文件名字"
        },
        {
          "name": "spaceid",
          "type": "string",
          "required": false,
          "description": "文件所在的空间spaceid"
        },
        {
          "name": "fatherid",
          "type": "string",
          "required": false,
          "description": "文件所在的目录fileid, 在根目录时为spaceid"
        },
        {
          "name": "file_size",
          "type": "uint64",
          "required": false,
          "description": "文件大小"
        },
        {
          "name": "ctime",
          "type": "uint64",
          "required": false,
          "description": "文件创建时间"
        },
        {
          "name": "mtime",
          "type": "uint64",
          "required": false,
          "description": "文件最后修改时间"
        },
        {
          "name": "file_type",
          "type": "uint32",
          "required": false,
          "description": "文件类型, 1:文件夹 2:文件 3:文档(文档) 4:文档(表格) 5:文档(收集表) 6:文档(幻灯片)"
        },
        {
          "name": "file_status",
          "type": "uint32",
          "required": false,
          "description": "文件状态, 1:正常 2:删除"
        },
        {
          "name": "sha",
          "type": "string",
          "required": false,
          "description": "文件sha"
        },
        {
          "name": "md5",
          "type": "string",
          "required": false,
          "description": "文件md5"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n    \"fileid\": \"FILEID\",\n    \"new_name\": \"NEW_NAME\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"file\": {\n        \"fileid\": \"FILEID\",\n        \"file_name\": \"FILE_NAME\",\n        \"spaceid\": \"SPACEID\",\n        \"fatherid\": \"FATHERID\",\n        \"file_size\": 1777777777,\n        \"ctime\": 17777777777,\n        \"mtime\": 177777777,\n        \"file_type\": 2,\n        \"file_status\": 1,\n        \"sha\": \"SHA\",\n        \"md5\": \"MD5\"\n    }\n}"
        }
      ],
      "sections": []
    }
  ]
}