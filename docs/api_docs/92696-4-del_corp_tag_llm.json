{
  "group_title": "删除企业客户标签",
  "api_name": "del_corp_tag",
  "method": "POST",
  "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/del_corp_tag?access_token=ACCESS_TOKEN",
  "description": "企业可通过此接口删除客户标签库中的标签，或删除整个标签组。",
  "query_params": [
    {
      "name": "access_token",
      "type": "string",
      "required": true,
      "description": "调用接口凭证"
    }
  ],
  "body_params": [
    {
      "name": "tag_id",
      "type": "string[]",
      "required": false,
      "description": "标签的id列表"
    },
    {
      "name": "group_id",
      "type": "string[]",
      "required": false,
      "description": "标签组的id列表"
    },
    {
      "name": "agentid",
      "type": "string",
      "required": false,
      "description": "授权方安装的应用agentid"
    }
  ],
  "response_params": [
    {
      "name": "errcode",
      "type": "int32",
      "required": false,
      "description": "返回码"
    },
    {
      "name": "errmsg",
      "type": "string",
      "required": false,
      "description": "对返回码的文本描述内容"
    }
  ],
  "request_examples": [
    {
      "title": "请求示例",
      "language": "json",
      "code": "{\n\t\"tag_id\": [\"TAG_ID_1\", \"TAG_ID_2\"],\n\t\"group_id\": [\"GROUP_ID_1\", \"GROUP_ID_2\"],\n\t\"agentid\" : 1000014\n}"
    }
  ],
  "response_examples": [
    {
      "title": "返回结果示例",
      "language": "json",
      "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
    }
  ],
  "sections": []
}