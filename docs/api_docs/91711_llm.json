{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "获取访问用户身份",
      "api_name": "getuserinfo3rd",
      "method": "GET",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/service/getuserinfo3rd",
      "description": "获取访问用户的身份信息。",
      "query_params": [
        {
          "name": "suite_access_token",
          "type": "string",
          "required": true,
          "description": "第三方应用的 suite_access_token"
        },
        {
          "name": "code",
          "type": "string",
          "required": true,
          "description": "通过成员授权获取到的 code，最大为512字节。每次成员授权带上的 code 将不一样，code 只能使用一次，5分钟未被使用自动过期。"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "CorpId",
          "type": "string",
          "required": false,
          "description": "用户所属企业的 corpid"
        },
        {
          "name": "UserId",
          "type": "string",
          "required": false,
          "description": "用户在企业内的 UserID"
        },
        {
          "name": "DeviceId",
          "type": "string",
          "required": false,
          "description": "手机设备号(由企业微信在安装时随机生成，删除重装会改变，升级不受影响)"
        }
      ],
      "request_examples": [],
      "response_examples": [
        {
          "title": "用户属于某个企业示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\",\n   \"CorpId\":\"CORPID\",\n   \"UserId\":\"USERID\",\n   \"DeviceId\":\"DEVICEID\"\n}"
        },
        {
          "title": "用户为学校家长示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\",\n   \"CorpId\":\"wxCorpId1\",\n   \"DeviceId\":\"DEVICEID\",\n   \"external_userid\": \"zhangsan_external\",\n   \"parents\":[\n\t\t{\n\t\t\t\"corpid\": \"wxCorpId1\",\n\t\t\t\"parent_userid\": \"zhangsan\",\n\t\t\t\"external_userid\": \"zhangsan_external\"\n\t\t},\n\t\t{\n\t\t\t\"corpid\": \"wxCorpId2\",\n\t\t\t\"parent_userid\": \"lisi\",\n\t\t\t\"external_userid\": \"lisi_external\"\n\t\t}\n   ]\n}"
        },
        {
          "title": "用户不属于任何企业示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\",\n   \"OpenId\":\"OPENID\",\n   \"DeviceId\":\"DEVICEID\"\n}"
        },
        {
          "title": "出错示例",
          "language": "json",
          "code": "{\n   \"errcode\": 40029,\n   \"errmsg\": \"invalid code\"\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "跳转的域名须完全匹配 access_token 对应第三方应用的可信域名，否则会返回 50001 错误。"
        }
      ]
    }
  ]
}