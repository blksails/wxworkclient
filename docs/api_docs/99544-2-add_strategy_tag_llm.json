{
  "group_title": "为指定规则组创建企业客户标签",
  "api_name": "add_strategy_tag",
  "method": "POST",
  "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/add_strategy_tag?access_token=ACCESS_TOKEN",
  "description": "企业可通过此接口向规则组中添加新的标签组和标签，每个企业的企业标签和规则组标签合计最多可配置10000个。",
  "query_params": [
    {
      "name": "access_token",
      "type": "string",
      "required": true,
      "description": "调用接口凭证"
    }
  ],
  "body_params": [
    {
      "name": "strategy_id",
      "type": "int32",
      "required": true,
      "description": "规则组id"
    },
    {
      "name": "group_id",
      "type": "string",
      "required": false,
      "description": "标签组id"
    },
    {
      "name": "group_name",
      "type": "string",
      "required": false,
      "description": "标签组名称，最长为30个字符"
    },
    {
      "name": "order",
      "type": "int32",
      "required": false,
      "description": "标签组次序值"
    },
    {
      "name": "tag.name",
      "type": "string",
      "required": true,
      "description": "添加的标签名称，最长为30个字符"
    },
    {
      "name": "tag.order",
      "type": "int32",
      "required": false,
      "description": "标签次序值"
    }
  ],
  "response_params": [
    {
      "name": "errcode",
      "type": "int32",
      "required": false,
      "description": "返回码"
    },
    {
      "name": "errmsg",
      "type": "string",
      "required": false,
      "description": "对返回码的文本描述内容"
    },
    {
      "name": "tag_group",
      "type": "object",
      "required": false,
      "description": "标签组信息"
    },
    {
      "name": "tag_group.group_id",
      "type": "string",
      "required": false,
      "description": "标签组id"
    },
    {
      "name": "tag_group.group_name",
      "type": "string",
      "required": false,
      "description": "标签组名称"
    },
    {
      "name": "tag_group.create_time",
      "type": "int32",
      "required": false,
      "description": "标签组创建时间"
    },
    {
      "name": "tag_group.order",
      "type": "int32",
      "required": false,
      "description": "标签组次序值"
    },
    {
      "name": "tag_group.tag",
      "type": "object[]",
      "required": false,
      "description": "标签组内的标签列表"
    },
    {
      "name": "tag_group.tag.id",
      "type": "string",
      "required": false,
      "description": "新建标签id"
    },
    {
      "name": "tag_group.tag.name",
      "type": "string",
      "required": false,
      "description": "新建标签名称"
    },
    {
      "name": "tag_group.tag.create_time",
      "type": "int32",
      "required": false,
      "description": "标签创建时间"
    },
    {
      "name": "tag_group.tag.order",
      "type": "int32",
      "required": false,
      "description": "标签次序值"
    }
  ],
  "request_examples": [
    {
      "title": "请求示例",
      "language": "json",
      "code": "{\n\t\"strategy_id\":1,\n\t\"group_id\": \"GROUP_ID\",\n\t\"group_name\": \"GROUP_NAME\",\n\t\"order\": 1,\n\t\"tag\": [{\n\t\t\t\"name\": \"TAG_NAME_1\",\n\t\t\t\"order\": 1\n\t\t},\n\t\t{\n\t\t\t\"name\": \"TAG_NAME_2\",\n\t\t\t\"order\": 2\n\t\t}\n\t]\n}"
    }
  ],
  "response_examples": [
    {
      "title": "返回结果示例",
      "language": "json",
      "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"tag_group\": {\n\t\t\"group_id\": \"TAG_GROUPID1\",\n\t\t\"group_name\": \"GOURP_NAME\",\n\t\t\"create_time\": 1557838797,\n\t\t\"order\": 1,\n\t\t\"tag\": [{\n\t\t\t\t\"id\": \"TAG_ID1\",\n\t\t\t\t\"name\": \"NAME1\",\n\t\t\t\t\"create_time\": 1557838797,\n\t\t\t\t\"order\": 1\n\t\t\t},\n\t\t\t{\n\t\t\t\t\"id\": \"TAG_ID2\",\n\t\t\t\t\"name\": \"NAME2\",\n\t\t\t\t\"create_time\": 1557838797,\n\t\t\t\t\"order\": 2\n\t\t\t}\n\t\t]\n\t}\n}"
    }
  ],
  "sections": []
}