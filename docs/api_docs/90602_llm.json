{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "设置授权配置",
      "api_name": "set_session_info",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/service/set_session_info?suite_access_token=SUITE_ACCESS_TOKEN",
      "description": "该接口可对某次授权进行配置。可支持测试模式（应用未发布时）。",
      "query_params": [
        {
          "name": "suite_access_token",
          "type": "string",
          "required": true,
          "description": "第三方应用access_token"
        }
      ],
      "body_params": [
        {
          "name": "pre_auth_code",
          "type": "string",
          "required": true,
          "description": "预授权码"
        },
        {
          "name": "session_info",
          "type": "object",
          "required": true,
          "description": "本次授权过程中需要用到的会话信息"
        },
        {
          "name": "session_info.appid",
          "type": "array",
          "required": false,
          "description": "允许进行授权的应用id，如1、2、3， 不填或者填空数组都表示允许授权套件内所有应用（仅旧的多应用套件可传此参数，新开发者可忽略）"
        },
        {
          "name": "session_info.auth_type",
          "type": "int32",
          "required": false,
          "description": "授权类型：0 正式授权， 1 测试授权。 默认值为0。注意，请确保应用在正式发布后的授权类型为“正式授权”"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"pre_auth_code\":\"xxxxx\",\n\t\"session_info\":\n\t{\n\t\t\"appid\":[1,2,3],\n\t\t\"auth_type\":1\n\t}\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}