{
  "group_title": "在管理后台对应用启用工作台自定义展示",
  "api_name": "set_workbench_template",
  "method": "POST",
  "api_url": "https://qyapi.weixin.qq.com/cgi-bin/agent/set_workbench_template?access_token=ACCESS_TOKEN",
  "description": "该接口指定应用自定义模版类型。同时也支持设置企业默认模版数据。若type指定为 'normal' 则为取消自定义模式，改为普通展示模式",
  "query_params": [
    {
      "name": "access_token",
      "type": "string",
      "required": true,
      "description": "调用接口凭证"
    }
  ],
  "body_params": [
    {
      "name": "agentid",
      "type": "uint32",
      "required": true,
      "description": "应用id"
    },
    {
      "name": "type",
      "type": "string",
      "required": true,
      "description": "模版类型，目前支持的自定义类型包括 'keydata'、 'image'、 'list'、 'webview'. 若设置的type为 'normal', 则相当于从自定义模式切换为普通宫格或者列表展示模式"
    },
    {
      "name": "keydata",
      "type": "object",
      "required": false,
      "description": "关键数据型模版数据结构"
    },
    {
      "name": "image",
      "type": "object",
      "required": false,
      "description": "图片型模版数据结构"
    },
    {
      "name": "list",
      "type": "object",
      "required": false,
      "description": "列表型模版数据结构"
    },
    {
      "name": "webview",
      "type": "object",
      "required": false,
      "description": "webview型模版数据结构"
    },
    {
      "name": "replace_user_data",
      "type": "bool",
      "required": false,
      "description": "是否覆盖用户工作台的数据。设置为true的时候，会覆盖企业所有用户当前设置的数据。若设置为false, 则不会覆盖用户当前设置的所有数据。默认为false"
    }
  ],
  "response_params": [
    {
      "name": "errcode",
      "type": "int32",
      "required": true,
      "description": "错误码"
    },
    {
      "name": "errmsg",
      "type": "string",
      "required": true,
      "description": "错误描述"
    }
  ],
  "request_examples": [
    {
      "title": "请求示例",
      "language": "json",
      "code": "{\n    \"agentid\":1000005,\n    \"type\":\"image\",\n    \"image\":{\n        \"url\":\"xxxx\",\n        \"jump_url\":\"http://www.qq.com\"\n    },\n    \"replace_user_data\":true\n}"
    }
  ],
  "response_examples": [
    {
      "title": "返回结果示例",
      "language": "json",
      "code": "{\n   \"errcode\":0,\n   \"errmsg\":\"ok\"\n}"
    }
  ],
  "sections": []
}