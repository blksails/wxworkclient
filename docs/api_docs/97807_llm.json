{
  "page_title": "第三方应用开发 - 服务端API",
  "apis": [
    {
      "group_title": "修改文档安全设置",
      "api_name": "mod_doc_safty_setting",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedoc/mod_doc_safty_setting",
      "description": "该接口用于修改文档、表格、智能表格的安全设置",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "docid",
          "type": "string",
          "required": true,
          "description": "操作的文档id"
        },
        {
          "name": "enable_readonly_copy",
          "type": "bool",
          "required": false,
          "description": "是否允许只读成员复制、下载文档，有值则覆盖"
        },
        {
          "name": "watermark",
          "type": "object",
          "required": false,
          "description": "水印设置"
        },
        {
          "name": "watermark.margin_type",
          "type": "uint32",
          "required": false,
          "description": "水印疏密度，1:稀疏，2:紧密"
        },
        {
          "name": "watermark.show_visitor_name",
          "type": "bool",
          "required": false,
          "description": "是否展示访问者名字水印，有值则覆盖"
        },
        {
          "name": "watermark.show_text",
          "type": "bool",
          "required": false,
          "description": "是否展示文本水印，有值则覆盖"
        },
        {
          "name": "watermark.text",
          "type": "string",
          "required": false,
          "description": "文字水印的文字，有值则覆盖"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n    \"docid\":\"DOCID\",\n    \"enable_readonly_copy\":false,\n    \"watermark\":{\n        \"margin_type\":1,\n        \"show_visitor_name\":true,\n        \"show_text\":true,\n        \"text\":\"test mark\"\n    }\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "* 自建应用需配置到“可调用应用”列表中的应用secret所获取的accesstoken来调用（accesstoken如何获取？）\n* 第三方应用需具有“文档”权限\n* 代开发自建应用需具有“文档”权限\n* 只能操作该应用创建的文档"
        },
        {
          "title": "关联链接",
          "content": "[上一篇](/document/path/97805)修改文档通知范围及权限\n[下一篇](/document/path/100192)管理智能表格内容权限\n[关于腾讯](http://www.tencent.com/)[用户协议](https://work.weixin.qq.com/eula)[帮助中心](https://work.weixin.qq.com/help)© 1998 - 2026 Tencent Inc. All Rights Reserved"
        }
      ]
    }
  ]
}