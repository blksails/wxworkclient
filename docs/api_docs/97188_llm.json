{
  "page_title": "服务商代开发",
  "apis": [
    {
      "group_title": "激活账号",
      "api_name": "active_account",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/license/active_account?provider_access_token=ACCESS_TOKEN",
      "description": "下单购买账号并支付完成之后，先调用获取订单中的账号列表接口获取到账号激活码，然后可以调用该接口将激活码绑定到某个企业员工，以对其激活相应的平台服务能力。",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "应用服务商的接口调用凭证"
        }
      ],
      "body_params": [
        {
          "name": "active_code",
          "type": "string",
          "required": true,
          "description": "账号激活码"
        },
        {
          "name": "corpid",
          "type": "string",
          "required": true,
          "description": "激活码所属企业corpid"
        },
        {
          "name": "userid",
          "type": "string",
          "required": true,
          "description": "待绑定激活的企业成员userid"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"active_code\" : \"XXXXXXXX\",\n\t\"corpid\": \"CORPID\",\n\t\"userid\": \"USERID\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "批量激活账号",
      "api_name": "batch_active_account",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/license/batch_active_account?provider_access_token=ACCESS_TOKEN",
      "description": "可在一次请求里为一个企业的多个成员激活许可账号，便于服务商批量化处理。",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "应用服务商的接口调用凭证"
        }
      ],
      "body_params": [
        {
          "name": "corpid",
          "type": "string",
          "required": true,
          "description": "激活码所属企业corpid"
        },
        {
          "name": "active_list",
          "type": "array",
          "required": true,
          "description": "需要激活的账号列表"
        },
        {
          "name": "active_list[].active_code",
          "type": "string",
          "required": true,
          "description": "账号激活码"
        },
        {
          "name": "active_list[].userid",
          "type": "string",
          "required": true,
          "description": "待绑定激活的企业成员userid"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "active_result",
          "type": "array",
          "required": false,
          "description": "激活结果列表"
        },
        {
          "name": "active_result[].active_code",
          "type": "string",
          "required": true,
          "description": "账号激活码"
        },
        {
          "name": "active_result[].userid",
          "type": "string",
          "required": true,
          "description": "本次激活的企业成员的加密userid"
        },
        {
          "name": "active_result[].errcode",
          "type": "int32",
          "required": true,
          "description": "用户激活错误码，0为成功"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"corpid\": \"CORPID\",\n\t\"active_list\":[\n\t{\n\t\t\"active_code\" : \"XXXXXXXX\",\n\t\t\"userid\": \"USERID\"\n\t},\n\t{\n\t\t\"active_code\" : \"XXXXXXXX\",\n\t\t\"userid\": \"USERID\"\n\t}]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"active_result\":[\n\t{\n\t\t\"active_code\" : \"XXXXXXXX\",\n\t\t\"userid\": \"USERID\",\n\t\t\"errcode\":0\n\t},\n\t{\n\t\t\"active_code\" : \"XXXXXXXX\",\n\t\t\"userid\": \"USERID\",\n\t\t\"errcode\":0\n\t}]\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "指定账号类型激活",
      "api_name": "active_account_by_type",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/license/active_account_by_type?provider_access_token=ACCESS_TOKEN",
      "description": "userid当前必须未激活指定类型的许可或者绑定的该类型账号已过期。从当前企业中选择一个该指定类型的激活截止时间最早的未激活的激活码进行激活。",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "应用服务商的接口调用凭证"
        }
      ],
      "body_params": [
        {
          "name": "type",
          "type": "int32",
          "required": true,
          "description": "账号类型。1：基础账号 2：互通账号"
        },
        {
          "name": "corpid",
          "type": "string",
          "required": true,
          "description": "激活码所属企业corpid"
        },
        {
          "name": "userid",
          "type": "string",
          "required": true,
          "description": "待绑定激活的企业成员userid"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"type\" : 1,\n\t\"corpid\": \"CORPID\",\n\t\"userid\": \"USERID\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}