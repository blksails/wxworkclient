          "type": "string",
          "required": false,
          "description": "企业微信CorpID"
        },
        {
          "name": "FromUserName",
          "type": "string",
          "required": false,
          "description": "此处固定为sys"
        },
        {
          "name": "CreateTime",
          "type": "int32",
          "required": false,
          "description": "消息创建时间，unix时间戳"
        },
        {
          "name": "MsgType",
          "type": "string",
          "required": false,
          "description": "消息类型，此时固定为：`event`"
        },
        {
          "name": "Event",
          "type": "string",
          "required": false,
          "description": "事件类型，此时固定为：`program_notify`"
        },
        {
