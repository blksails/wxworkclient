{
  "page_title": "专区程序接收事件通知",
  "apis": [
    {
      "group_title": "命中关键词规则通知",
      "api_name": "hit_keyword",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/smartdata/event/hit_keyword?access_token=ACCESS_TOKEN",
      "description": "当企业会话内容授权范围内成员的会话命中关键词规则时，企业微信专区后台会向有企业会话内容权限的应用关联的程序推送相应的事件消息。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "event_type",
          "type": "string",
          "required": true,
          "description": "事件类型，此时固定为hit_keyword"
        },
        {
          "name": "timestamp",
          "type": "uint32",
          "required": true,
          "description": "时间戳"
        },
        {
          "name": "hit_keyword.token",
          "type": "string",
          "required": true,
          "description": "10分钟内有效，用于调用获取命中关键词规则的会话记录，不超过128字节"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        }
      ],
      "request_examples": [
        {
          "title": "事件示例",
          "language": "json",
          "code": "{\n    \"event_type\": \"hit_keyword\",\n    \"timestamp\": 1408091189,\n    \"hit_keyword\": {\n        \"token\": \"xxx\"\n    }\n}"
        }
      ],
      "response_examples": []
    }
  ]
}