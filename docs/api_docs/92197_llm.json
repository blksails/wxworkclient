        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "qrcode_big",
          "type": "string",
          "required": false,
          "description": "1200px的大尺寸二维码"
        },
        {
          "name": "qrcode_middle",
          "type": "string",
          "required": false,
          "description": "430px的中尺寸二维码"
        },
        {
          "name": "qrcode_thumb",
          "type": "string",
          "required": false,
          "description": "258px的小尺寸二维码"
        }
      ],
      "request_examples": [],
      "response_examples": [
