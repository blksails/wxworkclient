{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "获取选人ticket对应的用户",
      "api_name": "list_selected_ticket_user",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/user/list_selected_ticket_user",
      "description": "当企业以成员授权的方式安装了第三方应用，成员在企业微信终端通过选人jsapi选择通讯录，应用获取到selectedTicket后，可调用该接口获取SelectedTicket对应的用户open_userid列表。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "selected_ticket",
          "type": "string",
          "required": true,
          "description": "选人jsapi返回的selectedTicket"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "operator_open_userid",
          "type": "string",
          "required": false,
          "description": "选人用户的open_userid"
        },
        {
          "name": "open_userid_list",
          "type": "array",
          "required": false,
          "description": "此次选人操作中，在应用可见范围内的open_userid列表"
        },
        {
          "name": "open_userid_list[].",
          "type": "string",
          "required": false,
          "description": "open_userid列表中的元素"
        },
        {
          "name": "unauth_open_userid_list",
          "type": "array",
          "required": false,
          "description": "此次选人操作中，不在应用可见范围内的open_userid列表"
        },
        {
          "name": "unauth_open_userid_list[].",
          "type": "string",
          "required": false,
          "description": "不在应用可见范围内的open_userid列表中的元素"
        },
        {
          "name": "total",
          "type": "int32",
          "required": false,
          "description": "用户选择的总人数"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"selected_ticket\": \"xxxx\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"operator_open_userid\":\"xxx\",\n\t\"open_userid_list\":[\"xxxx\",\"xxxx\"],\n\t\"unauth_open_userid_list\":[\"yyyy\", \"yyy\"],\n\t\"total\":10\n}"
        }
      ],
      "sections": []
    }
  ]
}