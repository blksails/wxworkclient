{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "新增成员",
      "api_name": "file_acl_add",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedrive/file_acl_add",
      "description": "该接口用于对指定文件添加成员。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "fileid",
          "type": "string",
          "required": true,
          "description": "文件fileid"
        },
        {
          "name": "auth_info",
          "type": "object[]",
          "required": true,
          "description": "添加成员的信息"
        },
        {
          "name": "auth_info[].type",
          "type": "uint32",
          "required": true,
          "description": "成员类型 1:个人 2:部门"
        },
        {
          "name": "auth_info[].userid",
          "type": "string",
          "required": true,
          "description": "成员userid,字符串"
        },
        {
          "name": "auth_info[].departmentid",
          "type": "uint32",
          "required": true,
          "description": "部门departmentid, 32位整型范围是[0, 2^32) (type为2时填写)"
        },
        {
          "name": "auth_info[].auth",
          "type": "uint32",
          "required": true,
          "description": "选项包括1:仅下载（仅浏览）"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n    \"fileid\": \"FILEID\",\n    \"auth_info\": [{\n        \"type\": 2,\n        \"departmentid\": 1,\n        \"auth\": 1\n    }, {\n        \"type\": 1,\n        \"userid\": \"USERID1\",\n        \"auth\": 1\n    }]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "* 自建应用需配置到“可调用应用”列表中的应用secret所获取的accesstoken来调用（accesstoken如何获取？）\n* 第三方应用需具有“微盘”权限\n* 代开发自建应用需具有“微盘”权限"
        }
      ]
    }
  ]
}