{
  "page_title": "管理收集表",
  "apis": [
    {
      "group_title": "收集表的统计信息查询",
      "api_name": "get_form_statistic",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedoc/get_form_statistic",
      "description": "该接口用于获取收集表的统计信息、已回答成员列表和未回答成员列表",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "repeated_id",
          "type": "string",
          "required": true,
          "description": "操作的收集表的 repeated_id，来源于 get_form_info 的返回"
        },
        {
          "name": "req_type",
          "type": "uint32",
          "required": true,
          "description": "请求类型 1: 只获取统计结果 2: 获取已提交列表 3: 获取未提交列表"
        },
        {
          "name": "start_time",
          "type": "uint64",
          "required": false,
          "description": "拉取已提交列表时必填，其余 type 不填。筛选开始时间，以当天的00:00:00开始筛选"
        },
        {
          "name": "end_time",
          "type": "uint64",
          "required": false,
          "description": "拉取已提交列表时必填，其余 type 不填。筛选结束时间，以当天的23:59:59结束筛选"
        },
        {
          "name": "limit",
          "type": "uint64",
          "required": false,
          "description": "分页拉取时批次大小，最大10000"
        },
        {
          "name": "cursor",
          "type": "uint64",
          "required": false,
          "description": "分页拉取的游标，首次不传"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "fill_cnt",
          "type": "uint64",
          "required": false,
          "description": "已填写次数"
        },
        {
          "name": "fill_user_cnt",
          "type": "uint64",
          "required": false,
          "description": "已填写人数"
        },
        {
          "name": "unfill_user_cnt",
          "type": "uint64",
          "required": false,
          "description": "未填写人数"
        },
        {
          "name": "submit_users",
          "type": "object[]",
          "required": false,
          "description": "已填写人列表"
        },
        {
          "name": "tmp_external_userid",
          "type": "string",
          "required": false,
          "description": "外部用户临时id，匿名填写不返回，同一个用户在不同的收集表中返回的该id不一致。可进一步通过 tmp_external_userid 的转换 接口转换成 external_userid，方便识别外部填写人的身份。"
        },
        {
          "name": "userid",
          "type": "string",
          "required": false,
          "description": "企业内成员的id，匿名填写不返回"
        },
        {
          "name": "submit_time",
          "type": "uint64",
          "required": false,
          "description": "提交时间"
        },
        {
          "name": "answer_id",
          "type": "uint64",
          "required": false,
          "description": "答案id"
        },
        {
          "name": "user_name",
          "type": "string",
          "required": false,
          "description": "名字，匿名填写不返回"
        },
        {
          "name": "unfill_users",
          "type": "object[]",
          "required": false,
          "description": "未填写人列表"
        },
        {
          "name": "has_more",
          "type": "bool",
          "required": false,
          "description": "是否还有更多"
        },
        {
          "name": "cursor",
          "type": "uint64",
          "required": false,
          "description": "上次分页拉取返回的 cursor"
        }
      ],
      "request_examples": [
        {
          "title": "仅获取统计结果",
          "language": "json",
          "code": "{\n    \"repeated_id\":\"REPEATED_ID1\",\n    \"req_type\":1\n}"
        },
        {
          "title": "获取已提交的列表",
          "language": "json",
          "code": "{\n    \"repeated_id\":\"REPEATED_ID2\",\n    \"req_type\":2,\n    \"start_time\":1667395287,\n    \"end_time\":1668418369,\n    \"limit\":20,\n    \"cursor\":1\n}"
        },
        {
          "title": "获取未提交的列表",
          "language": "json",
          "code": "{\n    \"repeated_id\":\"REPEATED_ID3\",\n    \"req_type\":3,\n    \"limit\":20,\n    \"cursor\":1\n}"
        }
      ],
      "response_examples": [
        {
          "title": "req_type = 1 仅获取统计信息",
          "language": "json",
          "code": "{\n    \"errcode\":0,\n    \"errmsg\":\"ok\",\n    \"fill_cnt\":1,\n    \"fill_user_cnt\":1,\n    \"unfill_user_cnt\":90\n}"
        },
        {
          "title": "req_type = 2,获取已提交列表",
          "language": "json",
          "code": "{\n    \"errcode\":0,\n    \"errmsg\":\"ok\",\n    \"fill_cnt\":1,\n    \"fill_user_cnt\":1,\n    \"unfill_user_cnt\":90,\n    \"submit_users\":[\n        {\n            \"userid\":\"USERID1\",\n            \"submit_time\":1668418200,\n            \"answer_id\":1,\n            \"user_name\":\"USER_NAME1\"\n        },\n        {\n            \"tmp_external_userid\":\"TMP_EXTERNAL_USERID1\",\n            \"submit_time\":1668418200,\n            \"answer_id\":2,\n            \"user_name\":\"USER_NAME2\"\n        }\n     ],\n    \"has_more\":false,\n    \"cursor\":1\n}"
        },
        {
          "title": "req_type = 3,获取未提交列表",
          "language": "json",
          "code": "{\n    \"errcode\":0,\n    \"errmsg\":\"ok\",\n    \"fill_cnt\":1,\n    \"fill_user_cnt\":1,\n    \"unfill_user_cnt\":90,\n    \"unfill_users\":[\n        {\n            \"userid\":\"USERID1\",\n            \"user_name\":\"USER_NAME1\"\n        }\n    ],\n    \"has_more\":false,\n    \"cursor\":1\n}"
        }
      ],
      "sections": []
    }
  ]
}