{
  "page_title": "通过手机号获取userid",
  "apis": [
    {
      "group_title": "通过手机号获取userid",
      "api_name": "getuserid",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/user/getuserid",
      "description": "通过手机号获取其所对应的userid。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证，授权企业的token或上游获取的下游企业的token"
        }
      ],
      "body_params": [
        {
          "name": "mobile",
          "type": "string",
          "required": true,
          "description": "用户在企业微信通讯录中的手机号码。长度为5~32个字节"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "userid",
          "type": "string",
          "required": false,
          "description": "成员UserID。对应管理端的账号，企业内必须唯一。不区分大小写，长度为1~64个字节。注意：第三方应用获取的值是密文的userid"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n   \"mobile\": \"13430388888\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"userid\": \"zhangsan\"\n}"
        }
      ],
      "sections": []
    }
  ]
}