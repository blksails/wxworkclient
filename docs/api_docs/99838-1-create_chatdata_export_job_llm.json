      "description": "返回码"
    },
    {
      "name": "errmsg",
      "type": "string",
      "required": false,
      "description": "对返回码的文本描述内容"
    },
    {
      "name": "jobid",
      "type": "string",
      "required": false,
      "description": "所创建任务的任务id"
    }
  ],
