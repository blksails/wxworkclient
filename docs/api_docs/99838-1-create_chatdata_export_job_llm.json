    {
      "name": "code",
      "type": "string",
      "required": true,
      "description": "从会话展示组件获取的code，只能使用一次，有效时间为五分钟"
    },
    {
      "name": "media_id",
      "type": "string",
      "required": true,
      "description": "导出内容的模板文件media_id，支持Word(doc/docx)、Excel(xls/xlsx)和Txt(txt)格式的文件"
    }
  ],
  "response_params": [
    {
      "name": "errcode",
      "type": "int32",
