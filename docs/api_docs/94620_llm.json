{
  "page_title": "第三方应用开发 - 服务端API - 应用管理 - 设置工作台自定义展示",
  "apis": [
    {
      "group_title": "在管理后台对应用启用工作台自定义展示",
      "api_name": "set_workbench_template",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/agent/set_workbench_template?access_token=ACCESS_TOKEN",
      "description": "设置应用在工作台展示的模版",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "agentid",
          "type": "uint32",
          "required": true,
          "description": "应用id"
        },
        {
          "name": "type",
          "type": "string",
          "required": true,
          "description": "模版类型，支持的自定义类型包括 'keydata', 'image', 'list', 'webview'. 若设置的type为 'normal', 则相当于从自定义模式切换为普通展示模式"
        },
        {
          "name": "image",
          "type": "object",
          "required": false,
          "description": "图片型模版数据"
        },
        {
          "name": "replace_user_data",
          "type": "bool",
          "required": false,
          "description": "是否覆盖用户工作台的数据"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"agentid\":1000005,\n    \"type\":\"image\",\n    \"image\":{\n        \"url\":\"xxxx\",\n        \"jump_url\":\"http://www.qq.com\"\n    },\n    \"replace_user_data\":true\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n   \"errcode\":0,\n   \"errmsg\":\"ok\"\n}"
        }
      ],
      "sections": []
    },
    {
