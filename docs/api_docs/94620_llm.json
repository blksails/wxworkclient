          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "agentid",
          "type": "uint32",
          "required": true,
          "description": "应用id"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "type",
          "type": "string",
          "required": false,
          "description": "模版类型"
        },
        {
          "name": "image",
          "type": "object",
          "required": false,
          "description": "图片型模版数据"
        },
        {
          "name": "replace_user_data",
          "type": "bool",
          "required": false,
          "description": "是否覆盖用户工作台的数据"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"agentid\":1000005\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n   \"errcode\":0,\n   \"errmsg\":\"ok\",\n   \"type\":\"image\",\n   \"image\":{\n               \"url\":\"xxxx\",\n               \"jump_url\":\"http://www.qq.com\"\n      },\n      \"replace_user_data\":true\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "设置应用在用户工作台展示的数据",
      "api_name": "set_workbench_data",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/agent/set_workbench_data?access_token=ACCESS_TOKEN",
      "description": "设置应用在用户工作台展示的数据",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "agentid",
          "type": "uint32",
          "required": true,
          "description": "应用id"
        },
        {
          "name": "userid",
          "type": "string",
          "required": true,
          "description": "需要设置的用户的userid"
        },
        {
          "name": "type",
          "type": "string",
          "required": true,
          "description": "模版类型，支持 'keydata', 'image', 'list', 'webview'"
        },
        {
          "name": "keydata",
          "type": "object",
          "required": false,
          "description": "关键数据型模版数据"
        },
        {
          "name": "image",
          "type": "object",
          "required": false,
          "description": "图片型模版数据"
        },
        {
          "name": "list",
          "type": "object",
          "required": false,
          "description": "列表型模版数据"
        },
        {
          "name": "webview",
          "type": "object",
          "required": false,
          "description": "webview型模版数据"
        }
      ],
      "response_params": [],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"agentid\":1000005,\n    \"userid\":\"test\",\n    \"type\":\"keydata\",\n    \"keydata\":{\n        \"items\":[\n            {\n                \"key\":\"待审批\",\n                \"data\":\"2\",\n                \"jump_url\":\"http://www.qq.com\"\n            }\n        ]\n    }\n}"
        }
      ],
      "response_examples": [],
      "sections": []
    },
    {
      "group_title": "批量设置应用在用户工作台展示的数据",
      "api_name": "batch_set_workbench_data",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/agent/batch_set_workbench_data?access_token=ACCESS_TOKEN",
      "description": "批量设置应用在用户工作台展示的数据",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "agentid",
          "type": "uint32",
          "required": true,
          "description": "应用id"
        },
        {
          "name": "userid_list",
          "type": "string[]",
          "required": true,
          "description": "需要设置的用户userid列表，最多1000个"
        },
        {
          "name": "data",
          "type": "object",
          "required": true,
          "description": "用户设置的数据"
        }
      ],
      "response_params": [],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"agentid\": 1000005,\n\t\"userid_list\":[\"userid1\",\"userid2\"],\n    \"data\": {\n        \"type\": \"keydata\",\n        \"keydata\": {\n            \"items\": [\n                {\n                    \"key\": \"待审批\",\n                    \"data\": \"0\",\n                    \"jump_url\": \"http://www.qq.com\"\n                }\n            ]\n        }\n    }\n}"
        }
      ],
      "response_examples": [],
      "sections": []
    }
  ]
}