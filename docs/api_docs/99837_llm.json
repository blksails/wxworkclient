{
  "page_title": "会话反垃圾分析",
  "apis": [
    {
      "group_title": "创建分析任务",
      "api_name": "create_spam_task",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/chatdata/create_spam_task",
      "description": "可调用本接口对每条会话内容进行反垃圾分析。该接口仅支持分析文本、语音、音频存档消息。",
      "query_params": [],
      "body_params": [
        {
          "name": "msg_list",
          "type": "object[]",
          "required": true,
          "description": "消息列表，每次最多1000个。总和不超过1000个。"
        },
        {
          "name": "msg_list[].msgid",
          "type": "string",
          "required": true,
          "description": "每条消息对应的msgid。多次出现同一个msgid，以首次出现的为准。目前支持文本、语音、音频存档消息"
        },
        {
          "name": "msg_list[].encrypt_info.secret_key",
          "type": "string",
          "required": true,
          "description": "该消息的密钥，将encrypted_secret_key用RSA私钥解密后得到"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "jobid",
          "type": "string",
          "required": false,
          "description": "任务id。首次提交时返回"
        },
        {
          "name": "fail_list",
          "type": "object[]",
          "required": false,
          "description": "提交出错的消息列表，只有msgid重复项返回至该列表"
        },
        {
          "name": "fail_list[].errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "fail_list[].errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "fail_list[].msgid",
          "type": "string",
          "required": false,
          "description": "每条消息对应的msgid，与入参对应"
        },
        {
          "name": "fail_list[].encrypt_info",
          "type": "object",
          "required": false,
          "description": "每条消息对应的加密信息，与入参对应"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"msg_list\":[\n        {\n            \"msgid\": \"MSGID1\",\n            \"encrypt_info\":{\n                \"secret_key\": \"SECRETKEY1\"\n            }\n        },\n        {\n            \"msgid\": \"MSGID2\",\n            \"encrypt_info\":{\n                \"secret_key\": \"SECRETKEY2\"\n            }\n        }\n    ]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "成功响应示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"jobid\": \"JOBID\",\n    \"fail_list\":[\n        {\n            \"errcode\": 710601,\n            \"errmsg\": \"xxx\",\n            \"msgid\": \"MSGID2\",\n            \"encrypt_info\":{\n                \"secret_key\": \"SECRETKEY2\"\n            }\n        }\n    ]\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "获取任务结果",
      "api_name": "get_spam_result",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/chatdata/get_spam_result",
      "description": "通过SDK调用，获取反垃圾分析任务的结果。",
      "query_params": [],
      "body_params": [
        {
          "name": "jobid",
          "type": "string",
          "required": true,
          "description": "任务id"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "status",
          "type": "int32",
          "required": false,
          "description": "任务执行状态 0: 执行未完成 1: 执行完成 2: 执行失败"
        },
        {
          "name": "analyze_result_list",
          "type": "object[]",
          "required": false,
          "description": "消息分析结果列表"
        },
        {
          "name": "analyze_result_list[].errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "analyze_result_list[].errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "analyze_result_list[].msgid",
          "type": "string",
          "required": false,
          "description": "消息对应的msgid"
        },
        {
          "name": "analyze_result_list[].spam_result",
          "type": "int32",
          "required": false,
          "description": "反垃圾分析结果 0: 无违规 1: 政治敏感 2: 色情"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"jobid\": \"JOBID\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "成功响应示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"status\": 1,\n    \"analyze_result_list\":[\n        {\n            \"errcode\": 0,\n            \"errmsg\": \"ok\",\n            \"msgid\": \"MSGID1\",\n            \"spam_result\": 1\n        },\n        {\n            \"errcode\": 710601,\n            \"errmsg\": \"xxx\",\n            \"msgid\": \"MSGID4\"\n        }\n    ]\n}"
        }
      ],
      "sections": []
    }
  ]
}