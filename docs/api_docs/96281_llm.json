{
  "page_title": "获取标签成员",
  "apis": [
    {
      "group_title": "获取标签成员",
      "api_name": "get",
      "method": "GET",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/tag/get",
      "description": "获取标签成员列表，返回应用可见范围内的成员信息。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        },
        {
          "name": "tagid",
          "type": "string",
          "required": true,
          "description": "标签ID"
        }
      ],
      "body_params": [],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "tagname",
          "type": "string",
          "required": false,
          "description": "标签名"
        },
        {
          "name": "userlist",
          "type": "object[]",
          "required": false,
          "description": "标签中包含的成员列表"
        },
        {
          "name": "userlist[].userid",
          "type": "string",
          "required": false,
          "description": "成员账号"
        },
        {
          "name": "userlist[].name",
          "type": "string",
          "required": false,
          "description": "成员名称，代开发自建应用需要管理员授权才返回该字段；此字段从2019年12月30日起，对新创建第三方应用不再返回，2020年6月30日起，对所有历史第三方应用不再返回，后续第三方仅通讯录应用可获取，未返回名称的情况需要通过通讯录展示组件来展示名字"
        },
        {
          "name": "partylist",
          "type": "int32[]",
          "required": false,
          "description": "标签中包含的部门id列表"
        }
      ],
      "request_examples": [],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\",\n   \"tagname\": \"乒乓球协会\",\n   \"userlist\": [\n         {\n             \"userid\": \"zhangsan\",\n             \"name\": \"李四\"\n         }\n     ],\n   \"partylist\": [2]\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "无限制，但返回列表仅包含应用可见范围的成员；第三方可获取自己创建的标签及应用可见范围内的标签详情"
        }
      ]
    }
  ]
}