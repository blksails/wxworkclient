          "language": "json",
          "code": "{\n    \"jobid\": \"JOBID\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n\t\"status\": 1,\n    \"fail_list\":[{\n        \"errcode\": 710601,\n        \"errmsg\": \"xxx\",\n        \"msgid\": \"MSGID\"\n    }],\n\t\"response_data\": \"RESULT\"\n}"
        }
      ],
      "sections": []
    }
  ]
}