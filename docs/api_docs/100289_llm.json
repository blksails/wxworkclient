        },
        {
          "name": "fail_list",
          "type": "object[]",
          "required": false,
          "description": "错误的消息列表"
        },
        {
          "name": "response_data",
          "type": "string",
          "required": true,
          "description": "企微通用模型的返回结果"
        }
      ],
      "request_examples": [
        {
