{
  "page_title": "获取审批模板详情",
  "apis": [
    {
      "group_title": "获取审批模板详情",
      "api_name": "gettemplatedetail",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/oa/gettemplatedetail?access_token=ACCESS_TOKEN",
      "description": "服务商可通过第三方应用Secret调用本接口，获取企业微信“审批应用”内，由服务商添加的模板的详情。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证。须使用第三方应用的secret获取，获取方式参考：文档-获取access_token"
        }
      ],
      "body_params": [
        {
          "name": "template_id",
          "type": "string",
          "required": true,
          "description": "模板的唯一标识id。可在“获取审批单据详情”、“审批状态变化回调通知”中获得，也可在使用“复制/更新模板到企业”接口回调中获得。注：此id为企业内模板的实例id，非服务商后台对应模板的id"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "template_names",
          "type": "object[]",
          "required": false,
          "description": "模板名称，若配置了多语言则会包含中英文的模板名称，默认为zh_CN中文"
        },
        {
          "name": "template_content",
          "type": "object",
          "required": false,
          "description": "模板控件信息"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n   \"template_id\" : \"ZLqk8pcsAoXZ1eYa6vpAgfX28MPdYU3ayMaSPHaaa\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"template_names\": [...],\n    \"template_content\": {...}\n}"
        }
      ],
      "sections": [
        {
          "title": "附录",
          "content": "包含Data控件、Selector控件、Contact控件、Table、Attendance控件、Vacation控件、Tips控件的config说明"
        },
        {
          "title": "错误说明",
          "content": "包含错误码301025和301026的说明"
        }
      ]
    }
  ]
}