{
  "page_title": "第三方应用开发 - 微盘 - 文件分块上传",
  "apis": [
    {
      "group_title": "分块上传初始化",
      "api_name": "file_upload_init",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedrive/file_upload_init?access_token=ACCESS_TOKEN",
      "description": "请求分块上传初始化接口，如果命中秒传，则流程结束，完成上传。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "spaceid",
          "type": "string",
          "required": false,
          "description": "空间spaceid"
        },
        {
          "name": "fatherid",
          "type": "string",
          "required": false,
          "description": "当前目录的fileid，根目录时为空间spaceid"
        },
        {
          "name": "selected_ticket",
          "type": "string",
          "required": false,
          "description": "[微盘和文件选择器jsapi](#40357)返回的selectedTicket。若填此参数，则不需要填`spaceid`/`fatherid`。"
        },
        {
          "name": "file_name",
          "type": "string",
          "required": true,
          "description": "文件名字"
        },
        {
          "name": "size",
          "type": "uint64",
          "required": true,
          "description": "文件大小。最大支持20G"
        },
        {
          "name": "block_sha",
          "type": "string[]",
          "required": true,
          "description": "文件分块累积sha值，按分块顺序填入数组。参考[附录-分块累积sha说明](#40102/%E9%99%84%E5%BD%95-%E5%88%86%E5%9D%97%E7%B4%AF%E7%A7%AFsha%E8%AF%B4%E6%98%8E)"
        },
        {
          "name": "skip_push_card",
          "type": "bool",
          "required": false,
          "description": "文件创建完成时是否推送企业微信卡片。默认false，即默认推送卡片"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "hit_exist",
          "type": "bool",
          "required": false,
          "description": "是否命中秒传"
        },
        {
          "name": "upload_key",
          "type": "string",
          "required": false,
          "description": "文件上传凭证。不命中秒传时返回，作为file_upload_part参数"
        },
        {
          "name": "fileid",
          "type": "string",
          "required": false,
          "description": "文件fileid。命中秒传时返回，此时上传流程完成"
        }
      ],
      "request_examples": [],
      "response_examples": [],
      "sections": []
    },
    {
      "group_title": "分块上传文件",
      "api_name": "file_upload_part",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedrive/file_upload_part?access_token=ACCESS_TOKEN",
      "description": "将文件内容按2M分块，依次请求分块上传文件接口。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "upload_key",
          "type": "string",
          "required": true,
          "description": "文件上传凭证。file_upload_init返回的upload_key"
        },
        {
          "name": "index",
          "type": "int32",
          "required": true,
          "description": "文件分块号。文件内容按2M分块，从1开始"
        },
        {
          "name": "file_base64_content",
          "type": "string",
          "required": true,
          "description": "分块的文件内容base64。（注意：只需要填入文件内容的Base64，不需要添加任何如:\"data:application/x-javascript;base64\" 的数据类型描述信息）"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [],
      "response_examples": [],
      "sections": []
    },
    {
      "group_title": "分块上传完成",
      "api_name": "file_upload_finish",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedrive/file_upload_finish?access_token=ACCESS_TOKEN",
      "description": "请求分块上传完成接口，流程结束，完成上传。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "upload_key",
          "type": "string",
          "required": true,
          "description": "文件上传凭证。file_upload_init返回的upload_key"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "fileid",
          "type": "string",
          "required": false,
          "description": "文件fileid"
        }
      ],
      "request_examples": [],
      "response_examples": [],
      "sections": []
    }
  ]
}