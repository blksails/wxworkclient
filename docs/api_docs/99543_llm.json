{
  "page_title": "服务商代开发",
  "apis": [
    {
      "group_title": "获取规则组列表",
      "api_name": "customer_strategy/list",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/customer_strategy/list?access_token=ACCESS_TOKEN",
      "description": "企业可通过此接口获取企业配置的所有客户规则组id列表。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "strategy",
          "type": "object[]",
          "required": false,
          "description": "规则组id"
        },
        {
          "name": "strategy[].strategy_id",
          "type": "uint32",
          "required": false,
          "description": "规则组id"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "分页游标，用于查询下一个分页的数据，无更多数据时不返回"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"cursor\":\"CURSOR\",\n\t\"limit\":1000\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"strategy\":\n\t[\n\t\t{\n\t\t\t\"strategy_id\":1\n\t\t},\n\t\t{\n\t\t\t\"strategy_id\":2\n\t\t}\n\t],\n\t\"next_cursor\":\"NEXT_CURSOR\"\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "获取规则组详情",
      "api_name": "customer_strategy/get",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/customer_strategy/get?access_token=ACCESS_TOKEN",
      "description": "企业可以通过此接口获取某个客户规则组的详细信息。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "strategy_id",
          "type": "uint32",
          "required": true,
          "description": "规则组id"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "strategy.strategy_id",
          "type": "uint32",
          "required": false,
          "description": "规则组id"
        },
        {
          "name": "strategy.parent_id",
          "type": "uint32",
          "required": false,
          "description": "父规则组id， 如果当前规则组没父规则组，则为0"
        },
        {
          "name": "strategy.strategy_name",
          "type": "string",
          "required": false,
          "description": "规则组名称"
        },
        {
          "name": "strategy.create_time",
          "type": "uint32",
          "required": false,
          "description": "规则组创建时间戳"
        },
        {
          "name": "strategy.admin_list",
          "type": "string[]",
          "required": false,
          "description": "规则组管理员userid列表"
        },
        {
          "name": "strategy.privilege",
          "type": "object",
          "required": false,
          "description": "权限配置"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"strategy_id\":1\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"strategy\": {\n\t\t\"strategy_id\":1,\n\t\t\"parent_id\":0,\n\t\t\"strategy_name\": \"NAME\",\n\t\t\"create_time\": 1557838797,\n\t\t\"admin_list\":[\n\t\t\t\"zhangsan\",\n\t\t\t\"lisi\"\n\t\t],\n\t\t\"privilege\": {...}\n\t}\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "获取规则组管理范围",
      "api_name": "customer_strategy/get_range",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/customer_strategy/get_range?access_token=ACCESS_TOKEN",
      "description": "企业可通过此接口获取某个客户规则组管理的成员和部门列表",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "strategy_id",
          "type": "uint32",
          "required": true,
          "description": "规则组id"
        },
        {
          "name": "cursor",
          "type": "string",
          "required": false,
          "description": "分页游标"
        },
        {
          "name": "limit",
          "type": "uint32",
          "required": false,
          "description": "每个分页的成员/部门节点数，默认为1000，最大为1000"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "range",
          "type": "object[]",
          "required": false,
          "description": "节点列表"
        },
        {
          "name": "range.type",
          "type": "uint32",
          "required": false,
          "description": "节点类型，1-成员 2-部门"
        },
        {
          "name": "range.userid",
          "type": "string",
          "required": false,
          "description": "管理范围内配置的成员userid，仅`type`为1时返回"
        },
        {
          "name": "range.partyid",
          "type": "uint32",
          "required": false,
          "description": "管理范围内配置的部门partyid，仅`type`为2时返回"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "分页游标，用于查询下一个分页的数据，无更多数据时不返回"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"strategy_id\": 1,\n\t\"cursor\":\"CURSOR\",\n\t\"limit\":1000\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n\t\"range\":\n\t[\n\t\t{\n\t\t\t\"type\":1,\n\t\t\t\"userid\":\"zhangsan\"\n\t\t},\n\t\t{\n\t\t\t\"type\":2,\n\t\t\t\"partyid\":1\n\t\t}\n\t],\n\t\"next_cursor\":\"NEXT_CURSOR\"\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "创建新的规则组",
      "api_name": "customer_strategy/create",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/customer_strategy/create?access_token=ACCESS_TOKEN",
      "description": "企业可通过此接口创建一个新的客户规则组。该接口仅支持串行调用，请勿并发创建规则组。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "parent_id",
          "type": "uint32",
          "required": false,
          "description": "父规则组id"
        },
        {
          "name": "strategy_name",
          "type": "string",
          "required": true,
          "description": "规则组名称"
        },
        {
          "name": "admin_list",
          "type": "string[]",
          "required": true,
          "description": "规则组管理员userid列表，不可配置超级管理员，每个规则组最多可配置20个负责人"
        },
        {
          "name": "privilege",
          "type": "object",
          "required": false,
          "description": "权限配置"
        },
        {
          "name": "range",
          "type": "object[]",
          "required": true,
          "description": "管理范围"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "strategy_id",
          "type": "uint32",
          "required": false,
          "description": "规则组id"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"parent_id\":0,\n\t\"strategy_name\": \"NAME\",\n\t\"admin_list\":[\n\t\t\"zhangsan\",\n\t\t\"lisi\"\n\t],\n\t\"privilege\": {...},\n\t\"range\": [...]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n\t\"strategy_id\":1\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "编辑规则组及其管理范围",
