{
  "page_title": "家校应用 - 班级收款 - 获取订单详情",
  "apis": [
    {
      "group_title": "获取订单详情",
      "api_name": "get_trade",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/school/get_trade",
      "description": "获取订单详情",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "payment_id",
          "type": "string",
          "required": true,
          "description": "收款项目id，由发起班级收款接口返回"
        },
        {
          "name": "trade_no",
          "type": "string",
          "required": true,
          "description": "订单号，由获取学生付款结果返回"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "transaction_id",
          "type": "string",
          "required": false,
          "description": "微信交易单号"
        },
        {
          "name": "pay_time",
          "type": "int32",
          "required": false,
          "description": "交易时间"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n   \"payment_id\":\"xxxx\",\n   \"trade_no\":\"xxxx\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\":0,\n\t\"errmsg\":\"ok\",\n\t\"transaction_id\":\"xxxxx\",\n\t\"pay_time\":12345\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "只允许获取由应用本身创建的收款项目的订单详情"
        }
      ]
    }
  ]
}