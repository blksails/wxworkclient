{
  "group_title": "分享消息到当前会话",
  "api_name": "sendChatMessage",
  "method": "POST",
  "api_url": "https://qyapi.weixin.qq.com/cgi-bin/chatdata/sendChatMessage?access_token=ACCESS_TOKEN",
  "description": "分享消息到当前会话，支持不同类型的消息。",
