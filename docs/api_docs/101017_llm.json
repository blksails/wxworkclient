{
  "page_title": "第三方应用开发 - 服务端API",
  "apis": [
    {
      "group_title": "新增记录事件",
      "api_name": "smart_sheet_change_add_record",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/callback/record_change/add",
      "description": "当成员在API创建的智能表格上修改了记录后，触发该事件。RecordId一次最多回调1000个，超过会分批回调",
      "query_params": [],
      "body_params": [
        {
          "name": "ToUserName",
          "type": "string",
          "required": true,
          "description": "企业微信CorpID"
        },
        {
          "name": "FromUserName",
          "type": "string",
          "required": true,
          "description": "本企业成员为userid，非本企业成员为tmp_external_userid"
        },
        {
          "name": "CreateTime",
          "type": "uint32",
          "required": true,
          "description": "消息创建时间，unix时间戳"
        },
        {
          "name": "MsgType",
          "type": "string",
          "required": true,
          "description": "消息类型，固定为：event"
        },
        {
          "name": "Event",
          "type": "string",
          "required": true,
          "description": "事件类型，固定为：smart_sheet_change"
        },
        {
          "name": "ChangeType",
          "type": "string",
          "required": true,
          "description": "事件类型，固定为：add_record"
        },
        {
          "name": "DocId",
          "type": "string",
          "required": true,
          "description": "文档ID"
        },
        {
          "name": "SheetId",
          "type": "string",
          "required": true,
          "description": "子表ID"
        },
        {
          "name": "RecordId",
          "type": "string[]",
          "required": true,
          "description": "记录ID列表"
        }
      ],
      "response_params": [],
      "request_examples": [
        {
          "title": "xml请求示例",
          "language": "xml",
          "code": "<xml>\n   <ToUserName><![CDATA[toUser]]></ToUserName>\n   <FromUserName><![CDATA[fromUser]]></FromUserName>\n   <CreateTime>1348831860</CreateTime>\n   <MsgType><![CDATA[event]]></MsgType>\n   <Event><![CDATA[smart_sheet_change]]></Event>\n   <ChangeType><![CDATA[add_record]]></ChangeType>\n   <DocId><![CDATA[dcjgewCwAAqeJcPI1d8Pwbjt7nttzAAA]]></DocId>\n   <SheetId><![CDATA[SheetId]]></SheetId>\n   <RecordId><![CDATA[RecordId1]]></RecordId>\n   <RecordId><![CDATA[RecordId2]]></RecordId>\n</xml>"
        }
      ],
      "response_examples": [],
      "sections": []
    },
