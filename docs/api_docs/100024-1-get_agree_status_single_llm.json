    },
    {
      "name": "item[].userid",
      "type": "string",
      "required": true,
      "description": "内部成员的userid"
    },
    {
      "name": "item[].external_userid",
      "type": "string",
      "required": true,
      "description": "外部成员的external_userid"
    }
  ],
  "response_params": [
    {
      "name": "errcode",
      "type": "int32",
      "required": false,
      "description": "返回码"
    },
    {
      "name": "errmsg",
      "type": "string",
      "required": false,
      "description": "对返回码的文本描述内容"
    },
    {
      "name": "agreeinfo",
      "type": "object[]",
      "required": false,
      "description": "同意情况"
    },
    {
      "name": "agreeinfo[].status_change_time",
      "type": "int32",
      "required": false,
      "description": "同意状态改变的具体时间，utc时间"
    },
    {
      "name": "agreeinfo[].userid",
      "type": "string",
      "required": false,
      "description": "内部成员的userid"
    },
    {
      "name": "agreeinfo[].external_userid",
      "type": "string",
      "required": false,
