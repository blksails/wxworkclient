{
  "page_title": "服务商代开发",
  "apis": [
    {
      "group_title": "应用同步调用专区程序",
      "api_name": "sync_call_program",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/chatdata/sync_call_program?access_token=ACCESS_TOKEN",
      "description": "应用同步调用专区程序",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "program_id",
          "type": "string",
          "required": true,
          "description": "应用关联的程序id"
        },
        {
          "name": "ability_id",
          "type": "string",
          "required": true,
          "description": "程序关联的能力id"
        },
        {
          "name": "notify_id",
          "type": "string",
          "required": false,
          "description": "通知id。由专区通知应用返回"
        },
        {
          "name": "request_data",
          "type": "string",
          "required": true,
          "description": "请求的输入JSON，要求与配置的输入协议格式匹配，如需使用专区程序示例，请留意Java版本demo的输入无需在request_data内包裹一层input对象"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "response_data",
          "type": "string",
          "required": false,
          "description": "专区程序的输出结果，为自定义的JSON字符串，要求与管理端配置的输出协议格式匹配，如需使用专区程序示例，请留意Java版本的demo没有在输出的response_data内包裹一层output对象"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体（Python）",
          "language": "json",
          "code": "{\n\t\"program_id\": \"xxx\",\n\t\"ability_id\": \"xxx\",\n\t\"notify_id\":\"xxx\",\n\t\"request_data\": \"{\\\"input\\\":\\\"xxx\\\"}\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果（Python）",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"response_data\": \"{\\\"output\\\":\\\"xxx\\\"}\"\n}"
        }
      ],
