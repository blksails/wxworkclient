  "page_title": "推送suite_ticket",
  "apis": [
    {
      "group_title": "推送suite_ticket",
      "api_name": "receive",
      "method": "POST",
      "api_url": "https://127.0.0.1/suite/receive",
      "description": "企业微信服务器会定时（每十分钟）向指令回调url推送ticket，suite_ticket实际有效期为30分钟，ticket会实时变更，并用于后续接口的调用。若开发者想立即获得ticket推送值，可登录服务商平台，在第三方应用详情-回调配置，手动刷新ticket推送。",
      "query_params": [
        {
          "name": "msg_signature",
          "type": "string",
          "required": true,
          "description": "消息签名"
        },
        {
          "name": "timestamp",
          "type": "string",
          "required": true,
          "description": "时间戳"
        },
        {
          "name": "nonce",
          "type": "string",
          "required": true,
          "description": "随机数"
        }
      ],
      "body_params": [
        {
          "name": "SuiteId",
          "type": "string",
          "required": true,
          "description": "第三方应用的SuiteId或者代开发应用模板id"
        },
        {
          "name": "InfoType",
          "type": "string",
          "required": true,
          "description": "suite_ticket"
        },
        {
          "name": "TimeStamp",
          "type": "string",
          "required": true,
          "description": "时间戳"
        },
        {
          "name": "SuiteTicket",
          "type": "string",
          "required": true,
          "description": "Ticket内容，最长为512字节"
        }
      ],
      "response_params": [],
      "request_examples": [
        {
