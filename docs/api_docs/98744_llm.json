{
  "page_title": "服务商代开发",
  "apis": [
    {
      "group_title": "获取带参授权链接",
      "api_name": "get_customized_auth_url",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/service/get_customized_auth_url?provider_access_token=PROVIDER_ACCESS_TOKEN",
      "description": "该API用于获取代开发自建应用授权链接，用于生成带参临时二维码。",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "provider_access_token，获取方法参见服务商的凭证"
        }
      ],
      "body_params": [
        {
          "name": "state",
          "type": "string",
          "required": true,
          "description": "state值，可以填写a-zA-Z0-9，长度不可超过32个字节。当扫带参二维码授权代开发模版时，获取企业永久授权码接口会返回该state值"
        },
        {
          "name": "templateid_list",
          "type": "array",
          "required": true,
          "description": "代开发自建应用模版ID列表，数量不能超过9个"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误描述"
        },
        {
          "name": "qrcode_url",
          "type": "string",
          "required": false,
          "description": "可用来生成二维码的授权url，需要开发者自行生成为二维码"
        },
        {
          "name": "expires_in",
          "type": "uint32",
          "required": false,
          "description": "有效期（秒）。10天过期。"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"state\":\"test\",\n\t\"templateid_list\": [\"dk1\",\"dk2\"]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\":0 ,\n\t\"errmsg\":\"ok\" ,\n\t\"qrcode_url\":\"xxxxx\",\n\t\"expires_in\":864000\n}"
        }
      ],
      "sections": []
    }
  ]
}