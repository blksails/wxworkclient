{
  "page_title": "服务商代开发 - 服务端API",
  "apis": [
    {
      "group_title": "创建自有分析程序任务",
      "api_name": "create_program_task",
      "method": "POST",
      "api_url": "create_program_task",
      "description": "开发者可调用本接口传入会话内容，使用自己上传的分析程序进行会话分析。",
      "query_params": [],
      "body_params": [
        {
          "name": "program_id",
          "type": "string",
          "required": true,
          "description": "应用关联的程序id"
        },
        {
          "name": "ability_id",
          "type": "string",
          "required": true,
          "description": "能力id"
        },
        {
          "name": "msg_list",
          "type": "array",
          "required": true,
          "description": "消息列表，最多1000个"
        },
        {
          "name": "msg_list[].msgid",
          "type": "string",
          "required": true,
          "description": "每条消息对应的msgid。多次出现同一个msgid，以首次出现的为准。目前支持文本、语音、音频存档消息"
        },
        {
          "name": "msg_list[].encrypt_info.secret_key",
          "type": "string",
          "required": true,
          "description": "该消息的密钥，将encrypted_secret_key用RSA私钥解密后得到"
        },
        {
          "name": "debug_info",
          "type": "object",
          "required": false,
          "description": "仅当处于调试模式时生效，将使用此字段下的内容而不是实际的消息来替换对应的占位符。"
        },
        {
          "name": "debug_info.chat",
          "type": "string",
          "required": true,
          "description": "将用于替换{chat}占位符"
        },
        {
          "name": "debug_info.chat_content",
          "type": "string",
          "required": true,
          "description": "将用于替换{chatcontent}占位符"
        },
        {
          "name": "escape_type",
          "type": "int32",
          "required": false,
          "description": "传入自有模型的内容的转义方式。默认为0。"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": true,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": true,
          "description": "错误信息"
        },
        {
          "name": "jobid",
          "type": "string",
          "required": false,
          "description": "任务id。首次提交时返回"
        },
        {
          "name": "fail_list",
          "type": "array",
          "required": false,
          "description": "提交出错的消息列表，只有msgid重复项返回至该列表"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"program_id\": \"PROG_ID\",\n\t\"ability_id\": \"ABILITY_ID\",\n    \"msg_list\":[{\n        \"msgid\": \"MSGID1\",\n        \"encrypt_info\":{\n            \"secret_key\": \"SECRETKEY1\"\n        }\n    },{\n        \"msgid\": \"MSGID2\",\n        \"encrypt_info\":{\n            \"secret_key\": \"SECRETKEY2\"\n        }\n    }],\n\t\"debug_info\":{\n\t\t\"chat\":\"xxx\",\n\t\t\"chat_content\":\"xxx\"\n\t},\n\t\"escape_type\":0\n}"
        }
      ],
      "response_examples": [
        {
          "title": "成功响应示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"jobid\": \"JOBID\",\n    \"fail_list\":[\n        {\n            \"errcode\": 710601,\n            \"errmsg\": \"xxx\",\n            \"msgid\": \"MSGID2\",\n            \"encrypt_info\":{\n                \"secret_key\": \"SECRETKEY2\"\n            }\n        }\n    ]\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "获取自有分析程序结果",
      "api_name": "get_program_task_result",
      "method": "POST",
      "api_url": "get_program_task_result",
      "description": "通过SDK调用，获取自有分析程序的结果。",
      "query_params": [],
      "body_params": [
        {
          "name": "jobid",
          "type": "string",
          "required": true,
          "description": "任务id"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": true,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": true,
          "description": "错误信息"
        },
        {
          "name": "fail_list",
          "type": "array",
          "required": false,
          "description": "错误的消息列表，如msgid不存在、非文本等"
        },
        {
          "name": "response_errcode",
          "type": "int32",
          "required": true,
          "description": "专区程序返回的错误码"
        },
        {
          "name": "response_data",
          "type": "string",
          "required": true,
          "description": "专区程序的输出结果，为自定义的JSON字符串"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"jobid\": \"JOBID\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "成功响应示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"fail_list\":[{\n        \"errcode\": 710601,\n        \"errmsg\": \"xxx\",\n        \"msgid\": \"MSGID\"\n    }],\n\t\"response_errcode\": 0,\n\t\"response_data\": \"{\\\"output\\\":\\\"xxx\\\"}\"\n}"
        }
      ],
      "sections": []
    }
  ]
}