{
  "page_title": "服务商代开发",
  "apis": [
    {
      "group_title": "ID转换接口",
      "api_name": "finish_openid_migration",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/service/finish_openid_migration?provider_access_token=ACCESS_TOKEN",
      "description": "服务商完成企业某个代开发应用的新旧id（userid/corpid/external_userid)迁移后，即可主动将该代开发应用设置为“迁移完成”。设置后，该代开发应用获取到的是升级后的id。注意，该接口需要使用provider_access_token来调用。",
      "query_params": [
        {
          "name": "provider_access_token",
          "type": "string",
          "required": true,
          "description": "应用提供商的provider_access_token，获取方法参见服务商的凭证"
        }
      ],
      "body_params": [
        {
          "name": "corpid",
          "type": "string",
          "required": true,
          "description": "企业corpid"
        },
        {
          "name": "agentid",
          "type": "int32",
          "required": true,
          "description": "企业代开发应用id"
        },
        {
          "name": "openid_type",
          "type": "array",
          "required": true,
          "description": "id类型：1-userid与corpid; 3-external_userid、external_tagid、kfid和msgid"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n    \"corpid\":\"xxxxx\",\n    \"agentid\":1111,\n    \"openid_type\":[\n        1,3\n    ]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n  \"errcode\":0,\n  \"errmsg\":\"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}