{
  "page_title": "删除视图",
  "apis": [
    {
      "group_title": "删除视图",
      "api_name": "delete_views",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedoc/smartsheet/delete_views",
      "description": "本接口用于在 smartsheet 中的某个子表里删除若干个视图。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "docid",
          "type": "string",
          "required": true,
          "description": "文档的docid"
        },
        {
          "name": "sheet_id",
          "type": "string",
          "required": true,
          "description": "Smartsheet 子表ID"
        },
        {
          "name": "view_ids",
          "type": "string[]",
          "required": true,
          "description": "要删除的视图ID列表"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"docid\": \"DOCID\",\n\t\"sheet_id\": \"123Abc\",\n\t\"view_ids\": [\n\t\t\"VIEWID1\", \"VIEWID2\"\n\t]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "* 自建应用需配置到“可调用应用”列表中的应用secret所获取的accesstoken来调用（accesstoken如何获取？）\n* 第三方应用需具有“文档”权限\n* 代开发自建应用需具有“文档”权限"
        }
      ]
    }
  ]
}