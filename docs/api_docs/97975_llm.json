{
  "page_title": "文件变更事件",
  "apis": [
    {
      "group_title": "文件变更事件",
      "api_name": "wedrive_file_change",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/webdrive/file_change?access_token=ACCESS_TOKEN",
      "description": "当接口指定的管理员在企业微信客户端对应用上传的文件进行变更，触发该事件。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "ToUserName",
          "type": "string",
          "required": true,
          "description": "企业微信CorpID"
        },
        {
          "name": "FromUserName",
          "type": "string",
          "required": true,
          "description": "此事件该值固定为`sys`，表示该消息由系统生成"
        },
        {
          "name": "CreateTime",
          "type": "uint32",
          "required": true,
          "description": "消息创建时间，unix时间戳"
        },
        {
          "name": "MsgType",
          "type": "string",
          "required": true,
          "description": "消息类型，此时固定为：`event`"
        },
        {
          "name": "Event",
          "type": "string",
          "required": true,
          "description": "事件类型，此时固定为：`wedrive_file_change`"
        },
        {
          "name": "ChangeType",
          "type": "string",
          "required": true,
          "description": "变更类型。有以下值：`create_file`-创建文件，`rename_file`-重命名文件，`update_file`-更新文件内容，`delete_file`-删除文件，`move_file`-移动文件"
        },
        {
          "name": "FileId",
          "type": "string",
          "required": true,
          "description": "文件fileid。可能有多个FileId节点，表示多个文件"
        }
      ],
      "response_params": [],
      "request_examples": [
        {
          "title": "xml请求示例",
          "language": "xml",
          "code": "<xml>\n   <ToUserName><![CDATA[toUser]]></ToUserName>\n   <FromUserName><![CDATA[sys]]></FromUserName>\n   <CreateTime>1348831860</CreateTime>\n   <MsgType><![CDATA[event]]></MsgType>\n   <Event><![CDATA[wedrive_file_change]]></Event>\n   <ChangeType><![CDATA[xxx_file]]></ChangeType>\n   <FileId><![CDATA[spxxxxxxxxxxxxx]]></FileId>\n</xml>"
        }
      ],
      "response_examples": [],
      "sections": [
        {
          "title": "说明",
          "content": "| 参数 | 说明 |\n| --- | --- |\n| ToUserName | 企业微信CorpID |\n| FromUserName | 此事件该值固定为`sys`，表示该消息由系统生成 |\n| CreateTime | 消息创建时间，unix时间戳 |\n| MsgType | 消息类型，此时固定为：`event` |\n| Event | 事件类型，此时固定为：`wedrive_file_change` |\n| ChangeType | 变更类型。有以下值：`create_file`-创建文件 ，`rename_file`-重命名文件，`update_file`-更新文件内容，`delete_file`-删除文件，`move_file`-移动文件 |\n| FileId | 文件fileid。可能有多个FileId节点，表示多个文件 |"
        }
      ]
    }
  ]
}