{
  "page_title": "服务商代开发",
  "apis": [
    {
      "group_title": "客户标签ID的转换",
      "api_name": "external_tagid",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/idconvert/external_tagid",
      "description": "将企业主体下的客户标签ID转换成服务商主体下的客户标签ID。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证，第三方应用access_token或代开发应用access_token"
        }
      ],
      "body_params": [
        {
          "name": "external_tagid_list",
          "type": "array",
          "required": true,
          "description": "企业主体下的客户标签ID或标签组ID列表，最多不超过1000个"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "items",
          "type": "array",
          "required": false,
          "description": "客户标签转换结果"
        },
        {
          "name": "items.external_tagid",
          "type": "string",
          "required": false,
          "description": "企业主体下的客户标签ID"
        },
        {
          "name": "items.open_external_tagid",
          "type": "string",
          "required": false,
          "description": "服务商主体下的客户标签ID，如果传入的external_tagid已经是服务商主体下的ID，则open_external_tagid与external_tagid相同。"
        },
        {
          "name": "invalid_external_tagid_list",
          "type": "array",
          "required": false,
          "description": "无法转换的客户标签ID列表"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n  \"external_tagid_list\":[\"TAG_ID1\",\"TAG_ID2\",\"TAG_ID3\",\"TAG_ID4\"]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n \"errcode\":0,\n \"errmsg\":\"ok\",\n \"items\":[\n \t{\n\t\t\t\"external_tagid\":\"TAG_ID1\",\n\t\t\t\"open_external_tagid\":\"OPEN_TAG_ID1\"\n\t},\n\t{\n\t\t\t\"external_tagid\":\"TAG_ID2\",\n\t\t\t\"open_external_tagid\":\"OPEN_TAG_ID2\"\n\t},\n\t\"invalid_external_tagid_list\":[\"TAG_ID3\",\"TAG_ID4\"]\n}"
        }
      ],
      "sections": []
    }
  ]
}