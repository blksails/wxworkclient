{
  "page_title": "外部联系人openid转换",
  "apis": [
    {
      "group_title": "外部联系人openid转换",
      "api_name": "convert_to_openid",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/convert_to_openid?access_token=ACCESS_TOKEN",
      "description": "企业和服务商可通过此接口，将微信外部联系人的userid转为微信openid，用于调用支付相关接口。暂不支持企业微信外部联系人（ExternalUserid为wo开头）的userid转openid。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "external_userid",
          "type": "string",
          "required": true,
          "description": "外部联系人的userid，注意不是企业成员的账号"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "openid",
          "type": "string",
          "required": false,
          "description": "该企业的外部联系人openid"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n  \"external_userid\":\"wmAAAAAAA\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n \"errcode\":0,\n \"errmsg\":\"ok\",\n \"openid\":\"ooAAAAAAAAAAA\"\n}"
        }
      ],
      "sections": []
    }
  ]
}