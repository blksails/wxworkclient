{
  "page_title": "第三方应用开发 - 服务端API - 数据与智能专区 - 专区程序接收事件通知 - 知识集管理回调",
  "apis": [
    {
      "group_title": "授权知识集",
      "api_name": "auth_knowledge_base",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/chatdata/auth_knowledge_base",
      "description": "当企业授权知识集时，企业微信服务器会向该知识集授权应用关联的程序推送消息。",
      "query_params": [],
      "body_params": [
        {
          "name": "knowledge_base_id",
          "type": "string",
          "required": true,
          "description": "知识集ID"
        },
        {
          "name": "knowledge_base_name",
          "type": "string",
          "required": true,
          "description": "知识集名称"
        },
        {
          "name": "timestamp",
          "type": "uint32",
          "required": true,
          "description": "授权时间时间戳"
        }
      ],
      "response_params": [],
      "request_examples": [
        {
          "title": "事件示例",
          "language": "json",
          "code": "{\n    \"event_type\": \"auth_knowledge_base\",\n    \"timestamp\": 1408091189,\n    \"auth_knowledge_base\": {\n        \"knowledge_base_id\": \"xxxxxxx\",\n        \"knowledge_base_name\": \"zzzzz\"\n    }\n}"
        }
      ],
      "response_examples": [],
      "sections": []
    },
