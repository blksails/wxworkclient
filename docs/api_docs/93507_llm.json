{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "关于客户朋友圈",
      "api_name": "获取企业全部的发表列表",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/chatdata/get_publish_list?access_token=ACCESS_TOKEN",
      "description": "企业统一创建，由成员确认后发表的内容",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "接口调用凭证"
        }
      ],
      "body_params": [],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误信息"
        },
        {
          "name": "publish_list",
          "type": "object[]",
          "required": false,
          "description": "发表列表"
        },
        {
          "name": "publish_list[].content",
          "type": "string",
          "required": false,
          "description": "内容"
        },
        {
          "name": "publish_list[].confirm_member",
          "type": "string",
          "required": false,
          "description": "确认成员"
        }
      ],
      "request_examples": [],
      "response_examples": [],
      "sections": [
        {
          "title": "关于客户朋友圈",
          "content": "成员可发表内容到微信客户的朋友圈，还可与客户评论互动。企业也可统一创建内容，由成员确认后发表。客户朋友圈可分为以下两类：企业发表和个人发表。"
        }
      ]
    },
