{
  "page_title": "创建日历",
  "apis": [
    {
      "group_title": "创建日历",
      "api_name": "add",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/oa/calendar/add",
      "description": "该接口用于通过应用在企业内创建一个日历。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "calendar.admins",
          "type": "string[]",
          "required": false,
          "description": "日历的管理员userid列表，管理员必须在通知范围成员的列表中。最多指定3人"
        },
        {
          "name": "calendar.set_as_default",
          "type": "int32",
          "required": false,
          "description": "是否将该日历设置为应用的默认日历。0-否；1-是。第三方应用不支持使用该参数"
        },
        {
          "name": "calendar.summary",
          "type": "string",
          "required": true,
          "description": "日历标题。1 ~ 128 字符"
        },
        {
          "name": "calendar.color",
          "type": "string",
          "required": true,
          "description": "日历在终端上显示的颜色，RGB颜色编码16进制表示，例如：\"#0000FF\" 表示纯蓝色"
        },
        {
          "name": "calendar.description",
          "type": "string",
          "required": false,
          "description": "日历描述。0 ~ 512 字符"
        },
        {
          "name": "calendar.shares",
          "type": "object[]",
          "required": false,
          "description": "日历通知范围成员列表。最多2000人"
        },
        {
          "name": "calendar.is_public",
          "type": "int32",
          "required": false,
          "description": "是否公共日历。0-否；1-是。注意：每个人最多可创建或订阅100个公共日历。该属性不可更新"
        },
        {
          "name": "calendar.public_range",
          "type": "object",
          "required": false,
          "description": "公开范围。仅当是公共日历时有效"
        },
        {
          "name": "calendar.is_corp_calendar",
          "type": "int32",
          "required": false,
          "description": "是否全员日历。0-否；1-是。注意：1. 每个企业最多可创建20个全员日历 2. 全员日历也是公共日历的一种，需要指定`public_range` 3. 全员日历不支持指定颜色、默认日历、只读权限 4. 该属性不可更新"
        },
        {
          "name": "calendar.agentid",
          "type": "int32",
          "required": false,
          "description": "授权方安装的应用agentid。仅旧的第三方多应用套件需要填此参数"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "cal_id",
          "type": "string",
          "required": false,
          "description": "日历ID"
        },
        {
          "name": "fail_result",
          "type": "object",
          "required": false,
          "description": "无效的输入内容"
        },
        {
          "name": "fail_result.shares",
          "type": "object[]",
          "required": false,
          "description": "无效的日历通知范围成员列表"
        },
        {
          "name": "fail_result.shares.errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "fail_result.shares.errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "fail_result.shares.userid",
          "type": "string",
          "required": false,
          "description": "日历通知范围成员的id"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n\t\"calendar\": {\n\t\t\"admins\":[\n\t\t\t\t\"admin1\",\n\t\t\t\t\"admin2\"\n\t\t],\n\t\t\"set_as_default\": 1,\n\t\t\"summary\": \"test_summary\",\n\t\t\"color\": \"#FF3030\",\n\t\t\"description\": \"test_describe\",\n\t\t\"shares\": [{\n\t\t\t\t\"userid\": \"userid2\",\n\t\t\t\t\"permission\": 1\n\t\t\t},\n\t\t\t{\n\t\t\t\t\"userid\": \"userid3\",\n\t\t\t\t\"permission\": 3\n\t\t\t}\n\t\t],\n\t\t\"is_public\": 1,\n\t\t\"public_range\": {\n\t\t\t\"userids\": [\"abel\", \"jack\"],\n\t\t\t\"partyids\": [1232, 34353]\n\t\t},\n\t\t\"is_corp_calendar\": 1\n\t},\n\t\"agentid\": 1000014\n}"
        }
      ],
      "response_examples": [
        {
          "title": "成功响应示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\" : \"ok\",\n\t\"cal_id\":\"wcjgewCwAAqeJcPI1d8Pwbjt7nttzAAA\",\n\t\"fail_result\": {\n\t\t\"shares\":[{\n\t\t\t\"errcode\": 40001,\n\t\t\t\"errmsg\": \"not found\",\n\t\t\t\"userid\": \"userid3\"\n\t\t}]\n\t}\n}"
        }
      ],
      "sections": []
    }
  ]
}