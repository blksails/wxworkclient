{
  "page_title": "服务商代开发",
  "apis": [
    {
      "group_title": "获取获客链接列表",
      "api_name": "list_link",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/customer_acquisition/list_link",
      "description": "企业可通过此接口获取当前仍然有效且是当前应用创建的获客链接。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "limit",
          "type": "int32",
          "required": false,
          "description": "返回的最大记录数，整型，最大值100"
        },
        {
          "name": "cursor",
          "type": "string",
          "required": false,
          "description": "用于分页查询的游标，字符串类型，由上一次调用返回，首次调用可不填"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "link_id_list",
          "type": "array",
          "required": false,
          "description": "link_id列表"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "分页游标，在下次请求时填写以获取之后分页的记录"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n   \"limit\":100,\n   \"cursor\":\"CURSOR\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n\t\"link_id_list\":\n\t[\n\t\t\"LINK_ID_AAA\",\n\t\t\"LINK_ID_BBB\",\n\t\t\"LINK_ID_CCC\"\n\t],\n\t\"next_cursor\":\"CURSOR\"\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "获取获客链接详情",
      "api_name": "get",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/customer_acquisition/get",
      "description": "企业可通过此接口根据获客链接id获取链接配置详情。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "link_id",
          "type": "string",
          "required": true,
          "description": "获客链接id。需要是当前应用创建"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "link.link_name",
          "type": "string",
          "required": false,
          "description": "获客链接的名称"
        },
        {
          "name": "link.url",
          "type": "string",
          "required": false,
          "description": "获客链接实际的url"
        },
        {
          "name": "link.create_time",
          "type": "int32",
          "required": false,
          "description": "创建时间"
        },
        {
          "name": "link.skip_verify",
          "type": "bool",
          "required": false,
          "description": "是否无需验证，默认为true"
        },
        {
          "name": "link.mark_source",
          "type": "bool",
          "required": false,
          "description": "是否标记客户添加来源为该应用创建的获客链接; 仅对「营销获客」应用生效"
        },
        {
          "name": "range.user_list",
          "type": "array",
          "required": false,
          "description": "该获客链接使用范围成员列表"
        },
        {
          "name": "range.department_list",
          "type": "array",
          "required": false,
          "description": "该获客链接使用范围的部门列表"
        },
        {
          "name": "priority_option.priority_type",
          "type": "int32",
          "required": false,
          "description": "优先分配类型，1-全企业范围内优先分配给有好友关系的；2-指定范围内优先分配有好友关系的"
        },
        {
          "name": "priority_option.priority_userid_list",
          "type": "array",
          "required": false,
          "description": "priority_type为2时的指定成员列表"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n   \"link_id\":\"LINK_ID_AAA\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n  \"errcode\": 0,\n  \"errmsg\": \"ok\",\n  \"link\":\n\t{\n\t\t\"link_name\":\"LINK_NAME\",\n\t\t\"url\":\"https://work.weixin.qq.com/ca/xxxxxx\",\n\t\t\"create_time\":1672502400,\n\t\t\"skip_verify\":true,\n\t\t\"mark_source\":true\n\t},\n\t\"range\":\n\t{\n\t\t\"user_list\":[\"rocky\",\"sam\"],\n\t\t\"department_list\":[1]\n\t},\n\t\"priority_option\":\n\t{\n\t\t\"priority_type\":2,\n\t\t\"priority_userid_list\":[\"tom\",\"lisi\"]\n\t}\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "创建获客链接",
      "api_name": "create_link",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/customer_acquisition/create_link",
      "description": "企业可通过此接口创建新的获客链接。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "link_name",
          "type": "string",
          "required": true,
          "description": "链接名称,最长为30个字符"
        },
        {
          "name": "range.user_list",
          "type": "array",
          "required": false,
          "description": "此获客链接关联的userid列表，最多500人"
        },
        {
          "name": "range.department_list",
          "type": "array",
          "required": false,
          "description": "此获客链接关联的部门id列表，部门覆盖总人数最多500个"
        },
        {
          "name": "skip_verify",
          "type": "bool",
          "required": false,
          "description": "是否无需验证，默认为true"
        },
        {
          "name": "priority_option.priority_type",
          "type": "int32",
          "required": false,
          "description": "客户与成员关系绑定，1-全企业范围内优先分配给有好友关系的；2-指定范围内优先分配有好友关系的"
        },
        {
          "name": "priority_option.priority_userid_list",
          "type": "array",
          "required": false,
          "description": "指定成员列表，priority_type为2时必填，最多1000个"
        },
        {
          "name": "mark_source",
          "type": "bool",
          "required": false,
          "description": "是否标记客户添加来源为该应用创建的获客链接, 默认值为true; 仅对「营销获客」应用生效"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "link.link_id",
          "type": "string",
          "required": false,
          "description": "获客链接的id"
        },
        {
          "name": "link.link_name",
          "type": "string",
          "required": false,
          "description": "获客链接名称"
        },
        {
          "name": "link.url",
          "type": "string",
          "required": false,
          "description": "获客链接"
        },
        {
          "name": "create_time",
          "type": "int32",
          "required": false,
          "description": "获客链接创建时间"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n   \"link_name\":\"获客链接1号\",\n   \"range\":\n   {\n   \t\t\"user_list\":[\"zhangsan\",\"lisi\"],\n\t\t\"department_list\":[2,3]\n   },\n   \"skip_verify\":true,\n   \"priority_option\":\n\t{\n\t\t\"priority_type\":2,\n\t\t\"priority_userid_list\":[\"tom\",\"lisi\"]\n\t},\n\t\"mark_source\":true\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n\t\"link\":{\n\t\t\"link_id\":\"LINK_ID\",\n\t\t\"link_name\":\"获客链接1号\",\n\t\t\"url\":\"URL\",\n\t\t\"create_time\":1667232000\n\t}\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "编辑获客链接",
      "api_name": "update_link",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/customer_acquisition/update_link",
      "description": "企业可通过此接口编辑获客链接，修改获客链接的关联范围或修改获客链接的名称。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "link_id",
          "type": "string",
          "required": true,
          "description": "获客链接的id。需要是当前应用创建"
        },
        {
          "name": "link_name",
          "type": "string",
          "required": false,
          "description": "更新的链接名称,最长为30个字符"
        },
        {
          "name": "range.user_list",
          "type": "array",
          "required": false,
          "description": "此获客链接关联的userid列表，最多可关联500个"
        },
        {
          "name": "range.department_list",
          "type": "array",
          "required": false,
          "description": "此获客链接关联的部门id列表，部门覆盖总人数最多500个"
        },
        {
          "name": "skip_verify",
          "type": "bool",
          "required": false,
          "description": "是否无需验证，默认为true"
        },
        {
          "name": "priority_option.priority_type",
          "type": "int32",
          "required": false,
          "description": "客户与成员关系绑定，1-全企业范围内优先分配给有好友关系的成员；2-指定范围内优先分配有好友关系的成员"
        },
        {
          "name": "priority_option.priority_userid_list",
          "type": "array",
          "required": false,
          "description": "priority_type为2时的指定成员列表，最多1000个"
        },
        {
          "name": "mark_source",
          "type": "bool",
          "required": false,
          "description": "是否标记客户添加来源为该应用创建的获客链接, 默认值为true; 仅对「营销获客」应用生效"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n   \"link_id\":\"LINK_ID\",\n   \"link_name\":\"获客链接1号\",\n   \"range\":\n   {\n   \t\t\"user_list\":[\"zhangsan\",\"lisi\"],\n\t\t\"department_list\":[2,3]\n   },\n   \"skip_verify\":true,\n   \"priority_option\":\n\t{\n\t\t\"priority_type\":2,\n\t\t\"priority_userid_list\":[\"tom\",\"lisi\"]\n\t},\n\t\"mark_source\":true\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    },
    {
