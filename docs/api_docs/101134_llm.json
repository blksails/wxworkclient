{
  "page_title": "第三方应用开发",
  "apis": [
    {
      "group_title": "unionid转换为第三方external_userid",
      "api_name": "unionid_to_external_userid",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/idconvert/unionid_to_external_userid?access_token=ACCESS_TOKEN",
      "description": "当微信用户进入服务商的小程序或公众号时，服务商可通过此接口，将微信客户的unionid转为第三方主体的external_userid，若该微信用户尚未成为企业的客户，则返回pending_id。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证，第三方应用access_token或代开发应用access_token"
        }
      ],
      "body_params": [
        {
          "name": "unionid",
          "type": "string",
          "required": true,
          "description": "微信客户的unionid"
        },
        {
          "name": "openid",
          "type": "string",
          "required": true,
          "description": "微信客户的openid"
        },
        {
          "name": "subject_type",
          "type": "uint32",
          "required": false,
          "description": "小程序或公众号的主体类型：0表示主体名称是企业的 (默认)， 1表示主体名称是服务商的"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": true,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": true,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "external_userid",
          "type": "string",
          "required": false,
          "description": "该授权企业的外部联系人ID"
        },
        {
          "name": "pending_id",
          "type": "string",
          "required": false,
          "description": "该微信账号尚未成为企业客户时，返回的临时外部联系人ID，该ID有效期为90天，当该用户在90天内成为企业客户时，可以通过external_userid查询pending_id关联"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n  \"unionid\":\"oAAAAAAA\",\n  \"openid\":\"oBBBB\",\n  \"subject_type\":1\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n  \"errcode\":0,\n  \"errmsg\":\"ok\",\n  \"external_userid\":\"ooAAAAAAAAAAA\",\n  \"pending_id\":\"ooBBBBBB\"\n}"
        }
      ],
      "sections": []
    },
    {
      "group_title": "external_userid查询pending_id",
      "api_name": "external_userid_to_pending_id",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/idconvert/batch/external_userid_to_pending_id?access_token=ACCESS_TOKEN",
      "description": "该接口可用于当一个微信用户成为企业客户前已经使用过服务商服务的场景。本接口获取到的pending_id可以维持unionid和external_userid的关联关系。pending_id有效期为90天，超过有效期之后，将无法通过该接口将external_userid换取对应的pending_id。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证 ，第三方应用access_token或代开发应用access_token"
        }
      ],
      "body_params": [
        {
          "name": "chat_id",
          "type": "string",
          "required": false,
          "description": "群id，如果有传入该参数，则只检查群主是否在可见范围，同时会忽略在该群以外的external_userid。如果不传入该参数，则只检查客户跟进人是否在可见范围内。"
        },
        {
          "name": "external_userid",
          "type": "array",
          "required": true,
          "description": "该企业的外部联系人ID，最多可同时查询100个外部联系人"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": true,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": true,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "result",
          "type": "object[]",
          "required": true,
          "description": "转换结果"
        },
        {
          "name": "result[].external_userid",
          "type": "string",
          "required": true,
          "description": "该企业的外部联系人ID"
        },
        {
          "name": "result[].pending_id",
          "type": "string",
          "required": true,
          "description": "该微信账号还未成为企业客户时，unionid_to_external_userid接口返回的临时外部联系人ID"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n  \"chat_id\":\"xxxxxx\",\n  \"external_userid\":[\"oAAAAAAA\", \"oBBBBB\"]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n  \"errcode\":0,\n  \"errmsg\":\"ok\",\n  \"result\":[\n    {\n      \"external_userid\":\"oAAAAAAA\",\n      \"pending_id\":\"pAAAAA\"\n    },\n    {\n      \"external_userid\":\"oBBBBB\",\n      \"pending_id\":\"pBBBBB\"\n    }\n  ]\n}"
        }
      ],
      "sections": []
    }
  ]
}