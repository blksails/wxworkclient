{
  "page_title": "获取打卡人员排班信息",
  "apis": [
    {
      "group_title": "获取打卡人员排班信息",
      "api_name": "getcheckinschedulist",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/checkin/getcheckinschedulist",
      "description": "应用可通过此接口，获取应用可见范围内、打卡规则为“按班次上下班”规则的指定员工指定时间段内的排班信息。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证，获取方式参考：文档-获取access_token"
        }
      ],
      "body_params": [
        {
          "name": "useridlist",
          "type": "string[]",
          "required": true,
          "description": "需要获取排班信息的用户列表（不超过100个）"
        },
        {
          "name": "starttime",
          "type": "uint32",
          "required": true,
          "description": "获取排班信息的开始时间。Unix时间戳"
        },
        {
          "name": "endtime",
          "type": "uint32",
          "required": true,
          "description": "获取排班信息的结束时间。Unix时间戳（与starttime跨度不超过一个月）"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码描述"
        },
        {
          "name": "schedule_list",
          "type": "object[]",
          "required": false,
          "description": "排班表信息"
        },
        {
          "name": "schedule_list[].userid",
          "type": "string",
          "required": false,
          "description": "打卡人员userid"
        },
        {
          "name": "schedule_list[].yearmonth",
          "type": "uint32",
          "required": false,
          "description": "排班表月份，格式为年月，如202011"
        },
        {
          "name": "schedule_list[].groupid",
          "type": "uint32",
          "required": false,
          "description": "打卡规则id"
        },
        {
          "name": "schedule_list[].groupname",
          "type": "string",
          "required": false,
          "description": "打卡规则名"
        },
        {
          "name": "schedule_list[].schedule",
          "type": "object",
          "required": false,
          "description": "个人排班信息"
        },
        {
          "name": "schedule_list[].schedule.scheduleList",
          "type": "object[]",
          "required": false,
          "description": "个人排班表信息"
        },
        {
          "name": "schedule_list[].schedule.scheduleList.day",
          "type": "uint32",
          "required": false,
          "description": "排班日期，为表示当月第几天的数字"
        },
        {
          "name": "schedule_list[].schedule.scheduleList.schedule_info",
          "type": "object",
          "required": false,
          "description": "个人当日排班信息"
        },
        {
          "name": "schedule_list[].schedule.scheduleList.schedule_info.schedule_id",
          "type": "uint32",
          "required": false,
          "description": "当日安排班次id，班次id也可在打卡规则中查询获得"
        },
        {
          "name": "schedule_list[].schedule.scheduleList.schedule_info.schedule_name",
          "type": "string",
          "required": false,
          "description": "班次名称"
        },
        {
          "name": "schedule_list[].schedule.scheduleList.schedule_info.time_section",
          "type": "object[]",
          "required": false,
          "description": "班次上下班时段信息"
        },
        {
          "name": "schedule_list[].schedule.scheduleList.schedule_info.time_section.id",
          "type": "uint32",
          "required": false,
          "description": "时段id，为班次中某一堆上下班时间组合的id"
        },
        {
          "name": "schedule_list[].schedule.scheduleList.schedule_info.time_section.work_sec",
          "type": "uint32",
          "required": false,
          "description": "上班时间。距当天00:00的秒数"
        },
        {
          "name": "schedule_list[].schedule.scheduleList.schedule_info.time_section.off_work_sec",
          "type": "uint32",
          "required": false,
          "description": "下班时间。距当天00:00的秒数"
        },
        {
          "name": "schedule_list[].schedule.scheduleList.schedule_info.time_section.remind_work_sec",
          "type": "uint32",
          "required": false,
          "description": "上班提醒时间。距当天00:00的秒数"
        },
        {
          "name": "schedule_list[].schedule.scheduleList.schedule_info.time_section.remind_off_work_sec",
          "type": "uint32",
          "required": false,
          "description": "下班提醒时间。距当天00:00的秒数"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"starttime\": 1492617600,\n    \"endtime\": 1492790400,\n    \"useridlist\": [\n        \"james\",\n        \"paul\"\n    ]\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"schedule_list\":[\n        {\n            \"userid\":\"james\",\n            \"yearmonth\":202011,\n            \"groupid\":11,\n            \"groupname\":\"排班\",\n            \"schedule\":{\n                \"scheduleList\":[\n                    {\n                        \"day\":25,\n                        \"schedule_info\":{\n                            \"schedule_id\":229,\n                            \"schedule_name\":\"早班\",\n                            \"time_section\":[\n                                {\n                                    \"id\":1,\n                                    \"work_sec\":32400,\n                                    \"off_work_sec\":43200,\n                                    \"remind_work_sec\":32400,\n                                    \"remind_off_work_sec\":43200\n                                }\n                            ]\n                        }\n                    },\n                    {\n                        \"day\":26,\n                        \"schedule_info\":{\n                            \"schedule_id\":171,\n                            \"schedule_name\":\"晚班\",\n                            \"time_section\":[\n                                {\n                                    \"id\":2,\n                                    \"work_sec\":64800,\n                                    \"off_work_sec\":79200,\n                                    \"remind_work_sec\":64800,\n                                    \"remind_off_work_sec\":79200\n                                }\n                            ]\n                        }\n                    },\n                    {\n                        \"day\":30,\n                        \"schedule_info\":{\n                            \"schedule_id\":0,\n                            \"schedule_name\":\"休息\",\n                            \"time_section\":[\n\n                            ]\n                        }\n                    }\n                ]\n            }\n        }\n    ],\n    \"errcode\":0,\n    \"errmsg\":\"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}