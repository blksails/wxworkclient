{
  "page_title": "设置专区接收回调事件",
  "apis": [
    {
      "group_title": "设置专区接收回调事件",
      "api_name": "set_receive_callback",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/chatdata/set_receive_callback",
      "description": "应用可通过该接口设置专区中接收回调的程序id。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "访问令牌"
        }
      ],
      "body_params": [
        {
          "name": "program_id",
          "type": "string",
          "required": true,
          "description": "应用关联的程序id，同一个应用只能设置一个程序接收。若先设置了程序A接收，再调用该接口设置程序B时，会更改为程序B接收"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n  \"program_id\": \"xxx\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}