{
  "page_title": "自动激活回调通知",
  "apis": [
    {
      "group_title": "自动激活回调通知",
      "api_name": "auto_activate",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/webhook/callback/auto_activate",
      "description": "企业成员满足自动激活条件并触发自动激活后，企业微信后台会推送“自动激活通知”到服务商的系统事件接收URL。",
      "query_params": [],
      "body_params": [],
      "response_params": [
        {
          "name": "ServiceCorpId",
          "type": "string",
          "required": false,
          "description": "服务商CorpID"
        },
        {
          "name": "InfoType",
          "type": "string",
          "required": false,
          "description": "事件类型，此时固定为auto_activate"
        },
        {
          "name": "AuthCorpId",
          "type": "string",
          "required": false,
          "description": "客户企业CorpID"
        },
        {
          "name": "Scene",
          "type": "string",
          "required": false,
          "description": "许可自动激活的时机，1:企业成员主动访问应用，2:服务商调用消息推送接口，3:服务商调用互通接口"
        },
        {
          "name": "TimeStamp",
          "type": "string",
          "required": false,
          "description": "时间戳"
        },
        {
          "name": "AccountList",
          "type": "object",
          "required": false,
          "description": "激活的许可账号列表"
        },
        {
          "name": "AccountList.ActiveCode",
          "type": "string",
          "required": false,
          "description": "自动激活的许可账号激活码"
        },
        {
          "name": "AccountList.Type",
          "type": "string",
          "required": false,
          "description": "自动激活的许可的类型，1:基础许可，2:互通许可"
        },
        {
          "name": "AccountList.ExpireTime",
          "type": "string",
          "required": false,
          "description": "自动激活后，该许可的到期时间"
        },
        {
          "name": "AccountList.UserId",
          "type": "string",
          "required": false,
          "description": "许可自动激活的成员的UserID"
        },
        {
          "name": "AccountList.PreviousStatus",
          "type": "string",
          "required": false,
          "description": "激活成员自动激活前的许可状态，1:未激活许可，2:已激活许可且许可未过期（即许可的剩余时长小于等于7天），3:已激活许可且许可已过期"
        },
        {
          "name": "AccountList.PreviousActiveCode",
          "type": "string",
          "required": false,
          "description": "仅针对已激活的成员进行自动激活时返回，返回该成员之前激活的旧的激活码"
        }
      ],
      "request_examples": [
        {
          "title": "事件示例",
          "language": "xml",
          "code": "<xml>\n\t\t<ServiceCorpId><![CDATA[aaaa]]></ServiceCorpId>\n\t\t<InfoType><![CDATA[auto_activate]]></InfoType>\n\t\t<AuthCorpId><![CDATA[bbbb]]></AuthCorpId>\n\t\t<Scene>1</Scene>\n\t\t<TimeStamp>1403610513</TimeStamp>\n\t\t<AccountList>\n\t\t\t<ActiveCode><![CDATA[XXXX]]></ActiveCode>\n\t\t\t<Type>1</Type>\n\t\t\t<ExpireTime>1700000000</ExpireTime>\n\t\t\t<UserId><![CDATA[USERID]]></UserId>\n\t\t\t<PreviousStatus>1</PreviousStatus>\n\t\t\t<PreviousActiveCode><![CDATA[YYYY]]></PreviousActiveCode>\n\t\t</AccountList>\n</xml>"
        }
      ],
      "response_examples": []
    }
  ]
}