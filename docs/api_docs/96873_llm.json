{
  "page_title": "获取下级/下游企业的access_token",
  "apis": [
    {
      "group_title": "获取下级/下游企业的access_token",
      "api_name": "gettoken",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/corpgroup/corp/gettoken",
      "description": "获取应用可见范围内下级/下游企业的access_token，该access_token可用于调用下级/下游企业通讯录的只读接口。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证，上级/上游企业应用access_token"
        }
      ],
      "body_params": [
        {
          "name": "corpid",
          "type": "string",
          "required": true,
          "description": "已授权的下级/下游企业corpid"
        },
        {
          "name": "business_type",
          "type": "int32",
          "required": false,
          "description": "填0则为企业互联/局校互联，填1则表示上下游企业，默认0"
        },
        {
          "name": "agentid",
          "type": "uint32",
          "required": true,
          "description": "已授权的下级/下游企业应用ID"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "出错返回码，为0表示成功，非0表示调用失败"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "返回码提示语"
        },
        {
          "name": "access_token",
          "type": "string",
          "required": false,
          "description": "获取到的下级/下游企业调用凭证，最长为512字节"
        },
        {
          "name": "expires_in",
          "type": "uint32",
          "required": false,
          "description": "凭证的有效时间（秒）"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n\t\"corpid\": \"wwabc\",\n\t\"business_type\":1,\n\t\"agentid\": 1111\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\",\n   \"access_token\": \"accesstoken000001\",\n   \"expires_in\": 7200\n}"
        }
      ],
      "sections": []
    }
  ]
}