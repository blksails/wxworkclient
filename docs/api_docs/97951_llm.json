{
  "page_title": "第三方应用开发 - 服务端API - 微盘 - 上传文件",
  "apis": [
    {
      "group_title": "上传文件",
      "api_name": "file_upload",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/wedrive/file_upload?access_token=ACCESS_TOKEN",
      "description": "该接口用于向微盘中的指定位置上传文件。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "spaceid",
          "type": "string",
          "required": false,
          "description": "空间spaceid"
        },
        {
          "name": "fatherid",
          "type": "string",
          "required": false,
          "description": "父目录fileid, 在根目录时为空间spaceid"
        },
        {
          "name": "selected_ticket",
          "type": "string",
          "required": false,
          "description": "[微盘和文件选择器jsapi](#40357)返回的selectedTicket。若填此参数，则不需要填`spaceid`/`fatherid`。"
        },
        {
          "name": "file_name",
          "type": "string",
          "required": true,
          "description": "文件名字（注意：文件名最多填255个字符, 英文算1个, 汉字算2个）"
        },
        {
          "name": "file_base64_content",
          "type": "string",
          "required": true,
          "description": "文件内容base64（注意：只需要填入文件内容的Base64，不需要添加任何如:\"data:application/x-javascript;base64\" 的数据类型描述信息），文件大小上限为10M。大于10M文件，可使用[文件分块上传](#40102)接口"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "错误码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "错误码说明"
        },
        {
          "name": "fileid",
          "type": "string",
          "required": false,
          "description": "新建文件的fielid"
        }
      ],
      "request_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n    \"spaceid\": \"SPACEID\",\n    \"fatherid\": \"FATHERID\",\n    \"selected_ticket\": \"SELECTED_TICKET\",\n    \"file_name\": \"FILE_NAME\",\n    \"file_base64_content\": \"FILE_BASE64_CONTENT\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\",\n    \"fileid\": \"FILEID\"\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "* 自建应用需配置到“[可调用应用](#23784)”列表中的应用secret所获取的accesstoken来调用（[accesstoken如何获取？](#10013/%E7%AC%AC%E4%B8%89%E6%AD%A5%EF%BC%9A%E8%8E%B7%E5%8F%96access_token)）\n* 第三方应用需具有“微盘”权限\n* 代开发自建应用需具有“微盘”权限"
        }
      ]
    }
  ]
}