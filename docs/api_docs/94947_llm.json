{
  "page_title": "撤回应用消息",
  "apis": [
    {
      "group_title": "撤回应用消息",
      "api_name": "recall",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/message/recall",
      "description": "本接口可以撤回24小时内通过发送应用消息接口推送的消息，仅可撤回企业微信端的数据，微信插件端的数据不支持撤回。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证。获取方法查看“获取access_token”"
        }
      ],
      "body_params": [
        {
          "name": "msgid",
          "type": "string",
          "required": true,
          "description": "消息ID。从应用发送消息接口处获得。"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        }
      ],
      "request_examples": [
        {
          "title": "请求包体示例",
          "language": "json",
          "code": "{\n\t\"msgid\": \"vcT8gGc-7dFb4bxT35ONjBDz901sLlXPZw1DAMC_Gc26qRpK-AK5sTJkkb0128t\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n   \"errcode\": 0,\n   \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": []
    }
  ]
}