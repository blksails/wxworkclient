{
  "page_title": "获取获客链接使用成员接受消息数据",
  "apis": [
    {
      "group_title": "获取获客链接使用成员接受消息数据",
      "api_name": "get_chat_info",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/customer_acquisition/get_chat_info",
      "description": "获客组件可通过此接口获取成员收消息情况，如次数、客户来源等信息。",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "chat_key",
          "type": "string",
          "required": true,
          "description": "[成员多次收消息事件](#42924/%E6%88%90%E5%91%98%E5%A4%9A%E6%AC%A1%E6%94%B6%E6%B6%88%E6%81%AF%E4%BA%8B%E4%BB%B6)中回调的会话信息凭据ChatKey，回调后30分钟内有效"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "chat_info",
          "type": "object",
          "required": false,
          "description": ""
        },
        {
          "name": "chat_info.recv_msg_cnt",
          "type": "int32",
          "required": false,
          "description": "成员收到的某个客户的消息次数"
        },
        {
          "name": "chat_info.link_id",
          "type": "string",
          "required": false,
          "description": "成员添加客户的获客链接id"
        },
        {
          "name": "chat_info.state",
          "type": "string",
          "required": false,
          "description": "成员添加客户的state"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n  \"chat_key\":\"CHAT_KEY\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n\t\"errcode\": 0,\n\t\"errmsg\": \"ok\",\n\t\"chat_info\":\n\t{\n\t\t\t\"recv_msg_cnt\":3,\n\t\t\t\"link_id\":\"caXXXXXXX\",\n\t\t\t\"state\":\"STATE\"\n\t}\n}"
        }
      ],
      "sections": []
    }
  ]
}