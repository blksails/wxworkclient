{
  "page_title": "停止企业群发",
  "apis": [
    {
      "group_title": "停止企业群发",
      "api_name": "cancel_groupmsg_send",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/externalcontact/cancel_groupmsg_send",
      "description": "企业和第三方应用可调用此接口，停止无需成员继续发送的企业群发",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证"
        }
      ],
      "body_params": [
        {
          "name": "msgid",
          "type": "string",
          "required": true,
          "description": "群发消息的id，通过获取群发记录列表接口返回"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        }
      ],
      "request_examples": [
        {
          "title": "请求示例",
          "language": "json",
          "code": "{\n    \"msgid\": \"msgGCAAAXtWyujaWJHDDGi0mACAAAA\"\n}"
        }
      ],
      "response_examples": [
        {
          "title": "返回结果示例",
          "language": "json",
          "code": "{\n    \"errcode\": 0,\n    \"errmsg\": \"ok\"\n}"
        }
      ],
      "sections": [
        {
          "title": "权限说明",
          "content": "企业需要使用配置到“可调用应用”列表中的自建应用secret所获取的accesstoken来调用。第三方应用调用需要企业授权客户联系下群发消息给客户和客户群的权限；营销获客类应用需要拥有“客户联系权限->消息推送权限->群发消息给客户和客户群”权限。"
        },
        {
          "title": "注意事项",
          "content": "注意，此接口无法撤回已经群发给客户的消息。"
        }
      ]
    }
  ]
}