      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/corpgroup/corp/get_chain_corpinfo_list",
      "description": "自建应用/代开发应用可通过该接口获取企业上下游通讯录的某个分组下的企业列表",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证。上游企业应用access_token"
        }
      ],
      "body_params": [
        {
          "name": "chain_id",
          "type": "string",
          "required": true,
          "description": "上下游id"
        },
        {
          "name": "groupid",
          "type": "int32",
          "required": false,
          "description": "分组id。如果不填，表示根目录"
