        {
          "name": "group_corps[].pending_corpid",
          "type": "string",
          "required": false,
          "description": "未加入企业id"
        },
        {
          "name": "group_corps[].is_joined",
          "type": "int32",
          "required": false,
          "description": "企业是否已加入"
        }
      ],
      "request_examples": [],
      "response_examples": []
    },
