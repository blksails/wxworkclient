{
  "page_title": "服务商代开发 - 服务端API - 上下游 - 上下游通讯录管理",
  "apis": [
    {
      "group_title": "获取上下游列表",
      "api_name": "get_chain_list",
      "method": "GET",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/corpgroup/corp/get_chain_list",
      "description": "自建应用/代开发应用可调用，仅返回应用可见范围内的上下游列表",
      "query_params": [
        {
          "name": "access_token",
          "type": "string",
          "required": true,
          "description": "调用接口凭证。上游企业应用access_token"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "chains",
          "type": "object[]",
          "required": false,
          "description": "企业上下游列表"
        },
        {
          "name": "chains[].chain_id",
          "type": "string",
          "required": false,
          "description": "上下游id"
        },
        {
          "name": "chains[].chain_name",
          "type": "string",
          "required": false,
          "description": "上下游名称"
        }
      ],
      "request_examples": [],
      "response_examples": []
    },
    {
      "group_title": "获取上下游通讯录分组",
      "api_name": "get_chain_group",
      "method": "POST",
      "api_url": "https://qyapi.weixin.qq.com/cgi-bin/corpgroup/corp/get_chain_group",
      "description": "自建应用/代开发应用可通过该接口获取企业上下游通讯录分组详情",
      "query_params": [
