          "required": true,
          "description": "调用接口凭证。上游企业应用access_token"
        }
      ],
      "body_params": [
        {
          "name": "chain_id",
          "type": "string",
          "required": true,
          "description": "上下游id"
        },
        {
          "name": "groupid",
          "type": "int32",
          "required": false,
          "description": "分组id。填写此参数返回指定分组，不填则返回全部分组"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "groups",
          "type": "object[]",
          "required": false,
          "description": "分组列表数据"
        },
        {
          "name": "groups[].groupid",
          "type": "int32",
          "required": false,
          "description": "分组id"
        },
        {
          "name": "groups[].group_name",
          "type": "string",
          "required": false,
          "description": "分组名称"
        },
        {
          "name": "groups[].parentid",
          "type": "int32",
          "required": false,
          "description": "父分组id。根分组id为1"
        },
        {
          "name": "groups[].order",
          "type": "int32",
          "required": false,
          "description": "父部门中的次序值。order值大的排序靠前。值范围是[0, 2^32)"
        }
      ],
      "request_examples": [],
      "response_examples": []
    },
    {
      "group_title": "获取企业上下游通讯录分组下的企业详情列表",
      "api_name": "get_chain_corpinfo_list",
