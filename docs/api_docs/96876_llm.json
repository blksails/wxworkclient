        {
          "name": "cursor",
          "type": "string",
          "required": false,
          "description": "开启分页使用，传入返回值next_cursor"
        },
        {
          "name": "limit",
          "type": "int32",
          "required": false,
          "description": ">0开启分页功能"
        }
      ],
      "response_params": [
        {
          "name": "errcode",
          "type": "int32",
          "required": false,
          "description": "返回码"
        },
        {
          "name": "errmsg",
          "type": "string",
          "required": false,
          "description": "对返回码的文本描述内容"
        },
        {
          "name": "has_more",
          "type": "bool",
          "required": false,
          "description": "开启分页时告知是否还有更多记录"
        },
        {
          "name": "next_cursor",
          "type": "string",
          "required": false,
          "description": "下次请求时应传入的cursor"
        },
        {
          "name": "group_corps",
          "type": "object[]",
          "required": false,
          "description": "分组列表数据"
        },
        {
          "name": "group_corps[].groupid",
          "type": "int32",
          "required": false,
          "description": "企业所属上下游的分组id"
        },
        {
          "name": "group_corps[].corpid",
          "type": "string",
          "required": false,
          "description": "企业id，最多64个字节，已加入的企业返回"
        },
        {
          "name": "group_corps[].corp_name",
          "type": "string",
          "required": false,
          "description": "企业名称"
        },
        {
          "name": "group_corps[].custom_id",
          "type": "string",
          "required": false,
          "description": "上下游企业自定义id"
        },
        {
          "name": "group_corps[].invite_userid",
          "type": "string",
          "required": false,
          "description": "该上下游的邀请人的userid"
